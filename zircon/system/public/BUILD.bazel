# The logic in BUILD.gn is too complex for bazel2gn, manually keep these
# files synchronized.
# LINT.IfChange
load("@rules_cc//cc:defs.bzl", "cc_library")
load("//build/bazel/platforms:constraints.bzl", "HOST_OS_CONSTRAINTS")

cc_library(
    name = "public",
    hdrs = [
        "zircon/analyzer.h",
        "zircon/compiler.h",
        "zircon/errors.h",
        "zircon/fidl.h",
        "zircon/limits.h",
        "zircon/rights.h",
        "zircon/syscalls/iob.h",
        "zircon/syscalls/object.h",
        "zircon/time.h",
        "zircon/types.h",
    ],
    includes = ["."],
    visibility = ["//visibility:public"],
)

# LINT.ThenChange(BUILD.gn)
