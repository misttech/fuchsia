import("//build/dist/resource.gni")
import("//build/fuzz.gni")
import("//build/test.gni")
import("//build/testing/bootfs_test.gni")

group("tests") {
  testonly = true
  deps = [
    ":trace-reader-fuzzer-host($host_toolchain)",
    ":trace-reader-fuzzers",
  ]
}

test("trace-reader-test") {
  output_name = "trace-reader-test-test"
  if (is_fuchsia) {
    fdio_config = [ "//build/config/fuchsia:fdio_config" ]
    if (configs + fdio_config - fdio_config != configs) {
      configs -= fdio_config
    }
  }
  sources = [
    "file_reader_tests.cc",
    "reader_tests.cc",
    "records_tests.cc",
  ]
  deps = [
    "//sdk/lib/fit",
    "//zircon/system/ulib/trace-engine:trace-engine-headers-for-reader",
    "//zircon/system/ulib/trace-reader",
    "//zircon/system/ulib/zxtest",
  ]
  if (is_fuchsia) {
    deps += [
      "//sdk/lib/fdio",
      "//zircon/system/ulib/zx",
    ]
  }
}

bootfs_test("trace-reader-test-bootfs-test") {
  name = "trace-reader-test-test"
  deps = [ ":trace-reader-test" ]
}

fuchsia_library_fuzzer("trace-reader-fuzzer-fuchsia") {
  sources = [ "fuzz_test.cc" ]
  deps = [ "//zircon/system/ulib/trace-reader" ]
}

host_library_fuzzer("trace-reader-fuzzer-host") {
  sources = [ "fuzz_test.cc" ]
  deps = [ "//zircon/system/ulib/trace-reader" ]
}

resource("fxt-corpus") {
  sources = [
    "//src/performance/trace2json/test_data/example_benchmark.fxt",
    "//src/performance/trace2json/test_data/no_magic.fxt",
    "//src/performance/trace2json/test_data/simple_trace.fxt",
  ]
  outputs = [ "data/fxt-corpus/{{source_file_part}}" ]
}

fuchsia_fuzzer_component("trace-reader-fuzzer-cpp") {
  component_name = "trace-reader-fuzzer"
  manifest = "meta/reader-fuzzer.cml"
  deps = [
    ":fxt-corpus",
    ":trace-reader-fuzzer-fuchsia",
  ]
}

fuchsia_fuzzer_package("trace-reader-fuzzers") {
  package_name = "trace-reader-fuzzer"
  cpp_fuzzer_components = [ ":trace-reader-fuzzer-cpp" ]
}
