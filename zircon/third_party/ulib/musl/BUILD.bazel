load("//build/bazel/rules/cc:fx_cc_library.bzl", "fx_cc_library")

package(default_applicable_licenses = ["//:license"])

# We share just this internal header with fdio so it can implement
# getifaddrs re-using this address manipulation code.
fx_cc_library(
    name = "getifaddrs-internal",
    hdrs = [
        "src/network/getifaddrs.h",
        "src/network/netlink.h",
    ],
    includes = ["."],
    visibility = ["//sdk/lib/fdio:__subpackages__"],
)
