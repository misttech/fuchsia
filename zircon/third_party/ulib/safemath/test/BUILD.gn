import("//build/components.gni")
import("//build/test.gni")

group("tests") {
  testonly = true
  deps = [ ":safemath-test-pkg" ]
}

test("safemath") {
  output_name = "safemath-test"
  sources = [ "byte_conversions_unittest.cc" ]
  deps = [
    "//sdk/lib/stdcompat",
    "//zircon/system/ulib/zxtest",
    "//zircon/third_party/ulib/safemath",
  ]
}

fuchsia_unittest_package("safemath-test-pkg") {
  deps = [ ":safemath" ]
}
