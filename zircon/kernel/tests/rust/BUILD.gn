import("//build/rust/rustc_staticlib.gni")
import("//zircon/kernel/params.gni")

source_set("kernel-tests") {
  testonly = true
  if (enable_rust_in_zircon) {
    sources = [ "rust-tests.cc" ]
    deps = [
      ":trivial_tests",
      "//zircon/kernel/lib/unittest",
    ]
  }
}

rustc_staticlib("trivial_tests") {
  testonly = true
  visibility = [ ":*" ]

  edition = "2024"
  sources = [ "src/lib.rs" ]
  deps = [ "test_macro" ]
}
