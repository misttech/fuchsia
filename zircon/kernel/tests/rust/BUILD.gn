import("//zircon/kernel/kernel_rust_crate.gni")
import("//zircon/kernel/params.gni")

source_set("kernel-tests") {
  testonly = true
  sources = [ "rust-tests.cc" ]
  deps = [
    ":trivial_tests",
    "//zircon/kernel/lib/unittest",
  ]
}

kernel_rust_crate("trivial_tests") {
  testonly = true
  visibility = [ ":*" ]
  sources = [ "src/lib.rs" ]
  deps = [ "test_macro" ]
}
