import("//zircon/kernel/kernel_rust_crate.gni")
import("//zircon/kernel/params.gni")

# This directory has tests of the Rust build support and fundamental features
# of the compiler and cross-language linkage support.  It is not a place to put
# tests for other kernel code that happens to be in Rust.

source_set("kernel-tests") {
  testonly = true
  sources = [ "rust-tests.cc" ]
  deps = [
    ":trivial_tests",
    "//zircon/kernel/lib/unittest",
  ]
}

kernel_rust_crate("trivial_tests") {
  testonly = true
  visibility = [ ":*" ]
  sources = [ "src/lib.rs" ]
  deps = [ "test_macro" ]
}
