import("//build/zircon/zircon_cpu.gni")
import("//zircon/kernel/params.gni")

source_set("top") {
  sources = [
    "debug.cc",
    "handoff.cc",
    "init.cc",
    "main.cc",
  ]
  deps = [
    "//src/lib/elfldltl",
    "//src/lib/ksync",
    "//src/lib/zbitl",
    "//zircon/kernel/arch:arch-rs",
    "//zircon/kernel/arch/$zircon_cpu",
    "//zircon/kernel/dev:init",
    "//zircon/kernel/dev/hw_rng",
    "//zircon/kernel/kernel",
    "//zircon/kernel/lib/backtrace",
    "//zircon/kernel/lib/boot-options",
    "//zircon/kernel/lib/code-patching:self-test",
    "//zircon/kernel/lib/console",
    "//zircon/kernel/lib/counters",
    "//zircon/kernel/lib/counters:counters-rs",
    "//zircon/kernel/lib/crashlog",
    "//zircon/kernel/lib/cxxabi-dynamic-init:headers",
    "//zircon/kernel/lib/debuglog",
    "//zircon/kernel/lib/flow-id:flow-id-rs",
    "//zircon/kernel/lib/heap",
    "//zircon/kernel/lib/init",
    "//zircon/kernel/lib/io",
    "//zircon/kernel/lib/jtrace:headers",
    "//zircon/kernel/lib/lockup_detector",
    "//zircon/kernel/lib/page",
    "//zircon/kernel/lib/thread-stack",
    "//zircon/kernel/lib/userabi",
    "//zircon/kernel/lib/version",
    "//zircon/kernel/phys:boot-constants",
    "//zircon/kernel/phys:handoff",
    "//zircon/kernel/phys:zircon-abi-spec",
    "//zircon/kernel/platform",
    "//zircon/kernel/platform:platform-rs",
    "//zircon/kernel/vm:vm-rs",
  ]
  if (enable_rust_in_zircon) {
    deps += [ "//zircon/kernel/lib/ktrace:ktrace-rs" ]
  }
}
