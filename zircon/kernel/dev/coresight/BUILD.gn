import("//build/cpp/library_headers.gni")

static_library("coresight") {
  public_deps = [ ":headers" ]

  sources = [
    "component.cc",
    "rom_table.cc",
  ]
}

library_headers("headers") {
  headers = [
    "dev/coresight/component.h",
    "dev/coresight/rom_table.h",
  ]

  public_deps = [
    # <dev/coresight/component.h> has #include <hwreg/bitfields.h>.
    # <dev/coresight/rom_table.h> has #include <hwreg/bitfields.h>.
    # <dev/coresight/rom_table.h> has #include <hwreg/internal.h>.
    "//zircon/system/ulib/hwreg:headers",

    # <dev/coresight/rom_table.h> has #include <lib/fit/result.h>.
    "//sdk/lib/fit",
  ]
}
