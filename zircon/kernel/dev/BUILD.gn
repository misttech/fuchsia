source_set("init") {
  sources = [ "init.cc" ]
  deps = [
    "//zircon/kernel/lib/boot-options",
    "//zircon/kernel/phys:handoff",
  ]
}

group("kernel-tests") {
  testonly = true
  deps = []
  if (current_cpu == "arm64") {
    deps += [
      "interrupt/gic/v2:kernel-tests",
      "timer/arm_generic:kernel-tests",
    ]
  }
}
