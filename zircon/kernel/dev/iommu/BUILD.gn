import("//build/cpp/library_headers.gni")

static_library("iommu") {
  public_deps = [ ":headers" ]

  sources = [ "bti.cc" ]

  deps = [
    "//zircon/kernel/lib/fbl",
    "//zircon/kernel/lib/libc",
    "//zircon/kernel/object:headers",
    "//zircon/kernel/vm:headers",
  ]
}

library_headers("headers") {
  headers = [
    "dev/iommu/bti.h",
    "dev/iommu/common.h",
    "dev/iommu/iommu.h",
    "dev/iommu/pmt.h",
  ]
}
