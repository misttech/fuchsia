import("//build/cpp/library_headers.gni")

static_library("stub") {
  public_deps = [
    ":headers",
    "//zircon/kernel/dev/iommu:headers",
  ]

  sources = [
    "stub_bti.cc",
    "stub_iommu.cc",
    "stub_pmt.cc",
  ]
  deps = [
    "//zircon/kernel/dev/iommu",
    "//zircon/kernel/lib/ktl",
    "//zircon/kernel/lib/libc",
    "//zircon/kernel/lib/page",
    "//zircon/kernel/vm:headers",
  ]
}

library_headers("headers") {
  headers = [ "dev/iommu/stub/stub.h" ]
  public_deps = [
    "//zircon/kernel/dev/iommu:headers",
    "//zircon/kernel/lib/ktl:headers",  # <dev/iommu/stub/stub.h> has #include
                                        # <ktl/unique_ptr.h>.
  ]
}
