import("//build/components.gni")
import("//build/test.gni")

cc_test_executable("arm_smmu_tests_binary") {
  # Tests
  sources = [
    "device_aspace_test.cc",
    "page_cache_test.cc",
    "smmu_mode_string_tests.cc",
  ]

  # The subset of code being tested on the host
  sources += [
    "../device_aspace.cc",
    "../smmu_mode.cc",
    "../translation_table_helper.cc",
  ]

  # Mocks and other dependencies
  sources += [
    "//zircon/system/ulib/region-alloc/region-alloc.cc",
    "mocks/pmm.cc",
  ]

  deps = [
    "//zircon/system/ulib/fbl",
    "//zircon/system/ulib/region-alloc:headers",
    "//zircon/system/ulib/zx",
    "//zircon/system/ulib/zxtest",
  ]

  # This causes our local mock headers to be found before the actual kernel
  # headers.
  include_dirs = [
    "mocks/include",  # mocks first
    "//zircon/kernel/dev/iommu/arm_smmu/include",  # arm_smmu headers next
    "//zircon/kernel/dev/iommu/include",  # generic iommu headers last
  ]

  include_dirs += [ "//zircon" ]
}

group("host_tests") {
  testonly = true
  deps = [ ":arm_smmu_tests($host_toolchain)" ]
}

group("tests") {
  testonly = true
  deps = [ ":host_tests" ]
}

if (is_host) {
  binary_dir = get_label_info(":arm_smmu_tests_binary($linux_x64_toolchain)",
                              "root_out_dir")
  host_test("arm_smmu_tests") {
    binary_path = "${binary_dir}/arm_smmu_tests_binary"
    deps = [ ":arm_smmu_tests_binary($linux_x64_toolchain)" ]
  }
}
