import("//build/cpp/library_headers.gni")

library_headers("headers") {
  headers = [ "dev/clocks_and_pmic/moonflower/init.h" ]
}

source_set("moonflower") {
  sources = [
    "moonflower_clocks_and_pmic.cc",
    "moonflower_qupv3_clock.cc",
    "moonflower_rcg_clock.cc",
  ]
  public_deps = [ ":headers" ]
  deps = [
    "//zircon/kernel/dev/pdev/clocks_and_pmic",
    "//zircon/kernel/lib/debuglog",
    "//zircon/kernel/lib/ktl",
    "//zircon/system/ulib/hwreg",
  ]
}
