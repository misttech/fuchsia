import("//build/cpp/library_headers.gni")

library_headers("headers") {
  headers = [ "lib/heap_profile.h" ]
  public_deps = [
    "//zircon/system/public",

    # <lib/heap_profile.h> has #include <lib/page/size.h>
    "//zircon/kernel/lib/page",

    # <lib/heap_profile.h> has #include <fbl/intrusive_hash_table.h>
    "//zircon/system/ulib/fbl",
  ]
}

source_set("profile") {
  public_deps = [ ":headers" ]
  if (is_host) {
    configs += [ "//build/config/fuchsia:enable_zircon_asserts" ]
  }
}

group("tests") {
  testonly = true
  deps = [ "tests" ]
}
