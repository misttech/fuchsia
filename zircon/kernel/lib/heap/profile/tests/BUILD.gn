import("//build/test.gni")

if (is_host) {
  test("profile_test") {
    testonly = true
    sources = [ "heap_profile_test.cc" ]

    deps = [
      "//zircon/kernel/lib/heap/profile",
      "//zircon/system/ulib/zxtest",
    ]
  }
}

group("tests") {
  testonly = true
  deps = [ ":profile_test($host_toolchain)" ]
}
