import("//build/cpp/library_headers.gni")

library_headers("headers") {
  headers = [ "lib/control-region.h" ]
  public_deps = [
    "//src/lib/lockdep:headers",
    "//zircon/kernel/lib/ktl:headers",
  ]
}

group("tests") {
  testonly = true
}

group("kernel-tests") {
  testonly = true
  deps = [ "tests" ]
}

group("phys-tests") {
  testonly = true
}

group("boot_tests") {
  testonly = true
}
