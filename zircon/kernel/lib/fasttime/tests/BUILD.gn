import("//build/components/fuchsia_unittest_package.gni")
import("//build/testing/cc_test_executable.gni")
import("//src/bringup/lib/restricted-machine/loadable.gni")

cc_test_executable("fasttime-unittests") {
  testonly = true

  sources = [ "fasttime_test.cc" ]
  deps = [
    "//sdk/lib/fdio",
    "//src/bringup/lib/restricted-machine",
    "//src/lib/fxl/test:gtest_main",
    "//zircon/kernel/lib/fasttime:headers",
    "//zircon/system/ulib/fbl",
    "//zircon/system/ulib/fzl",
    "//zircon/system/ulib/zx",
  ]
  data_deps = [ "loadable(//build/toolchain:linux_$current_cpu)" ]
  if (additional_restricted_cpu != "") {
    data_deps +=
        [ "loadable(//build/toolchain:linux_$additional_restricted_cpu)" ]
  }
}

fuchsia_unittest_package("fasttime-tests") {
  manifest = "meta/fasttime_unittests.cml"
  test_type = "system"
  deps = [ ":fasttime-unittests" ]
}

group("tests") {
  testonly = true
  deps = [ ":fasttime-tests" ]
}
