import("//build/test.gni")

if (is_host) {
  test("btree_test") {
    sources = [ "btree_test.cc" ]
    deps = [
      "//zircon/kernel/lib/btree",
      "//zircon/system/ulib/zxtest",
    ]
  }
}

group("tests") {
  testonly = true
  deps = [ ":btree_test($host_toolchain)" ]
}
