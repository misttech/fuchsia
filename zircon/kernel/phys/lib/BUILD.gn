all_libs = [
  "boot-shim",
  "memalloc",
]

group("lib") {
  testonly = true
  deps = all_libs
}

group("tests") {
  testonly = true
  deps = []
  foreach(lib, all_libs) {
    deps += [ "$lib:tests" ]
  }
}
