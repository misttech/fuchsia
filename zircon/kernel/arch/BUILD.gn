import("//build/rust/rustc_library.gni")

rustc_library("arch-rs") {
  edition = "2024"
  sources = [ "src/lib.rs" ]
  non_rust_deps = [ ":ffi" ]
}

source_set("ffi") {
  sources = [ "arch_ffi.cc" ]
  deps = [ "//zircon/kernel/lib/ktl" ]
}
