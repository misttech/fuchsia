import("//build/cpp/library_headers.gni")
import("//build/zircon/migrated_targets.gni")

library_headers("headers") {
  headers = [
    "lz4/lz4.h",
    "lz4/lz4frame.h",
  ]
}

static_library("lz4") {
  public_deps = [ ":headers" ]

  sources = [
    "src/lib/lz4.c",
    "src/lib/lz4.h",
    "src/lib/lz4frame.c",
    "src/lib/lz4frame.h",
    "src/lib/lz4hc.c",
    "src/lib/lz4hc.h",
    "src/lib/xxhash.c",
    "src/lib/xxhash.h",
  ]
  defines = [
    "XXH_NAMESPACE=LZ4_",

    # Preempt the default that will break symbols out of hidden visibility.
    "LZ4LIB_VISIBILITY=",

    # lz4frame.h doesn't let you just predefine LZ4FLIB_API like you can
    # LZ4LIB_VISIBILITY, so this kludge works with how its macros are
    # defined so the //third_party/lz4/src sources don't need to be touched.
    "LZ4_DLL_IMPORT=1",
    "__declspec(x)=",
  ]

  configs += [
    "//build/config:Wno-implicit-fallthrough",
    "//build/config:Wno-missing-declarations",
    "//build/config:Wno-missing-prototypes",
  ]
}

group("tests") {
  testonly = true
  deps = [
    "rust:tests",
    "test:tests",
  ]
}
