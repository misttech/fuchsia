import("//build/rust/rustc_library.gni")

rustc_library("lz4") {
  name = "lz4"
  edition = "2024"
  with_unit_tests = true
  sources = [ "src/lib.rs" ]
  deps = [ "//third_party/rust_crates:thiserror" ]
  non_rust_deps = [ "//third_party/lz4" ]
}

group("tests") {
  testonly = true
  deps = [ ":lz4_test($host_toolchain)" ]
}
