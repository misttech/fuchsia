import("//build/python/python_library.gni")

python_library("tenacity") {
  enable_mypy = false
  source_root = "src/tenacity"
  sources = [
    "__init__.py",
    "_asyncio.py",
    "_utils.py",
    "after.py",
    "before.py",
    "before_sleep.py",
    "nap.py",
    "retry.py",
    "stop.py",
    "tornadoweb.py",
    "wait.py",
  ]
}
