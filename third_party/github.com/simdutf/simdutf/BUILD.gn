config("simdutf_config") {
  include_dirs = [ "src/include" ]
}

source_set("simdutf") {
  sources = [ "src/src/simdutf.cpp" ]

  include_dirs = [ "src/src" ]

  public_configs = [ ":simdutf_config" ]

  # Suppress warnings in third-party code.
  configs += [ "//build/config:Wno-extra-semi" ]
}
