[package]
name = "splines"
version = "5.0.0"
license = "BSD-3-Clause"
authors = ["Dimitri Sabadie <hadronized@strongly-typed-thoughts.net>"]
description = "Spline interpolation made easy"
keywords = ["spline", "interpolation"]
categories = ["science"]
homepage = "https://git.sr.ht/~hadronized/splines"
repository = "https://git.sr.ht/~hadronized/splines"
documentation = "https://docs.rs/splines"
readme = "README.md"

rust-version = "1.86.0"
edition = "2024"

[features]
default = ["std"]
std = []

[dependencies]
cgmath = { version = ">=0.17, <0.19", optional = true }
glam = { version = ">=0.10, <0.31", optional = true }
nalgebra = { version = ">=0.21, <0.34", optional = true }
serde = { version = "1", features = ["derive"], optional = true }

# needed for no_std, to provide cos impl
num-traits = { version = "0.2", default-features = false, features = ["libm"], optional = true }

[dev-dependencies]
float-cmp = ">=0.6, < 0.11"
serde_json = "1"

[package.metadata.docs.rs]
features = ["std", "cgmath", "glam", "nalgebra", "serde"]

[[example]]
name = "hello-world"

[[example]]
name = "serialization"
required-features = ["serde"]
