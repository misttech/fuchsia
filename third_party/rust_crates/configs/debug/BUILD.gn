# THIS FILE IS FOR CONFIGS THAT ONLY APPLY IN THE DEBUG COMPILATION MODE

# All targets in this file will pick up this restricted visibility
visibility = [ "//third_party/rust_crates/*" ]

config("optimize_speed") {
  if (is_debug) {
    configs = [ "//build/config:optimize_speed" ]
  }
}
