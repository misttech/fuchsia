    name = "fake_dispatcher",
    deps = [
        "@pigweed//pw_async_fuchsia:fake_dispatcher",
    ],
)

cc_library(
    name = "dispatcher",
    deps = [
        "@pigweed//pw_async_fuchsia:dispatcher",
    ],
)

cc_library(
    name = "util",
    deps = [
        "@pigweed//pw_async_fuchsia:util",
    ],
)

alias(
    name = "pw_async_fuchsia_test",
    actual = "@pigweed//pw_async_fuchsia:pw_async_fuchsia_test",
)

alias(
    name = "test_pkg",
    actual = "@pigweed//pw_async_fuchsia:test_pkg",
)
