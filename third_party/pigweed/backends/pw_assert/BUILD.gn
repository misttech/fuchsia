import("//build_overrides/pigweed.gni")

config("backend_config") {
  include_dirs = [
    "$dir_pw_assert_fuchsia/assert_public_overrides",
    "$dir_pw_assert_fuchsia/check_public_overrides",
    "$dir_pw_assert_fuchsia/public",
  ]
  visibility = [ ":*" ]
}

source_set("pw_assert") {
  public_configs = [ ":backend_config" ]
  public = [
    "$dir_pw_assert_fuchsia/assert_public_overrides/pw_assert_backend/assert_backend.h",
    "$dir_pw_assert_fuchsia/check_public_overrides/pw_assert_backend/check_backend.h",
  ]
  sources = [ "$dir_pw_assert_fuchsia/assert.cc" ]
  deps = [ "$dir_pw_assert:facade" ]
}

# The assert backend deps that might cause circular dependencies, since
# pw_assert is so ubiquitous. pw_assert backends must provide their own "impl"
# target that collects their actual dependencies. The backend "impl" group may
# be empty if everything can go directly in the backend target without causing
# circular dependencies.
source_set("pw_assert.impl") {
}
