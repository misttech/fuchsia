config("tink_config") {
  cflags = [
    "-Wno-ignored-qualifiers",
    "-Wno-deprecated-declarations",
    "-Wno-deprecated-copy",
    "-Wno-extra-semi",
  ]
  include_dirs = [
    "$root_gen_dir/third_party/tink-cc/src",
    "//third_party/tink-cc/src",
  ]
}

config("tink_fips") {
  defines = [ "TINK_USE_FIPS=0" ]
}
