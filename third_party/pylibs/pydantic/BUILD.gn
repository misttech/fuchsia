import("//build/python/python_library.gni")

if (is_host) {
  python_library("pydantic") {
    enable_mypy = false
    library_name = "pydantic"

    sources = [
      "__init__.py",
      "_migration.py",
      "alias_generators.py",
      "aliases.py",
      "annotated_handlers.py",
      "class_validators.py",
      "color.py",
      "config.py",
      "dataclasses.py",
      "datetime_parse.py",
      "decorator.py",
      "env_settings.py",
      "error_wrappers.py",
      "errors.py",
      "fields.py",
      "functional_serializers.py",
      "functional_validators.py",
      "generics.py",
      "json.py",
      "json_schema.py",
      "main.py",
      "mypy.py",
      "networks.py",
      "parse.py",
      "py.typed",
      "root_model.py",
      "schema.py",
      "tools.py",
      "type_adapter.py",
      "types.py",
      "typing.py",
      "utils.py",
      "validate_call_decorator.py",
      "validators.py",
      "version.py",
      "warnings.py",

      # _internal
      "_internal/__init__.py",
      "_internal/_config.py",
      "_internal/_core_metadata.py",
      "_internal/_core_utils.py",
      "_internal/_dataclasses.py",
      "_internal/_decorators.py",
      "_internal/_decorators_v1.py",
      "_internal/_discriminated_union.py",
      "_internal/_docs_extraction.py",
      "_internal/_fields.py",
      "_internal/_forward_ref.py",
      "_internal/_generate_schema.py",
      "_internal/_generics.py",
      "_internal/_git.py",
      "_internal/_import_utils.py",
      "_internal/_internal_dataclass.py",
      "_internal/_known_annotated_metadata.py",
      "_internal/_mock_val_ser.py",
      "_internal/_model_construction.py",
      "_internal/_namespace_utils.py",
      "_internal/_repr.py",
      "_internal/_schema_gather.py",
      "_internal/_schema_generation_shared.py",
      "_internal/_serializers.py",
      "_internal/_signature.py",
      "_internal/_typing_extra.py",
      "_internal/_utils.py",
      "_internal/_validate_call.py",
      "_internal/_validators.py",

      # deprecated
      "deprecated/__init__.py",
      "deprecated/class_validators.py",
      "deprecated/config.py",
      "deprecated/copy_internals.py",
      "deprecated/decorator.py",
      "deprecated/json.py",
      "deprecated/parse.py",
      "deprecated/tools.py",

      # experimental
      "experimental/__init__.py",
      "experimental/arguments_schema.py",
      "experimental/pipeline.py",

      # plugin
      "plugin/__init__.py",
      "plugin/_loader.py",
      "plugin/_schema_validator.py",
    ]
    source_root = "src/pydantic"

    library_deps = [
      "//prebuilt/third_party/pydantic-core:pydantic_core",
      "//third_party/pylibs/annotated_types",
      "//third_party/pylibs/typing_extensions",
      "//third_party/pylibs/typing_inspection",
    ]
  }
}
