import("//build/python/python_library.gni")

if (is_host) {
  python_library("typing_inspection") {
    enable_mypy = false
    library_name = "typing_inspection"

    sources = [
      "__init__.py",
      "introspection.py",
      "py.typed",
      "typing_objects.py",
      "typing_objects.pyi",
    ]
    source_root = "src/src/typing_inspection"
  }
}
