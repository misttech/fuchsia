import("//build/python/python_library.gni")

if (is_host) {
  python_library("pyserial") {
    enable_mypy = false
    library_name = "serial"

    sources = [
      "__init__.py",
      "__main__.py",
      "rfc2217.py",
      "rs485.py",
      "serialposix.py",
      "serialutil.py",
      "serialwin32.py",
      "threaded/__init__.py",
      "tools/__init__.py",
      "tools/hexlify_codec.py",
      "tools/list_ports.py",
      "tools/list_ports_common.py",
      "tools/list_ports_linux.py",
      "tools/list_ports_osx.py",
      "tools/list_ports_posix.py",
      "tools/list_ports_windows.py",
      "tools/miniterm.py",
      "urlhandler/__init__.py",
      "urlhandler/protocol_alt.py",
      "urlhandler/protocol_cp2110.py",
      "urlhandler/protocol_hwgrep.py",
      "urlhandler/protocol_loop.py",
      "urlhandler/protocol_rfc2217.py",
      "urlhandler/protocol_socket.py",
      "urlhandler/protocol_spy.py",
      "win32.py",
    ]
    source_root = "src/serial"
  }
}
