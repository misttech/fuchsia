import("//build/python/python_library.gni")

if (is_host) {
  python_library("pyusb") {
    enable_mypy = false
    library_name = "usb"

    sources = [
      "__init__.py",
      "_debug.py",
      "_interop.py",
      "_lookup.py",
      "_objfinalizer.py",
      "backend/__init__.py",
      "backend/libusb0.py",
      "backend/libusb1.py",
      "backend/openusb.py",
      "control.py",
      "core.py",
      "legacy.py",
      "libloader.py",
      "util.py",
    ]
    source_root = "src/usb"
  }
}
