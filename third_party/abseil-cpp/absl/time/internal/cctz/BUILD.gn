# Please do not add more entries to this list. We plan to remove
# abseil-cpp from the Fuchsia platform source tree once cobalt
# moves out-of-tree.
visibility = [ "//third_party/abseil-cpp/*" ]

source_set("civil_time") {
  public_configs = [ "//third_party/abseil-cpp:abseil_config" ]

  sources = [ "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/civil_time_detail.cc" ]
  public = [
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/include/cctz/civil_time.h",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/include/cctz/civil_time_detail.h",
  ]
}

source_set("time_zone") {
  public_configs = [ "//third_party/abseil-cpp:abseil_config" ]

  sources = [
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_fixed.cc",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_fixed.h",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_format.cc",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_if.cc",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_if.h",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_impl.cc",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_impl.h",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_info.cc",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_info.h",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_libc.cc",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_libc.h",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_lookup.cc",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_posix.cc",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/time_zone_posix.h",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/tzfile.h",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/src/zone_info_source.cc",
  ]
  public = [
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/include/cctz/time_zone.h",
    "//third_party/abseil-cpp/src/absl/time/internal/cctz/include/cctz/zone_info_source.h",
  ]

  defines = []
  if (is_mac) {
    # Work-around for https://github.com/llvm/llvm-project/issues/117630
    defines += [ "_XOPEN_SOURCE=700" ]
  }

  deps = [ ":civil_time" ]

  if (is_fuchsia) {
    deps += [
      "//sdk/fidl/fuchsia.intl:fuchsia.intl_hlcpp",
      "//sdk/lib/async-loop:async-loop-cpp",
      "//sdk/lib/fdio:constants",
    ]
  }
}
