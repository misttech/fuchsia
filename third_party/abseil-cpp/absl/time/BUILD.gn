# Please do not add more entries to this list. We plan to remove
# abseil-cpp from the Fuchsia platform source tree once cobalt
# moves out-of-tree.
visibility = [
  "$cobalt_root/*",
  "//third_party/abseil-cpp/*",
  "//third_party/gvisor_syscall_tests/*",
  "//third_party/tink-cc/*",
]

source_set("time") {
  public_configs = [ "//third_party/abseil-cpp:abseil_config" ]

  sources = [
    "//third_party/abseil-cpp/src/absl/time/clock.cc",
    "//third_party/abseil-cpp/src/absl/time/duration.cc",
    "//third_party/abseil-cpp/src/absl/time/format.cc",
    "//third_party/abseil-cpp/src/absl/time/internal/get_current_time_chrono.inc",
    "//third_party/abseil-cpp/src/absl/time/internal/get_current_time_posix.inc",
    "//third_party/abseil-cpp/src/absl/time/time.cc",
  ]
  public = [
    "//third_party/abseil-cpp/src/absl/time/clock.h",
    "//third_party/abseil-cpp/src/absl/time/time.h",
  ]
  deps = [
    "../base",
    "../base:core_headers",
    "../numeric:int128",
    "../strings",
    "../time/internal/cctz:civil_time",
    "../time/internal/cctz:time_zone",
  ]
}
