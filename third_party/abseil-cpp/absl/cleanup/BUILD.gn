# Please do not add more entries to this list. We plan to remove
# abseil-cpp from the Fuchsia platform source tree once cobalt
# moves out-of-tree.
visibility = [
  "$cobalt_root/*",
  "//third_party/abseil-cpp/*",
  "//third_party/tink-cc/*",
  "//third_party/tink/*",
]

source_set("cleanup") {
  public_configs = [ "//third_party/abseil-cpp:abseil_config" ]

  public = [ "//third_party/abseil-cpp/src/absl/cleanup/cleanup.h" ]

  deps = [
    ":cleanup_internal",
    "../base:config",
    "../base:core_headers",
  ]
}

source_set("cleanup_internal") {
  public_configs = [ "//third_party/abseil-cpp:abseil_config" ]

  public = [ "//third_party/abseil-cpp/src/absl/cleanup/internal/cleanup.h" ]

  deps = [
    "../base:base_internal",
    "../base:core_headers",
    "../utility",
  ]
}
