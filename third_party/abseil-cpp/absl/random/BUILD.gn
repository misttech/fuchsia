# Please do not add more entries to this list. We plan to remove
# abseil-cpp from the Fuchsia platform source tree once cobalt
# moves out-of-tree.
visibility = [
  "$cobalt_root/*",
  "//third_party/abseil-cpp/*",
  "//third_party/tink/*",
]

source_set("random") {
  public = [ "//third_party/abseil-cpp/src/absl/random/random.h" ]
  public_configs = [ "//third_party/abseil-cpp:abseil_config" ]
  deps = [
    ":distributions",
    ":seed_sequences",
    "internal:entropy_pool",
    "internal:nonsecure_base",
    "internal:pcg_engine",
    "internal:randen_engine",
  ]
}

source_set("distributions") {
  sources = [
    "//third_party/abseil-cpp/src/absl/random/discrete_distribution.cc",
    "//third_party/abseil-cpp/src/absl/random/gaussian_distribution.cc",
  ]
  public = [
    "//third_party/abseil-cpp/src/absl/random/bernoulli_distribution.h",
    "//third_party/abseil-cpp/src/absl/random/beta_distribution.h",
    "//third_party/abseil-cpp/src/absl/random/discrete_distribution.h",
    "//third_party/abseil-cpp/src/absl/random/distributions.h",
    "//third_party/abseil-cpp/src/absl/random/exponential_distribution.h",
    "//third_party/abseil-cpp/src/absl/random/gaussian_distribution.h",
    "//third_party/abseil-cpp/src/absl/random/log_uniform_int_distribution.h",
    "//third_party/abseil-cpp/src/absl/random/poisson_distribution.h",
    "//third_party/abseil-cpp/src/absl/random/uniform_int_distribution.h",
    "//third_party/abseil-cpp/src/absl/random/uniform_real_distribution.h",
    "//third_party/abseil-cpp/src/absl/random/zipf_distribution.h",
  ]
  public_configs = [ "//third_party/abseil-cpp:abseil_config" ]
  deps = [
    "../base:base_internal",
    "../base:config",
    "../base:core_headers",
    "../meta:type_traits",
    "../numeric:bits",
    "../strings",
    "internal:distribution_caller",
    "internal:fast_uniform_bits",
    "internal:fastmath",
    "internal:generate_real",
    "internal:iostream_state_saver",
    "internal:traits",
    "internal:uniform_helper",
    "internal:wide_multiply",
  ]
}

source_set("seed_gen_exception") {
  sources = [ "//third_party/abseil-cpp/src/absl/random/seed_gen_exception.cc" ]
  public = [ "//third_party/abseil-cpp/src/absl/random/seed_gen_exception.h" ]
  public_configs = [ "//third_party/abseil-cpp:abseil_config" ]
  deps = [ "../base:config" ]
}

source_set("seed_sequences") {
  sources = [ "//third_party/abseil-cpp/src/absl/random/seed_sequences.cc" ]
  public = [ "//third_party/abseil-cpp/src/absl/random/seed_sequences.h" ]
  public_configs = [ "//third_party/abseil-cpp:abseil_config" ]
  deps = [
    ":seed_gen_exception",
    "../container:inlined_vector",
    "../types:span",
    "internal:entropy_pool",
    "internal:nonsecure_base",
    "internal:salted_seed_seq",
    "internal:seed_material",
  ]
}

source_set("bit_gen_ref") {
  public = [ "//third_party/abseil-cpp/src/absl/random/bit_gen_ref.h" ]
  public_configs = [ "//third_party/abseil-cpp:abseil_config" ]
  deps = [
    ":random",
    "../base:core_headers",
    "../base:fast_type_id",
    "../meta:type_traits",
    "internal:distribution_caller",
    "internal:fast_uniform_bits",
  ]
}
