import("//build/python/python_library.gni")

if (is_host) {
  python_library("PyMonsoon") {
    enable_mypy = false
    library_name = "Monsoon"

    sources = [
      "HVPM.py",
      "LVPM.py",
      "Main.py",
      "Operations.py",
      "PyMonsoon.pyproj",
      "PyMonsoon.sln",
      "README",
      "README.txt",
      "__init__.py",
      "calibrationData.py",
      "pmapi.py",
      "reflash.py",
      "sampleEngine.py",
      "setup.py",
    ]
    library_deps = [ "//third_party/pylibs/pyusb" ]
    source_root = "src"
  }
}
