load("@io_bazel_rules_go//go:def.bzl", "go_library")
load("@platforms//host:constraints.bzl", "HOST_CONSTRAINTS")
load("//build/bazel/host_tests:host_go_test.bzl", "host_go_test")
load("//build/bazel/rules/host:defs.bzl", "go_binary_host_tool")

package(default_applicable_licenses = ["//:license"])

# A regular library target. This does not compile any tests.
go_library(
    name = "lib",
    srcs = ["lib.go"],
    importpath = "go.fuchsia.dev/fuchsia/build/bazel/host_tests/go_tests/lib",
    target_compatible_with = HOST_CONSTRAINTS,
)

# A host test wrapping the library's tests, which will be visible to Fuchsia test runners
# as well as `bazel test`.
host_go_test(
    name = "lib_test",
    srcs = ["lib_test.go"],
    embed = [":lib"],
)

# A main library is the idiomatic way to allow tests to depend on the main
# binary's code.
go_library(
    name = "main_lib",
    srcs = ["main.go"],
    target_compatible_with = HOST_CONSTRAINTS,
    deps = [":lib"],
)

go_binary_host_tool(
    name = "main",
    embed = [":main_lib"],
    target_compatible_with = HOST_CONSTRAINTS,
)

host_go_test(
    name = "main_test",
    srcs = ["main_test.go"],
    embed = [":main_lib"],
)

test_suite(
    name = "go_tests",
    tests = [
        ":lib_test",
        ":main_test",
    ],
    visibility = ["//visibility:public"],
)
