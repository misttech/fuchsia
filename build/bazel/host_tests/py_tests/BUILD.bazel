load("@rules_python//python:py_library.bzl", "py_library")
load("@rules_python//python:py_test.bzl", "py_test")
load("//build/bazel/host_tests:host_test.bzl", "host_test")

test_suite(
    name = "py_tests",
    visibility = ["//visibility:public"],
)

host_test(
    name = "simple_test_host",
    binary = ":simple_test",
)

host_test(
    name = "test_with_py_library_host",
    binary = ":test_with_py_library",
)

host_test(
    name = "test_with_py_binary_host",
    binary = ":test_with_py_binary",
)

py_test(
    name = "simple_test",
    srcs = ["simple_test.py"],
)

py_test(
    name = "test_with_py_library",
    srcs = ["test_with_py_library.py"],
    deps = [":py_lib_for_test"],
)

py_library(
    name = "py_lib_for_test",
    srcs = ["lib_for_test.py"],
    imports = [
        ".",
        "foo",
    ],
)

py_test(
    name = "test_with_py_binary",
    srcs = ["test_with_py_binary.py"],
    data = [":test_with_py_library"],
    deps = ["@rules_python//python/runfiles"],
)
