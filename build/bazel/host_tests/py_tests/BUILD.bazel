load("@rules_python//python:py_library.bzl", "py_library")
load("//build/bazel/host_tests:host_py_test.bzl", "host_py_test")

package(default_applicable_licenses = ["//:license"])

test_suite(
    name = "py_tests",
    visibility = ["//visibility:public"],
)

host_py_test(
    name = "simple_test",
    srcs = ["simple_test.py"],
    main = "simple_test.py",
)

host_py_test(
    name = "test_with_py_library",
    srcs = ["test_with_py_library.py"],
    main = "test_with_py_library.py",
    deps = [":py_lib_for_test"],
)

py_library(
    name = "py_lib_for_test",
    srcs = ["lib_for_test.py"],
    imports = [
        ".",
        "foo",
    ],
)

host_py_test(
    name = "test_with_py_binary",
    srcs = ["test_with_py_binary.py"],
    test_args = ["$(rlocationpath :test_with_py_library_bin)"],
    test_data = [":test_with_py_library_bin"],
    deps = ["@rules_python//python/runfiles"],
)

# A simple test that contains unittests.TestCase classes.
# This supports the --list_host_python_unittests special argument
# to list its individual unit-tests, as required by `fx test --list <test>`.
host_py_test(
    name = "test_with_unittests",
    srcs = ["test_with_unittests.py"],
)

# A test to invoke test_with_unittests with `--list_host_python_unittests` and verify
# its output.
host_py_test(
    name = "list_unittests_test",
    srcs = ["list_unittests_test.py"],
    test_args = ["$(rlocationpath :test_with_unittests)"],
    test_data = [":test_with_unittests"],
    deps = ["@rules_python//python/runfiles"],
)
