load("//build/bazel/host_tests:host_test.bzl", "host_test")

test_suite(
    name = "cc_tests",
    tests = [
        ":dynamic_test_host",
        ":static_test_host",
    ],
    visibility = ["//visibility:public"],
)

host_test(
    name = "static_test_host",
    binary = ":static_test",
)

host_test(
    name = "dynamic_test_host",
    binary = ":dynamic_test",
)

# A simple statically linked test executable that does not use a runfiles library.
cc_test(
    name = "static_test",
    srcs = ["main.cc"],
    deps = [":foo"],
)

cc_library(
    name = "foo",
    srcs = ["foo.cc"],
    hdrs = ["foo.h"],
    # includes = [ "." ],
)

# A simple dynamically linked test executable, which calls a shared library function.
# Does not use a runfiles library.
cc_test(
    name = "dynamic_test",
    srcs = ["main.cc"],
    dynamic_deps = [":foo_shared"],
    deps = [":foo"],
)

cc_shared_library(
    name = "foo_shared",
    deps = [":foo"],
)

cc_test(
    name = "stdbool_c_test",
    srcs = ["main_stdbool.c"],
)
