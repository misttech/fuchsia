load("@platforms//host:constraints.bzl", "HOST_CONSTRAINTS")
load("//build/bazel/host_tests:host_rustc_test.bzl", "host_rustc_test")
load("//build/bazel/rules/rust:defs.bzl", "rustc_binary", "rustc_library")

rustc_library(
    name = "lib",
    srcs = ["lib.rs"],
    edition = "2024",
    target_compatible_with = HOST_CONSTRAINTS,
)

host_rustc_test(
    name = "lib_test",
    srcs = ["lib.rs"],
    edition = "2024",
)

rustc_library(
    name = "lib_with_test",
    srcs = ["lib.rs"],
    edition = "2024",
    target_compatible_with = HOST_CONSTRAINTS,
    with_host_unit_tests = True,
)

rustc_binary(
    name = "bin",
    srcs = ["main.rs"],
    edition = "2024",
    target_compatible_with = HOST_CONSTRAINTS,
    deps = [
        ":lib",
    ],
)

host_rustc_test(
    name = "bin_test",
    srcs = ["main.rs"],
    edition = "2024",
    deps = [
        ":lib",
    ],
)

rustc_binary(
    name = "bin_with_test",
    srcs = ["main.rs"],
    edition = "2024",
    target_compatible_with = HOST_CONSTRAINTS,
    with_host_unit_tests = True,
    deps = [
        ":lib",
    ],
)

test_suite(
    name = "rust_tests",
    tests = [
        ":bin_test",
        ":bin_with_test_test",
        ":lib_test",
        ":lib_with_test_test",
    ],
)
