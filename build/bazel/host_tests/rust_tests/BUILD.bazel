load("@platforms//host:constraints.bzl", "HOST_CONSTRAINTS")
load("//build/bazel/host_tests:host_rustc_test.bzl", "host_rustc_test")
load("//build/bazel/host_tests:host_test_data.bzl", "host_test_data_files")
load("//build/bazel/rules/rust:defs.bzl", "rustc_binary", "rustc_library")

package(default_applicable_licenses = ["//:license"])

# A regular library target. This does not compile any tests.
rustc_library(
    name = "lib",
    srcs = ["lib.rs"],
    edition = "2024",
    target_compatible_with = HOST_CONSTRAINTS,
)

# A host test wrapping the library's tests, which will be visible to Fuchsia test runners
# as well as `bazel test`.
host_rustc_test(
    name = "lib_test",
    srcs = ["lib.rs"],
    edition = "2024",
)

# The same library that also compiles its tests through a rust_test() target that will
# *not* be visible to Fuchsia test runners. To run it, one needs to use
# `fx bazel test --config=host //build/bazel/host_tests/rust_tests:lib_with_test_test`
rustc_library(
    name = "lib_with_test",
    srcs = ["lib.rs"],
    edition = "2024",
    target_compatible_with = HOST_CONSTRAINTS,
    with_host_unit_tests = True,
)

# Test target unit tests (built as host test here because of HOST_CONSTRAINTS)
rustc_library(
    name = "lib_with_target_test",
    srcs = ["lib.rs"],
    edition = "2024",
    target_compatible_with = HOST_CONSTRAINTS,
    with_unit_tests = True,
)

# A regular binary target, that does not compile any tests.
rustc_binary(
    name = "bin",
    srcs = ["main.rs"],
    edition = "2024",
    target_compatible_with = HOST_CONSTRAINTS,
    deps = [
        ":lib",
    ],
)

# A host test wrapping the binary's tests, which will be visible to Fuchsia test runners
# as well as `bazel test`.
host_rustc_test(
    name = "bin_test",
    srcs = ["main.rs"],
    edition = "2024",
    deps = [
        ":lib",
    ],
)

# The same binary that also compiles its tests through a rust_test() target that will
# *not* be visible to Fuchsia test runners. To run it, one needs to use
# `fx bazel test --config=host //build/bazel/host_tests/rust_tests:bin_with_test_test`.
rustc_binary(
    name = "bin_with_test",
    srcs = ["main.rs"],
    edition = "2024",
    target_compatible_with = HOST_CONSTRAINTS,
    with_host_unit_tests = True,
    deps = [
        ":lib",
    ],
)

# Test target unit tests for binary (built as host test here because of HOST_CONSTRAINTS)
rustc_binary(
    name = "bin_with_target_test",
    srcs = ["main.rs"],
    edition = "2024",
    target_compatible_with = HOST_CONSTRAINTS,
    with_unit_tests = True,
    deps = [
        ":lib",
    ],
)

# A small Rust binary that panics intentionally. Will be called
# at runtime by stacktrace_test.
rustc_binary(
    name = "panic_trigger",
    srcs = ["panic_trigger.rs"],
    edition = "2024",
)

host_test_data_files(
    name = "panic_trigger_as_test_data",
    srcs = [":panic_trigger"],
)

# A host test that runs panic_trigger. Used to verify that RUST_BACKTRACE=1 is
# properly passed when invoking the test.
host_rustc_test(
    name = "backtrace_test",
    srcs = ["backtrace_test.rs"],
    data = [":panic_trigger_as_test_data"],
    edition = "2024",
)

test_suite(
    name = "rust_tests",
    tests = [
        ":backtrace_test",
        ":bin_test",
        ":lib_test",
    ],
    visibility = ["//visibility:public"],
)
