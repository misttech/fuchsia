"""Tests for verity that host_test_data() works as expected."""

load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("//build/bazel/host_tests:host_test.bzl", "host_test")
load("//build/bazel/host_tests:host_test_data.bzl", "host_test_data_files", "host_test_data_map")

package(default_applicable_licenses = ["//:license"])

test_suite(
    name = "host_test_data_tests",
    visibility = ["//visibility:public"],
)

# A common C++ binary used to run all the tests. Its first argument determines which
# set of runtime dep files to check. Used by multiple host_test() targets below that
# specify a different set of dependencies.
cc_binary(
    name = "test_bin",
    srcs = ["main.cc"],
    data = [":data.for_test_bin"],
)

# This target is a data dependency of the test binary and thus should always
# be available when running any of the tests below.
host_test_data_files(
    name = "data.for_test_bin",
    srcs = ["test_bin.txt"],
)

# This target installs three files at the top of the test's runtime directory.
# It is used to check that sub-directory / package information from the source
# labels is ignored in the destination directory.
host_test_data_files(
    name = "data.files_list",
    srcs = [
        "subdir/test_data_2.txt",
        "test_data_1.txt",
        ":test_artifact",
    ],
)

# Same as above, but uses 'dest_dir' to specify an install location.
host_test_data_files(
    name = "data.files_list_with_dest_dir",
    srcs = [
        "subdir/test_data_2.txt",
        "test_data_1.txt",
        ":test_artifact",
    ],
    dest_dir = "test_data",
)

# This target installs three files into the test runtime directory at specific locations
# using a dictionary.
host_test_data_map(
    name = "data.explicit_map",
    files_map = {
        "data_1/test.txt": "test_data_1.txt",
        "subdir/data_2/test.txt": "subdir/test_data_2.txt",
        "obj/artifact": ":test_artifact",
    },
)

# This target generates an artifact that is used by some of the tests below.
genrule(
    name = "test_artifact",
    outs = ["artifact.txt"],
    cmd = "echo 'artifact' > $@",
)

# First test just checks that $runtime_dir/test_bin.txt has the right content.
host_test(
    name = "test_binary_data_dep",
    binary = ":test_bin",
    test_args = ["binary_data_dep"],
)

# Second test also checks for 'data' dependencies.
host_test(
    name = "test_data_deps",
    binary = ":test_bin",
    data = [":data.files_list"],
    test_args = ["data_deps"],
)

# Third test is the same as the second one, but the runtime dependencies come
# through filegroup() intermediate targets. This verifies that aspect collection
# works correctly
host_test(
    name = "test_data_filegroup_deps",
    binary = ":test_bin",
    data = [":data.filegroup"],
    test_args = ["data_filegroup_deps"],
)

filegroup(
    name = "data.filegroup",
    srcs = [
        ":data.files_list",
    ],
)

host_test(
    name = "test_explicit_map",
    binary = ":test_bin",
    data = [":data.explicit_map"],
    test_args = ["explicit_map"],
)

host_test(
    name = "test_dest_dir",
    binary = ":test_bin",
    data = [":data.files_list_with_dest_dir"],
    test_args = ["dest_dir"],
)
