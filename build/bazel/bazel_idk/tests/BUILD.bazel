# The headers used by some_library.cc are made available as follows for Fuchsia builds:
# * dependency.h: via `hdrs` in the `fuchsia_deps` ":test_source_set_dependency"
#   * This file includes another_header.h, which is available via
#     `hdrs_for_internal_use` in the deps ":test_source_set_dependency".
# * test_header.h: via `hdrs`
# dependency.h is also available via `hdrs` in the `deps`
# ":test_source_set_dependency2". This is required for non-Fuchsia builds.
idk_cc_source_library(
    name = "test-source-set",
    testonly = True,
    srcs = [
        "internal/helper.cc",
        "some_library.cc",
    ],
    hdrs = ["include/lib/test_lib/test_header.h"],
    api_area = "Developer",
    api_file_path = "different_file_name.api",
    category = "partner",
    fuchsia_deps = [
        # This target defines `RequiredFunction()`. The test executable would
        # fail to link if this dependency is not included in the `cc_library()`.
        ":test_source_set_dependency",
    ],
    idk_name = "test_source_set",
    stable = True,
    deps = [
        ":test_noop_atom",

        # Cover deps strings that omit the package path, omit the target name,
        # and provide the full label. The first case is covered in `fuchsia_deps`.
        "//build/bazel/bazel_idk/tests",
        "//build/bazel/bazel_idk/tests:test_source_set_dependency2",
    ],
)

# The headers used by some_library.cc are made available as follows for Fuchsia builds:
# * dependency.h: via `hdrs` in the `fuchsia_deps` ":test_source_set_dependency"
#   * This file includes another_header.h, which is available via
#     `hdrs_for_internal_use` in the deps ":test_source_set_dependency".
# * test_header.h: via `hdrs`
# dependency.h is also available via `hdrs` in the `deps`
# ":test_source_set_dependency2". This is required for non-Fuchsia builds.
idk_cc_shared_library(
    name = "test-shared-library",
    testonly = True,
    srcs = [
        "internal/helper.cc",
        "some_library.cc",
    ],
    hdrs = ["include/lib/test_lib/test_header.h"],
    api_area = "Developer",
    api_file_path = "different_file_name_shared_library.api",
    category = "partner",
    fuchsia_deps = [
        # This target defines `RequiredFunction()`. This library would
        # fail to link if this dependency is not included in the `cc_library()`.
        ":test_source_set_dependency",
    ],
    idk_name = "test_shared_library",
    output_name = "my_test_shared_library",
    deps = [
        # Cover deps strings that omit the package path, omit the target name,
        # and provide the full label. The first case is covered in `fuchsia_deps`.
        "//build/bazel/bazel_idk/tests",
        "//build/bazel/bazel_idk/tests:test_source_set_dependency2",
    ],
)

