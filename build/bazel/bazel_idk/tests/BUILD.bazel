idk_cc_source_library_zx(
    name = "test_source_set_zx",
    testonly = True,
    srcs = [
        "internal/helper.cc",
        "some_library.cc",
        "zx_source.cc",
    ],
    hdrs = ["include/lib/test_lib/test_header.h"],
    api_area = "Developer",
    category = "partner",
    # Test appending "_ALL_SOURCE" to an existing list of defines.
    defines = ["SOME_DEFINE"],
    fuchsia_deps = [
        # Test conversion of `foo:foo.headers` to `foo:foo` for `idk_deps` in `fuchsia_deps`.
        ":test_source_set_dependency_zx.headers",
    ],
    idk_name = "test_source_set_zx",
    implementation_deps = [
        # This target needs the full dependency to link (in the non-Fuchsia and
        # Zircon toolchain cases).
        # This also tests handling of duplicate dependencies when the headers targets are converted.
        ":test_source_set_dependency_zx",

        # Test conversion of `foo:foo.as-needed` to `foo:foo` for `idk_deps` in `implementation_deps`.
        ":test_source_set_dependency2_zx.as-needed",
    ],
    stable = True,
    deps = [
        # Test conversion of `foo:headers` to `foo:foo` for `idk_deps` in `deps`.
        ":headers",
    ],
)

idk_cc_shared_library_zx(
