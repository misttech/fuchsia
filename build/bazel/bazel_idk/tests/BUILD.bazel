    deps = [":atoms_to_build_for_each_cpu_and_api_level_combination_idk"],
)

# A filegroup of non-atom targets to build for each CPU and API level combination.
# Grouping the targets means that the transition will only run once per
# combination and allows `select()` statements to run in the context of the
# combination.
filegroup(
    name = "targets_to_build_for_each_cpu_and_api_level_combination",
    testonly = True,
    srcs = [
        # Depend directly on the underlying source libraries since they are not
        # dependencies of the atoms.
        ":all_underlying_source_libraries",

        # Exercise FIDL.
        # TODO(https://fxbug.dev/443762519): Remove these once FIDL bindings are
        # being used in API level configurations.
        "//examples/fidl/fuchsia.examples.docs",
        "//examples/fidl/fuchsia.examples.docs:versioning",
        # This tests indirect FIDL library dependencies.
        "//sdk/fidl/fuchsia.hardware.display.engine",
        # A FIDL library in a category.
        # Note that the "..._idk" IDK atom targets are not built in combinations.
        "//sdk/fidl/fuchsia.feedback",
    ] + select({
        # TODO(https://fxbug.dev/505380228): Merge these targets into the main
        # list once sysroots are available for all CPU architectures.
        "//build/bazel/platforms:is_fuchsia_" + target_cpu: [
            # Linking executables verifies that all deps are properly specified
            # and that FIDL bindings were generated correctly.
            ":all_test_executables",
        ],
        "//conditions:default": [],
    }),
    target_compatible_with = ["@platforms//os:fuchsia"],
)

build_in_all_idk_api_level_and_cpu_combinations(
    name = "all_api_level_and_cpu_combinations_non_idk_targets",
    testonly = True,
    target_compatible_with = ["@platforms//os:fuchsia"],
    # Do not add to this list. Add to
    # ":targets_to_build_for_each_cpu_and_api_level_combination" instead.
    deps = [":targets_to_build_for_each_cpu_and_api_level_combination"],
)

filegroup(
    name = "api_level_and_cpu_combinations_build_only_tests",
    testonly = True,
    # Do not add to this list. Add to the dependencies instead.
    srcs = [
        ":all_api_level_and_cpu_combinations_molecule_idk",
        ":all_api_level_and_cpu_combinations_non_idk_targets",
    ],
    target_compatible_with = ["@platforms//os:fuchsia"],
    visibility = ["//build/bazel/rules/tests:__pkg__"],
)

# Although this will output errors when built with `bazel build`, it will not
# fail the build. It must be run with `bazel test` in order for test failures to
# cause Bazel to fail.
analysis_test_suite(
    name = "analysis_tests",
    visibility = ["//build/bazel/rules/tests:__pkg__"],
)
