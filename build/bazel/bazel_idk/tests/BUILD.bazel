# Tests use of `select()` with header and source files.
# Also tests that `hdrs_for_internal_use` appear in the API file as appropriate.
# buildifier: leave-alone - Preserve attribute ordering for illustrative purposes.
idk_cc_source_library(
    name = "platform_dependent_source_library",
    testonly = True,

    # Source files.
    srcs = ["platform_dependent_library.cc"] + select({
        "@platforms//os:fuchsia": ["fuchsia_only_source.cc"],
        "//conditions:default": ["non_fuchsia_source.cc"],
    }),

    # Header files.
    hdrs = [
        "include/lib/test_lib/platform_dependent_header.h",
        "include/lib/test_lib/test_header.h",
    ] + select({
        "@platforms//os:fuchsia": ["include/lib/test_lib/fuchsia_only_header.h"],
        "//conditions:default": [],
    }),

    # Header files for internal use.
    hdrs_for_internal_use = ["include/lib/test_lib/internal/internal_header_appears_in_api_file.h"] + select({
        "@platforms//os:fuchsia": ["include/lib/test_lib/internal/fuchsia_only_internal_header_appears_in_api_file.h"],
        "//conditions:default": ["include/lib/test_lib/internal/non_fuchsia_internal_header_does_not_appear_in_api_file.h"],
    }),

    # IDK-related attributes.
    api_area = "Developer",
    category = "partner",
    idk_name = "platform_dependent_source_library",
    stable = True,
)

create_test_atom_info(
