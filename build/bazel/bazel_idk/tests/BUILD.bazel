# These executables test that all dependencies are linked in.
# They also test that the `include_base` is exported correctly.
# Note that these are in-tree tests and do not guarantee that the IDK contents
# are correct.

cc_binary(
    name = "test_executable_using_cc_shared_library",
    testonly = True,
    srcs = ["test_executable.cc"],
    deps = [":test-shared-library"],
)

cc_binary(
    name = "test_executable_using_cc_source_library",
    testonly = True,
    srcs = ["test_executable.cc"],
    deps = [":test-source-set"],
)

cc_binary(
    name = "test_executable_using_cc_static_library",
    testonly = True,
    srcs = ["test_executable.cc"],
    deps = [":test-static-library"],
)

cc_binary(
    name = "test_executable_using_platform_dependent_source_library",
    testonly = True,
    srcs = ["test_executable.cc"],
    deps = [":platform_dependent_source_library"],
)

cc_binary(
    name = "test_executable_using_cc_shared_library_zx",
    testonly = True,
    srcs = ["test_executable.cc"],
    deps = [":test_shared_library_zx"],
)

cc_binary(
    name = "test_executable_using_cc_source_library_zx",
    testonly = True,
    srcs = ["test_executable.cc"],
    deps = [":test_source_set_zx"],
)

cc_binary(
    name = "test_executable_using_cc_static_library_zx",
    testonly = True,
    srcs = ["test_executable.cc"],
    deps = [":test_static_library_zx"],
)

cc_import(
    name = "imported-test-static-library",
    testonly = True,
    hdrs = ["include/lib/test_lib/test_header.h"],
    # Bazel 8 does not automatically make the include path relative to the
    # source root - see https://fxbug.dev/478970857 so we must do so manually.
    # TODO(https://fxbug.dev/478896548): Make this `"include"` when updating to Bazel 9.
    includes = ["build/bazel/bazel_idk/tests/include"],
    static_library = ":test-static-library_export",
)

cc_binary(
    name = "test_executable_using_imported_cc_static_library",
    testonly = True,
    srcs = ["test_executable.cc"],
    deps = [":imported-test-static-library"],
)

filegroup(
    name = "build_only_tests",
    testonly = True,
    srcs = [
        ":test_molecule",
        ":test_executable_using_cc_shared_library",
        ":test_executable_using_cc_source_library",
        ":test_executable_using_cc_static_library",
        ":test_executable_using_platform_dependent_source_library",
        ":test_executable_using_cc_shared_library_zx",
        ":test_executable_using_cc_source_library_zx",
        ":test_executable_using_cc_static_library_zx",
        ":test_executable_using_imported_cc_static_library",

        # Build all the migrated atoms for the main platform build.
        "//sdk:fuchsia_idk_atoms_produced_by_main_platform_build",

        # Depend directly on the underlying source libraries since they are not
        # dependencies of the atoms.
        ":platform_dependent_source_library",
        ":test-source-set",
        ":test_source_set_dependency",
        ":test_source_set_zx",
        ":tests",
        "//sdk/lib/async:async-cpp",
        "//sdk/lib/fidl",
        "//sdk/lib/magma_common",
        "//sdk/lib/media/cpp:no_converters",
        "//sdk/lib/memory_barriers",
        "//sdk/lib/stdcompat",
        "//sdk/lib/utf-utils",
        "//src/zircon/lib/zircon",
        "//zircon/system/ulib/sync:sync-cpp",
        "//zircon/system/ulib/zx",

        # Build some of the underlying libraries on the host toolchain.
        ":build_only_tests_on_host_toolchain",

        # Exercise FIDL.
        # TODO(https://fxbug.dev/428285014): Remove once we are building elsewhere.
        "//examples/fidl/fuchsia.examples.docs",
        "//examples/fidl/fuchsia.examples.docs:versioning",
        # This tests indirect FIDL library dependencies.
        "//sdk/fidl/fuchsia.hardware.display.engine",

        # Non-IDK targets.
        # TODO(https://fxbug.dev/428229472): Remove once there are other dependencies on them.
        "//zircon/system/ulib/zircon-internal",
    ],
)

# Builds the targets listed in `tools` on the host toolchain.
genrule(
    name = "build_only_tests_on_host_toolchain",
    testonly = True,
    outs = ["build_only_tests_on_host_toolchain.stamp"],
    cmd = "touch $@",
    tools = [
        # Test linking on the host toolchain where possible.
        ":test_executable_using_cc_source_library_zx",

        # These libraries have Fuchsia-only dependencies and thus cannot be
        # linked into the executable on the host toolchain.
        ":test-shared-library",
        ":test-source-set",
        ":test-static-library",
        ":test_shared_library_zx",
        ":test_static_library_zx",

        # Verify that a target using `[non_]fuchsia_{hdrs|hdrs_for_internal_use|srcs}`
        # can be built on the host toolchain.
        ":test_executable_using_platform_dependent_source_library",

        # Other libraries.
        "//sdk/lib/stdcompat",
        "//sdk/lib/utf-utils",
        "//src/zircon/lib/zircon",
        # TODO(https://fxbug.dev/417305295): Uncomment when Fuchsia-only headers
        # are supported and this library can be built for host.
        # "//zircon/system/ulib/zx",
    ],
)

