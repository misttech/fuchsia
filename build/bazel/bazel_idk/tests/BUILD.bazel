# The following are example uses of the IDK atom rules that can be built and
# analyzed with cquery.
load("//build/bazel/bazel_idk:defs.bzl", "idk_atom", "idk_cc_source_library", "idk_molecule")

idk_atom(
    name = "test_atom",
    testonly = True,
    api_area = "Developer",
    category = "partner",
    id = "sdk://pkg/test",
    idk_name = "test_atom",
    meta_dest = "/pkg/test",
    stable = True,
    type = "data",
)

# The headers used by some_library.cc are made available as follows:
# * dependency.h: via `hdrs` in the deps ":test_source_set_dependency"
#   * another_header.h: via `hdrs_for_internal_use` in the deps ":test_source_set_dependency"
# * test_header.h: via `hdrs`
idk_cc_source_library(
    name = "test-source-set",
    testonly = True,
    srcs = ["some_library.cc"],
    hdrs = ["test_header.h"],
    api_area = "Developer",
    api_file_path = "different_file_name.api",
    category = "partner",
    fuchsia_deps = [
        # This target defines `RequiredFunction()`. ":test_executable" would
        # fail to link if this dependency is not included in the `cc_library()`.
        ":test_source_set_dependency",
    ],
    idk_name = "test_source_set",
    include_base = ".",
    stable = True,
    deps = [
        # Cover deps strings that omit the package path, omit the target name,
        # and provide the full label. The first case is covered in `fuchsia_deps`.
        "//build/bazel/bazel_idk/tests",
        "//build/bazel/bazel_idk/tests:test_source_set_dependency2",
    ],
)

idk_cc_source_library(
    name = "test_source_set_dependency",
    testonly = True,
    srcs = ["dependency.cc"],
    hdrs = ["dependency.h"],
    api_area = "Developer",

    # Test overriding the path to the API file.
    api_file_path = "dependency_1.api",
    category = "partner",
    hdrs_for_internal_use = ["another_header.h"],
    idk_name = "source_dependency_1",
    include_base = ".",
    stable = True,
    deps = [
        # Used to ensure transitive dependencies are included.
        ":test_source_set_subdependency",
    ],
)

idk_cc_source_library(
    name = "test_source_set_dependency2",
    testonly = True,
    hdrs = ["dependency.h"],
    api_area = "Developer",

    # Test specifying an absolute path to the API file.
    # The value is the same as the default path, but we are unable to detect
    # this for reasons explained in the implementation. Do not do this in real
    # instances.
    api_file_path = "//build/bazel/bazel_idk/tests:source_dependency_2.api",
    category = "partner",
    hdrs_for_internal_use = ["another_header.h"],
    idk_name = "source_dependency_2",
    include_base = ".",
    stable = True,
)

idk_cc_source_library(
    name = "test_source_set_subdependency",
    testonly = True,
    hdrs = ["dependency.h"],
    api_area = "Developer",
    category = "partner",
    hdrs_for_internal_use = ["another_header.h"],
    idk_name = "source_subdependency",
    include_base = ".",
    stable = True,
)

# A target whose name matches the last component of the package path. It is used
# to test deps on labels that omit the target name. Not to be confused with a
# collection of tests. For that, see ":build_only_tests".
idk_cc_source_library(
    name = "tests",
    testonly = True,
    hdrs = ["dependency.h"],
    api_area = "Developer",
    category = "partner",
    hdrs_for_internal_use = ["another_header.h"],
    idk_name = "tests_dependency",
    include_base = ".",
    stable = True,

    # Prevent mistaken use of this target as a group of tests.
    visibility = ["//visibility:private"],
)

idk_molecule(
    name = "test_submolecule",
    testonly = True,
    deps = [
        ":test-source-set_idk",
        ":test_atom_idk",
    ],
)

idk_molecule(
    name = "test_molecule",
    testonly = True,
    deps = [
        ":test_submolecule",
        "//sdk:fuchsia_idk_atoms_produced_by_main_platform_build",
        "//sdk/lib/magma_common:magma_common_idk",
        "//sdk/lib/media/cpp:no_converters_idk",
        "//sdk/lib/memory_barriers:memory_barriers_idk",
        "//sdk/lib/stdcompat:stdcompat_idk",

        # "//sdk/lib/utf-utils:utf-utils_idk" cannot be analyzed on the Fuchsia
        # toolchain because //zircon/system/ulib/zx does not yet exist.
    ],
)

# Tests that all dependencies are linked in.
cc_binary(
    name = "test_executable",
    testonly = True,
    srcs = ["test_executable.cc"],
    deps = [":test-source-set"],
)

filegroup(
    name = "build_only_tests",
    testonly = True,
    srcs = [
        ":test_molecule",
        ":test_executable",

        # Depend directly on the underlying source libraries since they are not
        # dependencies of the atoms.
        ":test-source-set",
        ":test_source_set_dependency",
        "//sdk/lib/magma_common",
        "//sdk/lib/media/cpp:no_converters",
        "//sdk/lib/memory_barriers",
        "//sdk/lib/stdcompat",

        # "//sdk/lib/utf-utils" cannot be analyzed on the Fuchsia
        # toolchain because //zircon/system/ulib/zx does not yet exist.

        # Build some of the underlying libraries on the host toolchain.
        ":build_only_tests_on_host_toolchain",
    ],
)

# Builds the targets listed in `tools` on the host toolchain.
genrule(
    name = "build_only_tests_on_host_toolchain",
    outs = ["build_only_tests_on_host_toolchain.stamp"],
    cmd = "touch $@",
    tools = [
        "//sdk/lib/stdcompat",
        "//sdk/lib/utf-utils",
    ],
)
