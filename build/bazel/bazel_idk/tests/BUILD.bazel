# The headers used by some_library.cc are made available as follows for Fuchsia builds:
# * dependency.h: via `hdrs` in the `fuchsia_deps` ":test_source_set_dependency"
#   * This file includes another_header.h, which is available via
#     `hdrs_for_internal_use` in the deps ":test_source_set_dependency".
# * test_header.h: via `hdrs`
# dependency.h is also available via `hdrs` in the `deps`
# ":test_source_set_dependency2".
# Non-Fuchsia builds also have a `non_fuchsia_deps` on ":test_source_set_dependency".
idk_cc_source_library(
    name = "test-source-library",
    testonly = True,
    srcs = [
        "internal/helper.cc",
        "some_library.cc",
    ],
    hdrs = ["include/lib/test_lib/test_header.h"],
    api_area = "Developer",
    api_file_path = "different_file_name.api",
    category = "partner",
    fuchsia_deps = [
        # This target defines `RequiredFunction()`. The test executable would
        # fail to link if this dependency is not included in the `cc_library()`.
        ":test_source_set_dependency",
    ],
    idk_name = "test_source_set",
    non_fuchsia_deps = [":test_source_set_dependency"],
    stable = True,
    deps = [
        ":test_noop_atom",

        # Cover deps strings that omit the package path, omit the target name,
        # and provide the full label. The first case is covered in `fuchsia_deps`.
        "//build/bazel/bazel_idk/tests",
        "//build/bazel/bazel_idk/tests:test_source_set_dependency2",
    ],
)

create_test_atom_info(
    name = "test_source_library_golden_info",
    testonly = True,
    additional_prebuild_info = {
        "include_dir": '"pkg/test_source_set/include"',
        "sources": '["pkg/test_source_set/internal/helper.cc","pkg/test_source_set/some_library.cc"]',
        "headers": '["pkg/test_source_set/include/lib/test_lib/test_header.h"]',
        "file_base": '"pkg/test_source_set"',
    },
    api_area = "Developer",
    api_contents_map = {
        "pkg/test_source_set/include/lib/test_lib/test_header.h": "//build/bazel/bazel_idk/tests:include/lib/test_lib/test_header.h",
    },
    api_file_path = "//build/bazel/bazel_idk/tests:different_file_name.api",
    atom_build_deps = [
        "//build/bazel/bazel_idk/tests:test-source-library_verify_no_duplicate_files",
        "//build/bazel/bazel_idk/tests:test-source-library_verify_pragma_once",
        "//build/bazel/bazel_idk:partner_idk_cc_source_library_allowlist",
        "//build/bazel/bazel_idk/tests:test-source-library_idk_verify_api",
    ],
    atom_files_map_generated_files = {},
    atom_files_map_source_files = {
        "pkg/test_source_set/include/lib/test_lib/test_header.h": "//build/bazel/bazel_idk/tests:include/lib/test_lib/test_header.h",
        "pkg/test_source_set/internal/helper.cc": "//build/bazel/bazel_idk/tests:internal/helper.cc",
        "pkg/test_source_set/some_library.cc": "//build/bazel/bazel_idk/tests:some_library.cc",
    },
    atoms_depset = depset([
        "//build/bazel/bazel_idk/tests:test_source_set_subdependency_idk",
        "//build/bazel/bazel_idk/tests:test_noop_atom_idk",
        "//build/bazel/bazel_idk/tests:tests_idk",
        "//build/bazel/bazel_idk/tests:test_source_set_dependency2_idk",
        "//build/bazel/bazel_idk/tests:test_source_set_dependency_idk",
    ]),
    category = "partner",
    id = "sdk://pkg/test_source_set",
    idk_deps = [
        "//build/bazel/bazel_idk/tests:test_noop_atom_idk",
        "//build/bazel/bazel_idk/tests:tests_idk",
        "//build/bazel/bazel_idk/tests:test_source_set_dependency2_idk",
        "//build/bazel/bazel_idk/tests:test_source_set_dependency_idk",
    ],
    idk_name = "test_source_set",
    is_stable = True,
    label = "//build/bazel/bazel_idk/tests:test-source-library_idk",
    meta_dest = "pkg/test_source_set/meta.json",
    type = "cc_source_library",
)

