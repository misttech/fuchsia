import("//build/bazel/assembly/bazel_product_bundle.gni")

# A GN wrapper for a Bazel `fuchsia_test_product_bundle` target.
#
# This template simplifies the arguments to `bazel_product_bundle` by deriving
# the `bazel_product_bundle_target` and `bazel_product_image_target` from the
# `bazel_target` parameter. It also sets some common defaults for test-only
# product bundles.
#
# Parameters
#
#  bazel_target (required)
#    The Bazel `fuchsia_test_product_bundle` target to build.
#    Type: label (from BUILD.bazel)
#
#  bazel_inputs_from_gn (optional)
#    See `bazel_product_bundle`.
#
template("bazel_test_product_bundle") {
  assert(defined(invoker.bazel_target), "bazel_target is required")

  bazel_product_bundle(target_name) {
    testonly = true

    forward_variables_from(invoker,
                           [
                             "bazel_inputs_from_gn",
                             "deps",
                           ])

    # Test bundles should be in product_bundles.json for infra.
    generate_product_bundle_metadata = true

    allow_eng_platform_bundle_use = true
    bazel_product_bundle_target = invoker.bazel_target

    # The fuchsia_test_product_bundle Bazel macro creates a fuchsia_product
    # target with a `_product` suffix.
    bazel_product_image_target = "${invoker.bazel_target}.product"
    product_bundle_name = get_label_info(invoker.bazel_target, "name")
  }
}
