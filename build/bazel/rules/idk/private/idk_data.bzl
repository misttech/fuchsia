"""Defines an IDK data atom."""

load(":idk_atom.bzl", "idk_atom")
load(":idk_common.bzl", "get_atom_visibility", "json_encode_dict_values")

visibility([
    "//build/bazel/rules/idk/...",
])

# LINT.IfChange(idk_data)

def _idk_data_impl(
        name,
        idk_name,
        category,
        api_area,
        type,
        file,
        testonly,
        visibility):
    """Implementation for the `idk_data()` macro."""

    # The directory structure will look as follows:
    # > data/
    #   > config/
    #     > `idk_name`/
    #       > config.json
    #       > meta.json
    # Note that unlike other atoms, the `idk_name` is not the second-level
    # directory and the `id` path (below) does not match the the file path.
    file_base = "data/%s/%s/" % (type, idk_name)
    if type == "config":
        file_dest = file_base + "config.json"
    else:
        fail("Unsupported data type: '%s'" % type)

    # Construct the files_map.
    files_map = {
        file_dest: file,
    }

    meta_dest = file_base + "meta.json"

    # This matches the `value` meta field in the GN `sdk_data()` template.
    # TODO(https://fxbug.dev/442641255): We may need to update
    # //build/sdk/generate_prebuild_idk/idk_generator.py to support the metadata
    # generated by `idk_atom()` and update the GN template to match that.
    additional_prebuild_info_values = {
        "data": [file_dest],
        "name": idk_name,
        "type": type,
    }

    idk_atom(
        name = name + "_idk",
        idk_name = idk_name,
        id = "sdk://data/" + idk_name,
        meta_dest = meta_dest,
        type = "data",
        category = category,
        stable = True,
        api_area = api_area,
        files_map = files_map,
        additional_prebuild_info = json_encode_dict_values(additional_prebuild_info_values),
        target_compatible_with = ["@platforms//os:fuchsia"],
        testonly = testonly,
        visibility = get_atom_visibility(visibility),
    )

idk_data = macro(
    doc = "Defines a data file to be included in an IDK.",
    implementation = _idk_data_impl,
    attrs = {
        "idk_name": attr.string(
            doc = """Name of the library in the IDK. Usually matches `name`.
GN equivalent: `name`""",
            mandatory = True,
            configurable = False,
        ),
        "category": attr.string(
            doc = "Publication level of the atom in the IDK. See _create_idk_atom().",
            values = ["partner"],
            mandatory = True,
            configurable = False,
        ),
        "api_area": attr.string(
            doc = """The API area responsible for maintaining this atom.
GN equivalent: `sdk_area`""",
            mandatory = True,
        ),
        "type": attr.string(
            doc = """Type of the data set in the SDK.
Currently only 'config' data types are supported.""",
            mandatory = True,
            values = ["config"],
            configurable = False,
        ),
        "file": attr.label(
            doc = "The data file to add to the IDK.",
            mandatory = True,
            allow_single_file = True,
            configurable = False,
        ),
        "testonly": attr.bool(
            doc = "Standard meaning.",
            default = False,
            configurable = False,
        ),
    },
)
# LINT.ThenChange(//build/sdk/sdk_atom.gni:sdk_data)
