"""Tests of platform Bazel rules, macros, and migrated targets.

This file will always contain tests for rules and macros.

During the migration, it also contains migrated targets that are not yet
otherwise part of the build.
"""

load("//build/bazel/platforms:constraints.bzl", "HOST_OS_CONSTRAINTS")
load("//build/bazel/rules:stamp_group.bzl", "stamp_group")
load(":rules.bzl", "build_for_host", "build_with_platform_api_level")

# Runs all tests and writes a stamp file.
stamp_group(
    name = "tests",
    testonly = True,
    stamp = "tests.bazel_stamp",
    # This target is only intended to be built in Fuchsia configurations.
    # Individual test groups can use a transition to build targets in host
    # configurations if needed.
    target_compatible_with = ["@platforms//os:fuchsia"],
    deps = [
        # Include all the quick tests.
        ":quick_tests",

        # Additional long tests.
        ":long_build_only_tests",
    ],
)

# Runs all tests that can be run fairly quickly and writes a stamp file.
# It covers the rules and macros but not most of the targets that use them.
# Specifically, it does not build all FIDL atoms or the full IDKs.
stamp_group(
    name = "quick_tests",
    testonly = True,
    stamp = "quick_tests.bazel_stamp",
    # This target is only intended to be built in Fuchsia configurations.
    # Individual test groups can use a transition to build targets in host
    # configurations if needed.
    target_compatible_with = ["@platforms//os:fuchsia"],
    deps = [
        ":quick_build_only_tests",
    ],
)

# Builds targets for which building successfully is the test.
filegroup(
    name = "quick_build_only_tests",
    testonly = True,
    srcs = [
        ":quick_build_only_tests_requiring_api_level",
        ":build_only_tests_in_host_configuration",

        # Fuchsia tests that do not require defining the Clang API level as "PLATFORM".
        "//build/bazel/bazel_idk/tests:api_level_and_cpu_combinations_build_only_tests",
    ],
    # This target is only intended to be built in Fuchsia configurations.
    # Individual test groups can use a transition to build targets in host
    # configurations if needed.
    target_compatible_with = ["@platforms//os:fuchsia"],
)

# A subset of ":quick_build_only_tests" that requires the API level to be defined.
build_with_platform_api_level(
    name = "quick_build_only_tests_requiring_api_level",
    testonly = True,
    stamp = "quick_build_only_tests_requiring_api_level.stamp",
    # This target is only intended to be built in Fuchsia configurations.
    target_compatible_with = ["@platforms//os:fuchsia"],
    deps = [
        "//build/bazel/bazel_idk/tests:build_only_tests",
    ],
)

filegroup(
    name = "targets_to_build_in_host_configuration",
    testonly = True,
    srcs = [
        # Host tools not in the IDK
        "//tools/fidl/fidlgen_rust",

        # Miscellaneous libraries.
        "//sdk/lib/fidl",
        "//sdk/lib/fidl/cpp:cpp_base",
        "//sdk/lib/fidl/cpp/wire",
        "//sdk/lib/fidl_base",
        "//sdk/lib/stdcompat",
        "//sdk/lib/utf-utils",
        "//src/zircon/lib/zircon",
        "//zircon/system/ulib/zx",
    ],
    target_compatible_with = HOST_OS_CONSTRAINTS,
)

# Builds targets for which building successfully is the test using the host configuration.
build_for_host(
    name = "build_only_tests_in_host_configuration",
    testonly = True,
    stamp = "build_only_tests_in_host_configuration.stamp",
    # This target transitions to the host config ("exec") to build the test targets.
    # To build the targets directly for the host platform, build the dependency
    # directly.
    target_compatible_with = ["@platforms//os:fuchsia"],
    deps = [":targets_to_build_in_host_configuration"],
)

# Builds targets for which building successfully is the test.
filegroup(
    name = "long_build_only_tests",
    testonly = True,
    srcs = [
        ":long_build_only_tests_requiring_api_level",

        # The source libraries represented by the atoms in
        # "//sdk:cc_source_libraries_idk" are not built by the IDK targets, so
        # build them here for each combination of API level and CPU architecture.
        # Note: The GN build does not explicitly build these targets like this.
        # Note: Header-only libraries are not compiled.
        "//sdk:all_underlying_cc_source_libraries_in_all_api_level_and_cpu_combinations",

        # Compile, generate the atom, and run compatibility tests for all FIDL
        # libraries in all categories.
        "//sdk/fidl:compatibility_tests",
    ],
    # This target is only intended to be built in Fuchsia configurations.
    # Individual test groups can use a transition to build targets in host
    # configurations if needed.
    target_compatible_with = ["@platforms//os:fuchsia"],
)

# A subset of ":long_build_only_tests" that requires the API level to be defined.
build_with_platform_api_level(
    name = "long_build_only_tests_requiring_api_level",
    testonly = True,
    stamp = "long_build_only_tests_requiring_api_level.stamp",
    # This target is only intended to be built in Fuchsia configurations.
    target_compatible_with = ["@platforms//os:fuchsia"],
    deps = [
        # Build the IDKs to exercise all the atoms migrated so far.
        "//sdk:fuchsia_idk_molecule_idk",
        "//sdk:in_tree_idk_molecule_idk",
    ],
)
