import("//build/bazel/bazel_build_action.gni")

# Used in "//:root_targets" to ensure the test targets are always available.
group("all") {
  testonly = true
  deps = [
    ":quick_tests",
    ":tests",
  ]
  visibility = [ "//:root_targets" ]
}

bazel_build_action("tests") {
  # Should only be run manually as it is not part of a bazel_build_group()`.
  visibility = [ ":*" ]
  testonly = true
  bazel_target = ":tests"
  copy_outputs = [
    {
      bazel = "{{BAZEL_TARGET_OUT_DIR}}/tests.bazel_stamp"
      ninja = "tests.bazel_stamp"
    },
  ]

  # The tests rely on the "fuchsia_platform" sysroots.
  deps = [ "//zircon/public/sysroot_sdk:sysroot_for_fuchsia_platform" ]

  bazel_platform = "fuchsia_platform_${current_cpu}"
  no_sdk = true
}

bazel_build_action("quick_tests") {
  # Should only be run manually as it is not part of a bazel_build_group()`.
  visibility = [ ":*" ]
  testonly = true
  bazel_target = ":quick_tests"
  copy_outputs = [
    {
      bazel = "{{BAZEL_TARGET_OUT_DIR}}/quick_tests.bazel_stamp"
      ninja = "quick_tests.bazel_stamp"
    },
  ]

  # The tests rely on the "fuchsia_platform" sysroots.
  deps = [ "//zircon/public/sysroot_sdk:sysroot_for_fuchsia_platform" ]

  bazel_platform = "fuchsia_platform_${current_cpu}"
  no_sdk = true
}
