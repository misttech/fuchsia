import("//build/bazel/bazel_build_action.gni")

# The GN test targets are not part of a `bazel_build_group()`, so they should
# only be built manually.
visibility = [ ":*" ]

# All the test targets defined in this file.
group("all") {
  testonly = true
  deps = [
    ":quick_tests",
    ":tests",
  ]
  visibility += [
    # Ensures the test targets are always available.
    "//:root_targets",

    # A small number of build bots build all the tests, accepting the bazel
    # action overhead. These bots should run all the GN build test targets even
    # if some underlying Bazel targets are subsets of others. Building all the
    # GN Bazel action targets ensures, for example, that they are configured
    # with all the necessary Bazel inputs.
    "//bundles/buildbot/*",
  ]
}

bazel_build_action("tests") {
  testonly = true
  bazel_target = ":tests"
  copy_outputs = [
    {
      bazel = "{{BAZEL_TARGET_OUT_DIR}}/tests.bazel_stamp"
      ninja = "tests.bazel_stamp"
    },
  ]
  bazel_config = "fuchsia_platform"
  deps = [
    # The following are currently needed by `fx_package()`.
    # TODO(b/519244675): Remove once `package-tool` is migrated to Bazel.
    "//src/sys/pkg/bin/package-tool:bazel_input($host_toolchain)",

    # TODO(b/519243783): Remove once `cmc` is migrated to Bazel.
    "//tools/cmc:bazel_input($host_toolchain)",
  ]
}

bazel_build_action("quick_tests") {
  testonly = true
  bazel_target = ":quick_tests"
  copy_outputs = [
    {
      bazel = "{{BAZEL_TARGET_OUT_DIR}}/quick_tests.bazel_stamp"
      ninja = "quick_tests.bazel_stamp"
    },
  ]
  bazel_config = "fuchsia_platform"
  deps = [
    # The following are currently needed by `fx_package()`.
    # TODO(b/519244675): Remove once `package-tool` is migrated to Bazel.
    "//src/sys/pkg/bin/package-tool:bazel_input($host_toolchain)",

    # TODO(b/519243783): Remove once `cmc` is migrated to Bazel.
    "//tools/cmc:bazel_input($host_toolchain)",
  ]
}
