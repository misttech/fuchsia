From 2752fb8d1db838ef522d4101755d4d2f522c5982 Mon Sep 17 00:00:00 2001
From: hvd <hvd@google.com>
Date: Thu, 19 Feb 2026 13:24:57 +0100
Subject: [PATCH] Fix visibility for `//cc/common:cc_shared_library_info_bzl`

It is expected that users will need the provider.
---
 cc/common/BUILD | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/third_party/bazel_vendor/rules_cc+/cc/common/BUILD b/third_party/bazel_vendor/rules_cc+/cc/common/BUILD
index 052056bbb..65530a675 100644
--- a/third_party/bazel_vendor/rules_cc+/cc/common/BUILD
+++ b/third_party/bazel_vendor/rules_cc+/cc/common/BUILD
@@ -55,7 +55,7 @@ bzl_library(
 bzl_library(
     name = "cc_shared_library_info_bzl",
     srcs = ["cc_shared_library_info.bzl"],
-    visibility = ["//cc:__subpackages__"],
+    visibility = ["//visibility:public"],
     deps = [
         "@cc_compatibility_proxy//:symbols_bzl",
     ],
