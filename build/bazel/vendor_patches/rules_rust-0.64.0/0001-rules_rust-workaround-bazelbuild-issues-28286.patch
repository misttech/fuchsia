From 9b8f16a980ed28b789676b11e46c32bcddea44ab Mon Sep 17 00:00:00 2001
From: David Fang <fangism@google.com>
Date: Fri, 6 Feb 2026 01:04:36 +0000
Subject: [rules_rust] workaround bazelbuild/issues/28286

Ensure that the output directory is not empty by touching
an empty file inside it.
Update rules to always expect this file as an output.

DO NOT SUBMIT: testing in CQ

Bug: 478896119
Change-Id: I0e1bdefa98e8a2b4013b310e451b2e3481c2fb07
---
 .../cargo/cargo_build_script_runner/bin.rs            | 11 +++++++++++
 .../cargo_build_script_runner/cargo_manifest_dir.rs   | 10 ++++++++++
 2 files changed, 21 insertions(+)

diff --git a/third_party/bazel_vendor/rules_rust+/cargo/cargo_build_script_runner/bin.rs b/third_party/bazel_vendor/rules_rust+/cargo/cargo_build_script_runner/bin.rs
index 51a52fc26c8..435c3f7028d 100644
--- a/third_party/bazel_vendor/rules_rust+/cargo/cargo_build_script_runner/bin.rs
+++ b/third_party/bazel_vendor/rules_rust+/cargo/cargo_build_script_runner/bin.rs
@@ -232,6 +232,17 @@ fn run_buildrs() -> Result<(), String> {
             .drain_runfiles_dir(&out_dir_abs)
             .unwrap();
     }
+
+    // Ensure the output directory is not empty.
+    // Workaround for https://github.com/bazelbuild/bazel/issues/28286
+    write(out_dir_abs.join(".rules_rust_empty"), "")
+        .unwrap_or_else(|e| {
+            panic!(
+                "Unable to create .rules_rust_empty file in {:?}: {}",
+                out_dir_abs, e
+            )
+        });
+
     Ok(())
 }
 
diff --git a/third_party/bazel_vendor/rules_rust+/cargo/cargo_build_script_runner/cargo_manifest_dir.rs b/third_party/bazel_vendor/rules_rust+/cargo/cargo_build_script_runner/cargo_manifest_dir.rs
index def343a34ec..f2955c7377a 100644
--- a/third_party/bazel_vendor/rules_rust+/cargo/cargo_build_script_runner/cargo_manifest_dir.rs
+++ b/third_party/bazel_vendor/rules_rust+/cargo/cargo_build_script_runner/cargo_manifest_dir.rs
@@ -312,6 +312,16 @@ impl RunfilesMaker {
             self.drain_runfiles_dir_unix()?;
         }
 
+        // Ensure the output directory is not empty.
+        // Workaround for https://github.com/bazelbuild/bazel/issues/28286
+        std::fs::write(self.output_dir.join(".rules_rust_empty"), "").map_err(|e| {
+            format!(
+                "Failed to create .rules_rust_empty in {}: {:?}",
+                self.output_dir.display(),
+                e
+            )
+        })?;
+
         // Due to the symlinks in `CARGO_MANIFEST_DIR`, some build scripts
         // may have placed symlinks over real files in `OUT_DIR`. To counter
         // this, all non-relative symlinks are resolved.
-- 
