{
    // Dynamic capability routing information needed by Scrutiny to construct
    // a valid routing graph for verify_routes and structured_config.
    dynamic_components: {},
    dynamic_dictionaries: {
        // From src/bringup/bin/kernel-args-forwarder/src/main.rs.
        // This represents the set of boot args which are represented as config
        // capabilities. This is a list of possible items, some may or may not
        // be present depending upon the product. This file does not attempt to
        // enforce any secure values for the config capabilities.
        "/bootstrap/kernel-args-forwarder": {
            boot_args: {
                configs: [
                    "fuchsia.astro.sysconfig.abr-wear-leveling",
                    "fuchsia.console.shell",
                    "fuchsia.console.use_virtio_console",
                    "fuchsia.netsvc.advertise",
                    "fuchsia.netsvc.all-features",
                    "fuchsia.netsvc.disable",
                    "fuchsia.netsvc.netboot",
                    "fuchsia.androidboot.slot_suffix",
                    "fuchsia.omaha_app_id",
                    "fuchsia.omaha_url",
                    "fuchsia.ota_channel",
                    "fuchsia.ota_realm",
                    "fuchsia.product_id",
                    "fuchsia.TERM",
                    "fuchsia.zircon.autorun.boot",
                    "fuchsia.zircon.autorun.system",
                    "fuchsia.zircon.namegen",
                    "fuchsia.zircon.nodename",
                    "fuchsia.zircon.system.pkgfs.cmd",
                    "fuchsia.zvb.current_slot",
                    "fuchsia.zvb.boot-partition-uuid",
                ],
            },
        },
    },
}
