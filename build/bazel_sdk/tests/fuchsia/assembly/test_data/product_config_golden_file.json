{
    "platform": {
        "connectivity": {
            "wlan": {
                "legacy_privacy_support": true
            }
        },
        "development_support": {
            "enabled": true
        },
        "diagnostics": {
            "archivist": "default",
            "additional_serial_log_components": [
                "/core/session-manager",
                "/core/session-manager/session:session"
            ],
            "no_console": false
        },
        "ui": {
            "pointer_auto_focus": true,
            "supported_input_devices": [
                "button",
                "keyboard"
            ],
            "attach_a11y_view": true
        }
    },
    "product": {
        "packages": {
            "base": {
                "ams-light-test": {
                    "manifest": "packages/ams-light-test"
                },
                "starnix_container_for_test": {
                    "manifest": "packages/starnix_container_for_test"
                }
            }
        },
        "base_drivers": [
            {
                "package": "packages/backlight_driver",
                "components": [
                    "meta/backlight_driver.cm"
                ]
            }
        ],
        "session": {
            "url": "fuchsia-pkg://fuchsia.com/test_session#meta/test_session.cm"
        },
        "release_info": {
            "info": {
                "name": "unknown",
                "repository": "unknown",
                "version": "unversioned"
            },
            "pibs": [
                {
                    "name": "testing_pib",
                    "repository": "unknown",
                    "version": "fake_version_123"
                }
            ]
        },
        "starnix_containers": [
            {
                "name": "starnix_container_for_test",
                "base": "pkg_for_test",
                "hals": [
                    "ams-light-test"
                ],
                "skip_subpackages": true,
                "images_or_package": {
                    "package": "packages/starnix_container_for_test"
                }
            }
        ]
    },
    "product_input_bundles": {
        "testing_pib": {
            "packages": {
                "for_product_config": {
                    "ams-light-test": {
                        "manifest": "packages/ams-light-test"
                    },
                    "pkg_for_test": {
                        "manifest": "packages/pkg_for_test"
                    }
                }
            },
            "release_info": {
                "name": "testing_pib",
                "repository": "unknown",
                "version": "fake_version_123"
            }
        }
    }
}
