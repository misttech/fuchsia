import("//build/rust/rustc_library.gni")

_source_root = "//third_party/alacritty-migrating/src/vte"

rustc_library("vte") {
  name = "vte"
  version = "0.1.0"
  edition = "2015"

  source_root = "$_source_root/src/lib.rs"
  configs -= [
    "//build/config/rust:2018_idioms",
    "//build/config/rust:cap_lints",
  ]
  configs += [ "//build/config/rust:cap_lints_allow" ]

  deps = [ "//third_party/rust_crates:utf8parse" ]
  sources = [
    "$_source_root/src/definitions.rs",
    "$_source_root/src/lib.rs",
    "$_source_root/src/table.rs",
  ]
}
