import("//build/rust/config.gni")
import("//build/rust/rustc_library.gni")
import("//build/rust/rustc_test.gni")

_source_root = "//third_party/alacritty-migrating/src/alacritty_terminal"

term_sources = [
  "$_source_root/src/ansi.rs",
  "$_source_root/src/clipboard.rs",
  "$_source_root/src/config/colors.rs",
  "$_source_root/src/config/debug.rs",
  "$_source_root/src/config/font.rs",
  "$_source_root/src/config/mod.rs",
  "$_source_root/src/config/scrolling.rs",
  "$_source_root/src/config/visual_bell.rs",
  "$_source_root/src/config/window.rs",
  "$_source_root/src/event.rs",
  "$_source_root/src/grid/mod.rs",
  "$_source_root/src/grid/row.rs",
  "$_source_root/src/grid/storage.rs",
  "$_source_root/src/grid/tests.rs",
  "$_source_root/src/index.rs",
  "$_source_root/src/lib.rs",
  "$_source_root/src/message_bar.rs",
  "$_source_root/src/selection.rs",
  "$_source_root/src/term/cell.rs",
  "$_source_root/src/term/color.rs",
  "$_source_root/src/term/mod.rs",
]

term_deps = [
  "//third_party/alacritty/vte",
  "//third_party/rust_crates:base64-v0_13_0",
  "//third_party/rust_crates:bitflags-v1_3_2",
  "//third_party/rust_crates:log",
  "//third_party/rust_crates:serde",
  "//third_party/rust_crates:serde_json",
  "//third_party/rust_crates:unicode-width",
]

config("allow_elided_named_lifetimes") {
  rustflags = [ "-Aelided_named_lifetimes" ]
}

rustc_library("term_model") {
  name = "term_model"
  version = "0.1.0"
  edition = "2018"

  source_root = "$_source_root/src/lib.rs"

  # TODO(https://fxbug.dev/69442) remove this allowance
  configs += [
    ":allow_elided_named_lifetimes",
    "//build/config/rust:allow_legacy_derive_helpers",
  ]

  deps = term_deps
  sources = term_sources
}

rustc_test("term-model_test") {
  name = "term_model_lib_test"
  version = "0.1.0"
  edition = "2018"

  source_root = "$_source_root/src/lib.rs"

  # TODO(fxbug.dev/69442) remove this allowance
  configs += [
    ":allow_elided_named_lifetimes",
    "//build/config/rust:allow_legacy_derive_helpers",
  ]

  # TODO(fxbug.dev/42173372): Fix the leaks and remove this.
  deps =
      term_deps + [ "//build/config/sanitizers:suppress-lsan.DO-NOT-USE-THIS" ]
  sources = term_sources
}
