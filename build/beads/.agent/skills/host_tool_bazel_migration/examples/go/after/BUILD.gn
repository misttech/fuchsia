import("//build/go/go_library.gni")
import("//build/go/go_test.gni")
import("//build/host.gni")

if (is_host) {
  # The migrated go_library and go_binary targets are removed.

  # You don't need to migrate go_test rules for now.
  go_test("go_test") {
    embed = [ ":example_lib" ]
    deps = [ "//third_party/golibs:github.com/google/go-cmp" ]

    # Step 1: Go test source file belongs to `go_test` target, which is moved
    # from `go_library` target here.
    sources = [ "main_test.go" ]
  }

  # The `install_host_tools` target is removed, and the dep is replaced with the added entry in
  # the `default_bazel_root_host_targets` list in `//build/bazel/bazel_root_targets_list.gni`
}

# These are convenience groups in GN.
#
# You don't need to migrate these groups, leave them as-is.
# You do need to update dep paths after you migrate go_binary above.
group("tests") {
  testonly = true
  deps = [ ":go_test($host_toolchain)" ]
}

group("examples") {
  testonly = true
  deps = [
    ":go_test($host_toolchain)",

    # The GN `install_host_tools` target is removed, and the dep is replaced with the added entry in
    # the `default_bazel_root_host_targets` list in `//build/bazel/bazel_root_targets_list.gni`
    "//build/bazel/host:bazel_root_host_tools.example_bin_migrated.host_tool($host_toolchain)",
  ]
}

