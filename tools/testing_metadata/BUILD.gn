import("//build/compiled_action.gni")
import("//build/rust/rustc_binary.gni")
import("//build/testing/host_test.gni")

if (is_host) {
  rustc_binary("testing_metadata_bin") {
    name = "testing_metadata"
    edition = "2024"
    with_unit_tests = true

    deps = [
      "//third_party/rust_crates:anyhow",
      "//third_party/rust_crates:argh",
      "//third_party/rust_crates:serde",
      "//third_party/rust_crates:serde_json",
      "//third_party/rust_crates:serde_json5",
      "//third_party/rust_crates:valico",
      "//third_party/rust_crates:walkdir",
    ]

    test_deps = [
      "//third_party/rust_crates:pretty_assertions",
      "//third_party/rust_crates:tempfile",
    ]

    sources = [ "src/main.rs" ]
    inputs = [
      "testing_input.schema.json",
      "testing_metadata.schema.json",
    ]

    configs += [ "//build/config:optimize_speed" ]
  }

  host_test("testing_metadata_host_test") {
    binary_path = "${root_out_dir}/testing_metadata_bin_test"
    deps = [ ":testing_metadata_bin_test" ]
  }
}

# The actual metadata file generation
if (current_toolchain == default_toolchain) {
  compiled_action("testing_metadata_json_action") {
    tool = "//tools/testing_metadata:testing_metadata_bin"
    tool_output_name = "testing_metadata"

    output_file = "${root_build_dir}/testing_metadata.json"
    depfile = "${output_file}.d"

    outputs = [ output_file ]
    check_for_output_dir_leaks = false

    args = [
      "--fuchsia-dir",
      rebase_path("//", root_build_dir),
      "--output",
      rebase_path(output_file, root_build_dir),
      "--depfile",
      rebase_path(depfile, root_build_dir),
    ]
  }
}

group("tests") {
  testonly = true
  deps = [ ":testing_metadata_host_test($host_toolchain)" ]
}

group("testing_metadata") {
  testonly = true
  deps = [
    ":testing_metadata_json_action($default_toolchain)",
    ":tests",
  ]
}
