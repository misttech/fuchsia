load("@io_bazel_rules_go//go:def.bzl", "go_library")
load("@platforms//host:constraints.bzl", "HOST_CONSTRAINTS")

package(default_applicable_licenses = ["//:license"])

go_library(
    name = "tap",
    srcs = [
        "doc.go",
        "parser.go",
        "producer.go",
        "tap.go",
    ],
    importpath = "go.fuchsia.dev/fuchsia/tools/testing/tap",
    target_compatible_with = HOST_CONSTRAINTS,
    visibility = ["//visibility:public"],
    deps = [
        ":tokenizer",
    ],
)

go_library(
    name = "tokenizer",
    srcs = [
        "tokenizer/iterator.go",
        "tokenizer/lexer.go",
        "tokenizer/stream.go",
    ],
    importpath = "go.fuchsia.dev/fuchsia/tools/testing/tap/tokenizer",
    target_compatible_with = HOST_CONSTRAINTS,
    visibility = ["//visibility:public"],
)
