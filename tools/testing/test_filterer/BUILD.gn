import("//build/go/go_binary.gni")
import("//build/go/go_library.gni")
import("//build/go/go_test.gni")

go_library("main") {
  sources = [ "main.go" ]
  deps = [
    "//third_party/golibs:github.com/google/go-cmp",
    "//third_party/luci-go/swarming/proto/api_v2:swarming_proto_go",
    "//tools/integration/testsharder:testsharder_lib",
    "//tools/testing/runtests",
  ]
}

go_binary("test_filterer") {
  embed = [ ":main" ]

  # Needed to support cross-compilation. The infra recipes always needs this
  # built for Linux, even if build happens on Mac.
  cgo = false
}

go_test("main_tests") {
  embed = [ ":main" ]
  sources = [ "main_test.go" ]
  output_name = "test_filterer_main_tests"
  deps = [
    "//third_party/golibs:github.com/google/go-cmp",
    "//third_party/luci-go/swarming/proto/api_v2:swarming_proto_go",
    "//tools/integration/testsharder:testsharder_lib",
    "//tools/testing/runtests",
  ]
}

group("tests") {
  testonly = true
  deps = [ ":main_tests" ]
}
