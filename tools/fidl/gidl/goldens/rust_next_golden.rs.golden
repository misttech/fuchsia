    #[test]
    fn encode_golden_nullable_handle_struct_non_null() {
            let handle_defs = create_handles(&[
// #0
HandleDef{
	subtype: HandleSubtype::Event,
	rights: fidl_next::fuchsia::zx::Rights::from_bits(2147483648).unwrap(),
},
]);
        let value = test_conformance::GoldenNullableHandleStruct { v: Some(copy_handle(&handle_defs[0])) };
        let mut buffer = Buffer::new();
        buffer.encode_next(value).unwrap();
        assert_eq!(&[
0xff,0xff,0xff,0xff,0x00,0x00,0x00,0x00,
], buffer.bytes().as_slice());
        // TODO: support handle dispositions
        assert_eq!(
            buffer.handles().iter().map(|h| h.raw_handle()).collect::<Vec<_>>(),
            &[handle_defs[0].handle,
]
        );
    }

