    }



    #[test]
    fn decode_golden_bool_struct() {

        let buffer = Buffer::from_raw_bytes(vec![
], &[
0x01,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
]);
        let recv_buffer = RecvBuffer::new(buffer);
        let _value: test_conformance::GoldenBoolStruct = recv_buffer.decode::< <test_conformance::GoldenBoolStruct as fidl_next::Encodable>::Encoded>().unwrap().take();
        assert_eq!(_value, test_conformance::GoldenBoolStruct { v: true });

    }

