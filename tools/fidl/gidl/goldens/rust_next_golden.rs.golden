    #[test]
    fn encode_golden_byte_vector_struct() {
        let value = test_conformance::GoldenByteVectorStruct { v: vec![1u8, 2u8, 3u8, 4u8, 1u8, 2u8, 3u8, 4u8, 1u8, 2u8, 3u8, 4u8] };
        let mut buffer = Buffer::new();
        buffer.encode_next(value).unwrap();
        assert_eq!(&[
0x0c,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
0xff,0xff,0xff,0xff,0xff,0xff,0xff,0xff,
0x01,0x02,0x03,0x04,0x01,0x02,0x03,0x04,
0x01,0x02,0x03,0x04,0x00,0x00,0x00,0x00,
], buffer.bytes().as_slice());
        // TODO: support handle dispositions
        assert_eq!(buffer.handles(), &[]);
    }

