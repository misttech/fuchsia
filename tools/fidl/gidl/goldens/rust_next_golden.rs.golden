        let buffer = Buffer::from_raw_bytes(vec![
], &[
0x01,0x00,0x02,0x00,0x00,0x00,0x00,0x00,
]);
        let recv_buffer = RecvBuffer::new(buffer);
        let _value: test_conformance::GoldenStructArrayStruct = recv_buffer.decode::< <test_conformance::GoldenStructArrayStruct as fidl_next::Encodable>::Encoded>().unwrap().take();
        assert_eq!(_value, test_conformance::GoldenStructArrayStruct { v: [test_conformance::GoldenIntStruct { v: 1i16 }, test_conformance::GoldenIntStruct { v: 2i16 }] });

    }

    #[test]
