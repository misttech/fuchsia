    #[test]
    fn encode_golden_string_struct() {
        let value = test_conformance::GoldenStringStruct { v: String::from("abcd") };
        let mut buffer = Buffer::new();
        buffer.encode_next(value).unwrap();
        assert_eq!(&[
0x04,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
0xff,0xff,0xff,0xff,0xff,0xff,0xff,0xff,
0x61,0x62,0x63,0x64,0x00,0x00,0x00,0x00,
], buffer.bytes().as_slice());
        // TODO: support handle dispositions
        assert_eq!(buffer.handles(), &[]);
    }

