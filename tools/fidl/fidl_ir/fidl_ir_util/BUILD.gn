import("//build/rust/rustc_library.gni")

rustc_library("fidl_ir_util") {
  edition = "2021"
  sources = [
    "src/decl.rs",
    "src/lib.rs",
  ]
  deps = [ "//tools/fidl/fidl_ir" ]
  with_unit_tests = true
}

group("tests") {
  testonly = true
  deps = [ ":fidl_ir_util_test($host_toolchain)" ]
}
