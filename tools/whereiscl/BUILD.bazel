load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")
load("@platforms//host:constraints.bzl", "HOST_CONSTRAINTS")
load("//build/bazel/rules:stamp_group.bzl", "stamp_group")
load("//build/bazel/rules/host:defs.bzl", "go_binary_host_tool")

package(default_applicable_licenses = ["//:license"])

go_library(
    name = "netutil",
    srcs = ["netutil/netutil.go"],
    importpath = "go.fuchsia.dev/fuchsia/tools/whereiscl/netutil",
    target_compatible_with = HOST_CONSTRAINTS,
)

go_library(
    name = "lib",
    srcs = [
        "changeinfo.go",
        "gistatus.go",
    ],
    importpath = "go.fuchsia.dev/fuchsia/tools/whereiscl",
    target_compatible_with = HOST_CONSTRAINTS,
    deps = [":netutil"],
)

go_library(
    name = "main",
    srcs = ["cmd/whereiscl.go"],
    importpath = "go.fuchsia.dev/fuchsia/tools/whereiscl/cmd",
    target_compatible_with = HOST_CONSTRAINTS,
    deps = [":lib"],
)

go_binary_host_tool(
    name = "whereiscl",
    embed = [":main"],
    target_compatible_with = HOST_CONSTRAINTS,
    visibility = ["//visibility:public"],
)

go_library(
    name = "testhelper",
    srcs = ["testhelper/testhelper.go"],
    importpath = "go.fuchsia.dev/fuchsia/tools/whereiscl/testhelper",
    target_compatible_with = HOST_CONSTRAINTS,
    deps = ["//third_party/golibs:github.com/google/go-cmp/cmp"],
)

# We can also migrate the test content to Bazel, even if we run it from GN for now.
go_test(
    name = "whereiscl_test",
    srcs = [
        "changeinfo_test.go",
        "gistatus_test.go",
    ],
    embed = [":lib"],
    target_compatible_with = HOST_CONSTRAINTS,
    deps = [
        ":testhelper",
        "//third_party/golibs:github.com/google/go-cmp/cmp",
    ],
)

stamp_group(
    name = "tests",
    testonly = True,
    stamp = "build.stamp",
    target_compatible_with = HOST_CONSTRAINTS,
    deps = [":whereiscl_test"],
)
