load("@io_bazel_rules_go//go:def.bzl", "go_library")
load("@platforms//host:constraints.bzl", "HOST_CONSTRAINTS")
load("//build/bazel/host_tests:host_go_test.bzl", "host_go_test")

package(default_applicable_licenses = ["//:license"])

go_library(
    name = "metrics",
    srcs = [
        "counter.go",
        "definitions.go",
        "registry.go",
        "timer.go",
    ],
    importpath = "go.fuchsia.dev/fuchsia/tools/check-licenses/metrics",
    target_compatible_with = HOST_CONSTRAINTS,
    visibility = ["//visibility:public"],
)

host_go_test(
    name = "metrics_test",
    srcs = [
        "counter_test.go",
        "registry_test.go",
        "timer_test.go",
    ],
    embed = [":metrics"],
    target_compatible_with = HOST_CONSTRAINTS,
    visibility = ["//tools/check-licenses:__subpackages__"],
)
