{
  "tools": {
    "exclude": [
      "search_file_content"
    ],
    "discoveryCommand": ".gemini/call_tool.py discover",
    "callCommand": ".gemini/call_tool.py"
  },
  "context": {
    "fileFiltering": {
      "respectGitIgnore": true,
      "enableRecursiveFileSearch": false
    },
    "includeDirectories": [
      "local",
      "vendor/google"
    ],
    "loadFromIncludeDirectories": true
  }
}