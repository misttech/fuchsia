{
    "fileFiltering": {
        "respectGitIgnore": true,
        "enableRecursiveFileSearch": false
    },
    "excludeTools": [
        "search_file_content"
    ],
    "includeDirectories": [
        "local",
        "vendor/google"
    ],
    "loadMemoryFromIncludeDirectories": true,
    "toolDiscoveryCommand": ".gemini/call_tool.py discover",
    "toolCallCommand": ".gemini/call_tool.py"
}
