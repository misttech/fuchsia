load(
    "@rules_fuchsia//fuchsia:defs.bzl",
    "fuchsia_cc_driver",
    "fuchsia_component_manifest",
    "fuchsia_driver_bind_bytecode",
    "fuchsia_driver_component",
    "fuchsia_package",
)

fuchsia_driver_bind_bytecode(
    name = "example-config-bind-bytecode",
    output = "example_config_driver.bindbc",
    rules = "meta/config_driver.bind",
    deps = [
        "//examples/drivers/bind/bindlib:gizmo.example",
    ],
)

cc_library(
    name = "common",
    srcs = [
        "config_driver.cc",
    ],
    hdrs = [
        "config_driver.h",
    ],
    deps = [
        "@fuchsia_sdk//pkg/driver_component_cpp",
        "@fuchsia_sdk//pkg/driver_logging_cpp",
        "@fuchsia_sdk//pkg/zx",
    ],
)

fuchsia_cc_driver(
    name = "example-config-driver",
    output_name = "example_config_driver",
    deps = [":common"],
)

fuchsia_component_manifest(
    name = "manifest",
    src = "meta/config_driver.cml",
)

fuchsia_driver_component(
    name = "component",
    bind_bytecode = ":example-config-bind-bytecode",
    driver_lib = ":example-config-driver",
    manifest = ":manifest",
)

fuchsia_package(
    name = "pkg",
    package_name = "example_config_driver",
    components = [":component"],
    fuchsia_api_level = "HEAD",
    package_repository_name = "fuchsia.com",
    visibility = ["//visibility:public"],
)
