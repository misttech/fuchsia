import("//build/components.gni")
import("//src/lib/dso/fuchsia_dso.gni")

fuchsia_cc_dso("lib") {
  output_name = "simple_dso"
  async = false
  sources = [ "main.cc" ]
  deps = [
    "//sdk/lib/syslog/cpp",
    "//src/lib/dso/cpp:sync",
  ]
}

fuchsia_package_with_single_component("simple_dso") {
  manifest = "meta/simple_dso.cml"
  deps = [ ":lib" ]
}

group("dso") {
  deps = [ ":simple_dso" ]
}
