import("//build/components.gni")

fuchsia_component("client") {
  component_name = "keyvaluestore_supporttrees_client"
  manifest = "//examples/fidl/new/key_value_store/support_trees/meta/client.cml"
  deps = [
    "client:bin",
    "//examples/fidl/new/key_value_store/data:resources",
  ]
}

fuchsia_component("server") {
  component_name = "keyvaluestore_supporttrees_server"
  manifest = "//examples/fidl/new/key_value_store/support_trees/meta/server.cml"
  deps = [ "server:bin" ]
}

fuchsia_package("examples_fidl_keyvaluestore_supporttrees_rust_next") {
  deps = [
    ":client",
    ":server",
    "//examples/fidl/new/key_value_store/support_trees:client_config_values",
  ]
}

fuchsia_component("test") {
  testonly = true
  manifest =
      "//examples/fidl/new/key_value_store/support_trees/test/meta/runner.cml"
  deps = [
    "//examples/fidl/new/key_value_store/support_trees/test:runner_bin",
    "//examples/fidl/new/key_value_store/support_trees/test/goldens:resources",
  ]
}

fuchsia_test_package(
    "examples_fidl_keyvaluestore_supporttrees_rust_next_tests") {
  deps = [
    ":client",
    ":server",
    "//examples/fidl/new/key_value_store/support_trees:client_config_values",
    "//examples/fidl/new/key_value_store/support_trees/realm",
  ]
  test_components = [ ":test" ]
}

group("tests") {
  testonly = true
  deps = [ ":examples_fidl_keyvaluestore_supporttrees_rust_next_tests" ]
}
