load("//build/bazel/rules/fidl:fidl_library.bzl", "fidl_library")

fidl_library(
    name = "fuchsia.sysmem2",
    srcs = [
        "allocator.fidl",
        "collection.fidl",
        "config.fidl",
        "constraints.fidl",
        "error.fidl",
        "overview.fidl",
        "results.fidl",
        "secure_mem.fidl",
        "usages.fidl",
    ],
    api_area = "Media",
    category = "partner",
    enable_cpp = True,
    enable_hlcpp = True,
    enable_rust = True,
    stable = True,
    visibility = ["//visibility:public"],
    deps = [
        "//sdk/fidl/fuchsia.images2",
        "//sdk/fidl/fuchsia.math",
        "//zircon/vdso/zx",
    ],
)

# TODO(https://fxbug.dev/446911800): Remove when the issue is resolved.
exports_files(["fuchsia.sysmem2.api"])
