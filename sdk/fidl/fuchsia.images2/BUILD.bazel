load("//build/bazel/rules/fidl:fidl_library.bzl", "fidl_library")

fidl_library(
    name = "fuchsia.images2",
    srcs = [
        "format_modifier.fidl",
        "image_format.fidl",
        "overview.fidl",
    ],
    api_area = "Media",  # Also Graphics.
    category = "partner",
    enable_hlcpp = True,
    stable = True,
    visibility = ["//visibility:public"],
    deps = ["//sdk/fidl/fuchsia.math"],
)

# TODO(https://fxbug.dev/446911800): Remove when the issue is resolved.
exports_files(["fuchsia.images2.api"])
