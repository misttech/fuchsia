/// The fuchsia.usb.policy interfaces provide mechanisms for clients to query and monitor
/// the overall state of USB devices and the USB subsystem, independent of the underlying
/// hardware driver implementations.
@available(added=HEAD)
library fuchsia.usb.policy;
