@available(added=HEAD)
library fuchsia.hardware.lightsensor;

using zx;

@serializable
type Metadata = table {
    1: gain uint8;

    2: integration_time zx.Duration;

    /// 0 means no polling.
    3: polling_time zx.Duration;
};
