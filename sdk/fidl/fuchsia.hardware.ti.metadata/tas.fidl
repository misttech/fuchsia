library fuchsia.hardware.ti.metadata;

const MAX_NUMBER_OF_REGISTER_WRITES uint32 = 256;

@serializable
type TasMetadata = struct {
    bridged bool;
    instance_count uint8;
    init_sequence1 vector<Register>:MAX_NUMBER_OF_REGISTER_WRITES;
    init_sequence2 vector<Register>:MAX_NUMBER_OF_REGISTER_WRITES;
};
