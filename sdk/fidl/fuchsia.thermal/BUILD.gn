import("//build/fidl/fidl.gni")

fidl("fuchsia.thermal") {
  sdk_category = "partner"
  stable = true
  sdk_area = "Power"
  sources = [
    "client_state.fidl",
    "overview.fidl",
    "sensor_manager.fidl",
    "thermal.fidl",
  ]

  public_deps = [ "//sdk/fidl/fuchsia.hardware.temperature" ]

  enable_hlcpp = true
}
