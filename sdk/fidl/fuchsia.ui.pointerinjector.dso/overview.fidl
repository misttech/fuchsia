/// Clone of |fuchsia.ui.pointerinjector|, but uses driver transport.
/// Only protocols are forked because those are the only types that require
/// the transport attribute.
/// Supports DSO experiment: https://fxbug.dev/403545512
@available(added=HEAD)
library fuchsia.ui.pointerinjector.dso;
