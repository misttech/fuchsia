library fuchsia.hardware.amlogic.metadata;

using zx;

type VoltageTableEntry = struct {
    microvolt uint32;
    duty_cycle uint32;
};

@serializable
type PowerMetadata = table {
    1: voltage_table vector<VoltageTableEntry>:MAX;
    2: voltage_pwm_period zx.Duration;
};
