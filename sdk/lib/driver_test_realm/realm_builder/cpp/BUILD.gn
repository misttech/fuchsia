import("//build/components.gni")
import("//build/cpp/sdk_source_set.gni")

sdk_source_set("cpp") {
  # TODO(https://fxbug.dev/376105715): Promote to "partner" with devicetree.
  category = "internal"
  sdk_name = "driver_test_realm_builder"
  sources = [
    "builder.cc",
    "lib.cc",
  ]
  public = [
    "builder.h",
    "lib.h",
  ]
  include_base = "//sdk"

  non_sdk_public_deps = [
    "//sdk/lib/driver_test_realm",
    "//sdk/lib/sys/component/cpp/testing:cpp",
  ]

  deps = [
    "//sdk/fidl/fuchsia.component:fuchsia.component_cpp",
    "//sdk/fidl/fuchsia.driver.development:fuchsia.driver.development_cpp",
    "//sdk/lib/component/incoming/cpp",
  ]
  public_deps = [
    "//sdk/fidl/fuchsia.component.decl:fuchsia.component.decl_cpp_hlcpp_conversion",
    "//sdk/fidl/fuchsia.component.test:fuchsia.component.test_cpp",
    "//sdk/fidl/fuchsia.driver.test:fuchsia.driver.test_cpp",
    "//sdk/lib/async-loop",
    "//sdk/lib/async-loop:async-loop-cpp",
    "//sdk/lib/driver_test_realm:internal_server_cpp",
    "//sdk/lib/sys/component/cpp/testing:cpp_library",
  ]
}
