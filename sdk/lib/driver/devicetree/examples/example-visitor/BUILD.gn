import("//build/components.gni")

import("//build/devicetree/devicetree_visitor.gni")

group("tests") {
  deps = [
    "test:example-visitor-test($host_toolchain)",
    "test:example-visitor-test-package",
  ]
  testonly = true
}

source_set("example-visitor-impl") {
  sources = [
    "example-visitor.cc",
    "example-visitor.h",
  ]
  public_deps = [ "//sdk/lib/driver/devicetree/visitors:driver-visitor" ]
  deps = [ "//sdk/lib/driver/devicetree/visitors:registration" ]
}

devicetree_visitor("example-visitor") {
  deps = [ ":example-visitor-impl" ]
}
