import("//build/components.gni")
import("//build/dist/resource.gni")
import("//build/test.gni")
import("//build/testing/host_test_data.gni")

if (is_host) {
  _example_board_target = "//sdk/lib/driver/devicetree/examples/example-board:example-board($default_toolchain)"
  _example_board_dtb = get_label_info(_example_board_target, "target_out_dir") +
                       "/example-board.dtb"

  host_test_data("test-dtb") {
    sources = [ _example_board_dtb ]
    deps = [ _example_board_target ]
    outputs = [ "$root_out_dir/test_data/example-visitor/example-board.dtb" ]
  }
} else {
  _example_board_target =
      "//sdk/lib/driver/devicetree/examples/example-board:example-board"
  _example_board_dtb = get_label_info(_example_board_target, "target_out_dir") +
                       "/example-board.dtb"

  resource("test-dtb") {
    sources = [ _example_board_dtb ]
    deps = [ _example_board_target ]
    outputs = [ "data/example-visitor/example-board.dtb" ]
  }

  fuchsia_unittest_package("example-visitor-test-package") {
    package_name = "example-visitor-test"
    deps = [ ":example-visitor-test" ]
  }
}

test("example-visitor-test") {
  sources = [ "test.cc" ]
  deps = [
    ":test-dtb",
    "//sdk/lib/driver/devicetree/examples/example-visitor",
    "//sdk/lib/driver/devicetree/testing:visitor-test-helper",
    "//sdk/lib/driver/devicetree/visitors:registry",
    "//sdk/lib/driver/devicetree/visitors/default/bind-property",
    "//sdk/lib/driver/devicetree/visitors/default/mmio",
    "//src/devices/bind/fuchsia:fuchsia_cpp",
    "//src/devices/bind/fuchsia.platform:fuchsia.platform_cpp",
    "//src/lib/fxl/test:gtest_main",
    "//third_party/googletest:gtest",
    "//zircon/system/ulib/zx",
  ]
  if (is_host) {
    _dtb_path =
        rebase_path("$root_out_dir/test_data/example-visitor/example-board.dtb",
                    root_build_dir)
    defines = [ "DTB_PATH=\"${_dtb_path}\"" ]
  } else {
    defines = [ "DTB_PATH=\"/pkg/data/example-visitor/example-board.dtb\"" ]
  }
}
