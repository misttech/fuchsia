import("//build/components.gni")
import("//build/devicetree/devicetree.gni")
import("//build/devicetree/devicetree_visitor.gni")
import("//build/test.gni")

group("tests") {
  deps = [ ":gpt-visitor-test" ]
  testonly = true
}

devicetree_visitor("gpt-visitor") {
  sources = [
    "gpt-visitor.cc",
    "gpt-visitor.h",
  ]
  enable_sdk_source_set = true
  category = "internal"
  deps = [
    "//sdk/lib/driver/devicetree/manager:node",
    "//sdk/lib/driver/devicetree/visitors:common-types",
    "//sdk/lib/driver/devicetree/visitors:registration",
    "//sdk/lib/driver/logging/cpp",
  ]
  public_deps = [ "//sdk/lib/driver/devicetree/visitors:driver-visitor" ]
  non_sdk_deps = [
    "//src/devices/bind/fuchsia:fuchsia_cpp",
    "//src/devices/bind/fuchsia.block.gpt:fuchsia.block.gpt_cpp",
  ]
}

test("gpt-visitor-test-bin") {
  sources = [ "test/gpt-visitor-test.cc" ]
  deps = [
    ":gpt-visitor.static",
    "//sdk/lib/driver/devicetree/testing:visitor-test-helper",
    "//sdk/lib/driver/devicetree/visitors:registry",
    "//sdk/lib/driver/devicetree/visitors/default/bind-property",
    "//src/devices/bind/fuchsia:fuchsia_cpp",
    "//src/devices/bind/fuchsia.block.gpt:fuchsia.block.gpt_cpp",
    "//src/devices/bind/fuchsia.platform:fuchsia.platform_cpp",
    "//src/lib/fxl/test:gtest_main",
  ]
}

dtb("gpt-dtb") {
  sources = [ "test/dts/gpt.dts.S" ]
}

resource("gpt-dtb-file") {
  sources = get_target_outputs(":gpt-dtb")
  outputs = [ "test-data/test-dt.dtb" ]
  deps = [ ":gpt-dtb" ]
}

fuchsia_unittest_package("gpt-visitor-test") {
  component_name = "gpt-visitor-test"
  deps = [
    ":gpt-dtb-file",
    ":gpt-visitor-test-bin",
  ]
}
