import("//build/components.gni")
import("//build/devicetree/devicetree.gni")
import("//build/test.gni")

dtb("test-data") {
  sources = [ "dts/resets.dts.S" ]
}

dtb("test-data-no-names") {
  sources = [ "dts/resets-no-names.dts.S" ]
}

dtb("test-data-name-mismatch") {
  sources = [ "dts/resets-name-mismatch.dts.S" ]
}

resource("test-data-file") {
  sources = get_target_outputs(":test-data")
  outputs = [ "test-data/{{source_file_part}}" ]
  deps = [ ":test-data" ]
}

resource("test-data-no-names-file") {
  sources = get_target_outputs(":test-data-no-names")
  outputs = [ "test-data/{{source_file_part}}" ]
  deps = [ ":test-data-no-names" ]
}

resource("test-data-name-mismatch-file") {
  sources = get_target_outputs(":test-data-name-mismatch")
  outputs = [ "test-data/{{source_file_part}}" ]
  deps = [ ":test-data-name-mismatch" ]
}

test("reset-visitor-test-bin") {
  sources = [ "reset-visitor-test.cc" ]
  deps = [
    "//sdk/fidl/fuchsia.hardware.reset:fuchsia.hardware.reset_bindlib_cpp",
    "//sdk/lib/driver/devicetree/testing:visitor-test-helper",
    "//sdk/lib/driver/devicetree/visitors:registry",
    "//sdk/lib/driver/devicetree/visitors/default/bind-property",
    "//sdk/lib/driver/devicetree/visitors/drivers/reset:reset-visitor.static",
    "//src/devices/bind/fuchsia:fuchsia_cpp",
    "//src/devices/bind/fuchsia.reset:fuchsia.reset_cpp",
    "//src/lib/fxl/test:gtest_main",
  ]
}

fuchsia_unittest_package("reset-visitor-test") {
  component_name = "reset-visitor-test"
  deps = [
    ":reset-visitor-test-bin",
    ":test-data-file",
    ":test-data-name-mismatch-file",
    ":test-data-no-names-file",
  ]
  test_specs = {
    environments = basic_envs
    log_settings = {
      max_severity = "ERROR"
    }
  }
}
