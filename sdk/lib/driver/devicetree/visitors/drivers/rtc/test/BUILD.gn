import("//build/components.gni")
import("//build/devicetree/devicetree.gni")
import("//build/test.gni")

dtb("test-data") {
  sources = [ "dts/rtc.dts.S" ]
}

resource("test-data-file") {
  sources = get_target_outputs(":test-data")
  outputs = [ "test-data/{{source_file_part}}" ]
  deps = [ ":test-data" ]
}

test("rtc-visitor-test-bin") {
  sources = [ "rtc-visitor-test.cc" ]
  deps = [
    "//sdk/fidl/fuchsia.hardware.hrtimer:fuchsia.hardware.hrtimer_bindlib_cpp",
    "//sdk/lib/driver/devicetree/testing:visitor-test-helper",
    "//sdk/lib/driver/devicetree/visitors:registry",
    "//sdk/lib/driver/devicetree/visitors/default/bind-property",
    "//sdk/lib/driver/devicetree/visitors/drivers/rtc:rtc-visitor.static",
    "//src/devices/bind/fuchsia:fuchsia_cpp",
    "//src/lib/fxl/test:gtest_main",
  ]
}

fuchsia_unittest_package("rtc-visitor-test") {
  component_name = "rtc-visitor-test"
  deps = [
    ":rtc-visitor-test-bin",
    ":test-data-file",
  ]
  test_specs = {
    environments = basic_envs
    log_settings = {
      max_severity = "ERROR"
    }
  }
}
