assert(is_host, "shac tests only supported for host testing")

import("//build/python/python_host_test.gni")

python_host_test("python_format_test") {
  main_source = "python_format_test.py"
  main_callable = "main"
  extra_args = [
    "--python-bin=" + rebase_path(python_exe_src, root_build_dir),
    "--autoflake=" +
        rebase_path("//third_party/pylibs/autoflake/main.py", root_build_dir),
    "--isort=" +
        rebase_path("//third_party/pylibs/isort/main.py", root_build_dir),
    "--black=" +
        rebase_path("//prebuilt/third_party/black/${host_os}-x64/black",
                    root_build_dir),
    "--python-format-script=" +
        rebase_path("//scripts/shac/python_format.py", root_build_dir),
  ]
  test_data_deps = [
    "//build/python:black",
    "//build/python:interpreter",
    "//scripts/shac:python_format_script",
    "//third_party/pylibs:autoflake",
    "//third_party/pylibs:isort",
    "//third_party/pylibs:pyflakes",
  ]
}

group("tests") {
  testonly = true
  deps = [ ":python_format_test" ]
}
