import("//build/python/host.gni")
import("//build/python/python_binary.gni")

if (is_host) {
  python_binary("debug") {
    main_source = "main.py"

    deps = [
      "//scripts/debug/zxdb_cli/cli:cli_lib",
      "//scripts/lib/package_server",
    ]
  }

  install_python_tool("install-debug") {
    name = "debug"
    binary = ":debug"
  }

  group("tests") {
    testonly = true
    deps = [ "zxdb_cli:tests" ]
  }

  group("install") {
    deps = [
      ":install-debug",
      "zxdb_cli:install",
    ]
  }
}
