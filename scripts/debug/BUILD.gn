import("//build/python/host.gni")
import("//build/python/python_binary.gni")

if (is_host) {
  python_binary("debug") {
    main_source = "main.py"

    deps = [ "//scripts/lib/package_server" ]
  }

  install_python_tool("install") {
    name = "debug"
    binary = ":debug"
  }
}
