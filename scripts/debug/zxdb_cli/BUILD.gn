import("//build/python/host.gni")

if (is_host) {
  group("tests") {
    testonly = true
    deps = [
      "cli:cli_test",
      "daemon:tests",
      "daemon_manager:tests",
      "shared:protocol_test($host_toolchain)",
      "tests:cli_integration_test",
    ]
  }

  group("install") {
    deps = [ "daemon:install" ]
  }
}
