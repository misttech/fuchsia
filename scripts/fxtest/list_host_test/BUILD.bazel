load("//build/bazel/host_tests:host_test_data.bzl", "host_test_data_files")

package(default_applicable_licenses = ["//:license"])

# Expose the list_host_python_unittests.py script as a test data file.
# Used by the host_py_test() macro to generate the test wrapper script.
host_test_data_files(
    name = "as_test_data",
    testonly = True,
    srcs = ["list_host_python_unittests.py"],
    dest_dir = "test_data",
    visibility = ["//visibility:public"],
)
