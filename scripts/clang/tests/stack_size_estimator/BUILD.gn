import("//build/python/python_host_test.gni")
import("//build/testing/host_test_data.gni")

if (is_host) {
  python_host_test("stack_estimator_test") {
    main_source = "stack_estimator_test.py"
    sources = [
      "//scripts/clang/stack_size_estimator/call_graph.py",
      "//scripts/clang/stack_size_estimator/graph.py",
      "//scripts/clang/stack_size_estimator/stack_estimator.py",
      "//scripts/clang/stack_size_estimator/symbolizer.py",
    ]
    deps = [ ":test_data" ]
  }

  host_test_data("test_data") {
    sources = [
      "test_call_graph.json",
      "test_combined.json",
      "test_config.json",
      "test_indirect.json",
      "test_input.json",
      "test_stack_sizes.json",
    ]
    outputs = [
      "$target_out_dir/stack_estimator_test/test_data/{{source_file_part}}",
    ]
  }
}

group("tests") {
  testonly = true
  deps = [ ":stack_estimator_test($host_toolchain)" ]
}
