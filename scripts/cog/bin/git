set -o errexit

SCRIPTS_COG_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"

readonly PY_TOOL="${SCRIPTS_COG_BIN_DIR}/../../fuchsia-vendored-python"

function main() {
    "$PY_TOOL" "${SCRIPTS_COG_BIN_DIR}/git.py" "$@"
}

main "$@"