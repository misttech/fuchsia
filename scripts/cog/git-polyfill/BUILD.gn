import("//build/python/python_host_test.gni")

group("tests") {
  testonly = true
  deps = [ ":git_test($host_toolchain)" ]
}

if (is_host) {
  python_host_test("git_test") {
    main_source = "tests/test_git.py"
    sources = [ "git.py" ]
  }
}
