import("//build/components.gni")
import("//build/rust/rustc_library.gni")

rustc_library("selinux") {
  with_unit_tests = true
  edition = "2024"
  sources = [
    "src/access_vector_cache.rs",
    "src/cache_stats.rs",
    "src/concurrent_access_cache.rs",
    "src/concurrent_cache.rs",
    "src/exceptions_config.rs",
    "src/kernel_permissions.rs",
    "src/lib.rs",
    "src/local_cache.rs",
    "src/new_policy/bitmap.rs",
    "src/new_policy/error.rs",
    "src/new_policy/id_type.rs",
    "src/new_policy/metadata.rs",
    "src/new_policy/mod.rs",
    "src/new_policy/parser.rs",
    "src/new_policy/traits.rs",
    "src/new_policy/types.rs",
    "src/permission_check.rs",
    "src/policy/arrays.rs",
    "src/policy/constraints.rs",
    "src/policy/error.rs",
    "src/policy/extensible_bitmap.rs",
    "src/policy/index.rs",
    "src/policy/metadata.rs",
    "src/policy/mod.rs",
    "src/policy/parsed_policy.rs",
    "src/policy/parser.rs",
    "src/policy/security_context.rs",
    "src/policy/symbols.rs",
    "src/policy/view.rs",
    "src/security_server.rs",
    "src/sid_table.rs",
    "src/sync.rs",
  ]
  inputs = [
    "testdata/composite_policies/compiled/allow_fork_policy",
    "testdata/composite_policies/compiled/class_defaults_policy",
    "testdata/composite_policies/compiled/fs_test_policy",
    "testdata/composite_policies/compiled/genfscon_policy",
    "testdata/composite_policies/compiled/handle_unknown_policy-allow",
    "testdata/composite_policies/compiled/handle_unknown_policy-deny",
    "testdata/composite_policies/compiled/handle_unknown_policy-reject",
    "testdata/composite_policies/compiled/minimal_policy",
    "testdata/composite_policies/compiled/range_transition_policy",
    "testdata/composite_policies/compiled/role_transition_not_allowed_policy",
    "testdata/composite_policies/compiled/role_transition_policy",
    "testdata/composite_policies/compiled/type_transition_policy",
    "testdata/composite_policies/compiled/exceptions_config_policy",
    "testdata/composite_policies/compiled/with_additional_domain_policy",
    "testdata/composite_policies/compiled/with_unlabeled_access_domain_policy",
    "testdata/expectations/emulator",
    "testdata/expectations/selinux_testsuite",
    "testdata/micro_policies/allow_a_attr_b_attr_class0_perm0_policy",
    "testdata/micro_policies/allow_a_t_a1_attr_class0_perm0_a2_attr_class0_perm1_policy",
    "testdata/micro_policies/allow_a_t_b_attr_class0_perm0_policy",
    "testdata/micro_policies/allow_a_t_b_t_class0_perm0_policy",
    "testdata/micro_policies/allow_with_constraints_policy",
    "testdata/micro_policies/allowxperm_policy",
    "testdata/micro_policies/constraints_policy",
    "testdata/micro_policies/file_no_defaults_policy",
    "testdata/micro_policies/file_range_source_high_policy",
    "testdata/micro_policies/file_range_source_low_high_policy",
    "testdata/micro_policies/file_range_source_low_policy",
    "testdata/micro_policies/file_range_target_high_policy",
    "testdata/micro_policies/file_range_target_low_high_policy",
    "testdata/micro_policies/file_range_target_low_policy",
    "testdata/micro_policies/file_source_defaults_policy",
    "testdata/micro_policies/file_target_defaults_policy",
    "testdata/micro_policies/multiple_levels_and_categories_policy",
    "testdata/micro_policies/no_allow_a_attr_b_attr_class0_perm0_policy",
    "testdata/micro_policies/no_allow_a_t_b_attr_class0_perm0_policy",
    "testdata/micro_policies/no_allow_a_t_b_t_class0_perm0_policy",
    "testdata/micro_policies/security_context_tests_policy",
    "testdata/micro_policies/security_server_tests_policy",
    "testdata/policies/emulator",
    "testdata/policies/selinux_testsuite",
  ]
  deps = [
    "src/new_policy/derive_macros",
    "//src/lib/trace/rust:trace",
    "//src/starnix/lib/starnix_logging",
    "//src/starnix/lib/starnix_uapi",
    "//third_party/rust_crates:anyhow",
    "//third_party/rust_crates:bstr",
    "//third_party/rust_crates:crossbeam-utils",
    "//third_party/rust_crates:hashbrown",
    "//third_party/rust_crates:itertools",
    "//third_party/rust_crates:paste",
    "//third_party/rust_crates:rapidhash",
    "//third_party/rust_crates:static_assertions",
    "//third_party/rust_crates:strum",
    "//third_party/rust_crates:strum_macros",
    "//third_party/rust_crates:thiserror",
    "//third_party/rust_crates:zerocopy",
  ]
  test_deps = [
    "//src/lib/fuchsia-sync",
    "//third_party/rust_crates:serde",
    "//third_party/rust_crates:serde_json5",
  ]
  configs += [ "//src/starnix/build:kernel_library_config" ]

  if (is_host) {
    # Host builds use `parking_lot` for lock primitives.
    deps += [ "//third_party/rust_crates:parking_lot" ]
  } else {
    # Fuchsia/starnix builds identified by feature `selinux_starnix`.
    features = [ "selinux_starnix" ]

    # Fuchsia/starnix builds use `starnix_sync` for lock primitives.
    deps += [ "//src/starnix/lib/starnix_sync" ]
  }
}

fuchsia_unittest_package("starnix-selinux-unit-tests") {
  deps = [ ":selinux_test" ]
}

group("tests") {
  testonly = true

  deps = [
    ":starnix-selinux-unit-tests",
    "scripts:tests",
  ]
}
