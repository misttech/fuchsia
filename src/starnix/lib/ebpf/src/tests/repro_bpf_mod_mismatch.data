-- asm
# Obtain proper unknown scalar (runtime 0, verifier unknown)
call 2
# Shift right to ensure max value is 1 (unknown mask >> 63)
rsh %r0, 63
# Load large payload
mov %r1, 0x1000
# Trigger issue:
mod %r1, %r0
# Load stack pointer
mov %r3, %r10
# Subtract offset.
# Verifier now sees a max result of 0x1000.
# access is known to be OOB: sub %r3, 0x1000
sub %r3, %r1
# Access memory. Verifier should reject this as OOB.
ldxb %r2, [%r3]
exit
-- error
access (4096) + 1 exceeds stack size (512)
