-- asm
# Get an unkown value in r0
call 2
# Narrow r0 range to [10, max]
jlt %r0, 10, +2
# If verifier incorrectly calculates range to be [10, 10]
# then the following code will exit, otherwise if it correctly
# calculates the range as [10, max], then r0 = 11 is a possibility
# and an infinite loop is entered.  The verifier will reject the
# program.
jeq %r0, 11, -1
mov %r0, 0
exit
-- error
at PC 2: bpf byte code does not terminate
