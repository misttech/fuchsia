{
    "name": "vreprint_basic",
    "initial_termios": {
        "c_iflag": [
            "ICRNL",
            "IXON"
        ],
        "c_oflag": [
            "OPOST",
            "ONLCR"
        ],
        "c_lflag": [
            "ISIG",
            "ICANON",
            "ECHO",
            "ECHOE",
            "ECHOK",
