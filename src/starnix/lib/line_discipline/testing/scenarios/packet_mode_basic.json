{
    "name": "packet_mode_basic",
    "initial_termios": {
        "c_iflag": [
            "IXON"
        ],
        "c_lflag": [
            "ISIG",
            "ICANON",
            "ECHO",
            "IEXTEN"
        ]
    },
    "events": [
        {
            "action": "set_packet_mode",
            "enabled": true
        },
        {
            "action": "write_to_master",
            "data": "foo\n"
        },
        {
            "action": "read_from_slave"
        },
        {
            "action": "write_to_slave",
            "data": "hello"
        },
        {
            "action": "read_from_master"
        },
        {
            "action": "set_termios",
            "termios": {
                "c_iflag": []
            }
        },
        {
            "action": "read_from_master"
        },
        {
            "action": "set_packet_mode",
            "enabled": false
        },
        {
            "action": "write_to_slave",
            "data": "world"
        },
        {
            "action": "read_from_master"
        }
    ]
}
