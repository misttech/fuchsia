{
    "name": "tcioflush_canon",
    "initial_termios": {
        "c_lflag": [
            "ICANON"
        ]
    },
    "events": [
        {
            "type": "write_to_master",
            "data": "input"
        },
        {
            "type": "write_to_slave",
            "data": "output"
        },
        {
            "type": "wait_until_readable",
            "side": "main"
        },
        {
            "type": "flush",
            "side": "replica",
            "queue_selector": "TCIOFLUSH"
        },
        {
            "type": "write_to_master",
            "data": "input2\n"
        },
        {
            "type": "write_to_slave",
            "data": "output2"
        },
        {
            "type": "read_from_slave",
            "data": "input2\n"
        },
        {
            "type": "read_from_master",
            "data": "outputoutput2"
        }
    ],
    "final_termios": {
        "c_iflag": [],
        "c_oflag": [],
        "c_lflag": [
            "ICANON"
        ]
    }
}
