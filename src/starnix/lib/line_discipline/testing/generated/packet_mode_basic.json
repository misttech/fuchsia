{
    "name": "packet_mode_basic",
    "initial_termios": {
        "c_iflag": [
            "IXON"
        ],
        "c_lflag": [
            "ISIG",
            "ICANON",
            "ECHO",
            "IEXTEN"
        ]
    },
    "events": [
        {
            "type": "set_packet_mode",
            "enabled": true
        },
        {
            "type": "write_to_master",
            "data": "foo\n"
        },
        {
            "type": "read_from_slave",
            "data": "foo\n"
        },
        {
            "type": "write_to_slave",
            "data": "hello"
        },
        {
            "type": "read_from_master",
            "data": "\u0000foo\nhello"
        },
        {
            "type": "set_termios",
            "termios": {
                "c_iflag": []
            }
        },
        {
            "type": "read_from_master",
            "data": "\u0010"
        },
        {
            "type": "set_packet_mode",
            "enabled": false
        },
        {
            "type": "write_to_slave",
            "data": "world"
        },
        {
            "type": "read_from_master",
            "data": "world"
        }
    ],
    "final_termios": {
        "c_iflag": [],
        "c_oflag": [],
        "c_lflag": []
    }
}
