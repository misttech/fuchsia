import("//build/components.gni")
import("//build/components/fuchsia_unittest_package.gni")
import("//build/fuzz.gni")
import("//build/rust/rustc_fuzzer.gni")

rustc_fuzzer("fuzz_bytecode_parse_from_bytes") {
  edition = "2024"
  sources = [ "fuzz/bytecode_parse_from_bytes.rs" ]
  source_root = "fuzz/bytecode_parse_from_bytes.rs"
  deps = [
    "//src/lib/fuzzing/rust:fuzz",
    "//src/starnix/lib/third_party/rust_netlink/netlink_packet_sock_diag",
  ]
  configs += [ "//build/config/rust/lints:deny_unused_results" ]
}

fuchsia_fuzzer_component("fuzz_bytecode_parse_from_bytes_component") {
  manifest = "meta/fuzz_bytecode_parse_from_bytes.cml"
  deps = [ ":fuzz_bytecode_parse_from_bytes" ]
}

rustc_fuzzer("fuzz_bytecode_serialize") {
  edition = "2024"
  sources = [ "fuzz/bytecode_serialize.rs" ]
  source_root = "fuzz/bytecode_serialize.rs"
  deps = [
    "//src/lib/fuzzing/rust:fuzz",
    "//src/starnix/lib/third_party/rust_netlink/netlink_packet_sock_diag",
    "//third_party/rust_crates:arbitrary",
  ]
  configs += [ "//build/config/rust/lints:deny_unused_results" ]
}

fuchsia_fuzzer_component("fuzz_bytecode_serialize_component") {
  manifest = "meta/fuzz_bytecode_serialize.cml"
  deps = [ ":fuzz_bytecode_serialize" ]
}

rustc_fuzzer("fuzz_bytecode_serialize_varied_buffer") {
  edition = "2024"
  sources = [ "fuzz/bytecode_serialize_varied_buffer.rs" ]
  source_root = "fuzz/bytecode_serialize_varied_buffer.rs"
  deps = [
    "//src/lib/fuzzing/rust:fuzz",
    "//src/starnix/lib/third_party/rust_netlink/netlink_packet_sock_diag",
    "//third_party/rust_crates:arbitrary",
  ]
  configs += [ "//build/config/rust/lints:deny_unused_results" ]
}

fuchsia_fuzzer_component("fuzz_bytecode_serialize_varied_buffer_component") {
  manifest = "meta/fuzz_bytecode_serialize_varied_buffer.cml"
  deps = [ ":fuzz_bytecode_serialize_varied_buffer" ]
}

fuchsia_fuzzer_package("netlink_packet_sock_diag_fuzzers") {
  rust_fuzzer_components = [
    ":fuzz_bytecode_parse_from_bytes_component",
    ":fuzz_bytecode_serialize_component",
    ":fuzz_bytecode_serialize_varied_buffer_component",
  ]
}

group("tests") {
  testonly = true
  deps = [ ":netlink_packet_sock_diag_fuzzers" ]
}
