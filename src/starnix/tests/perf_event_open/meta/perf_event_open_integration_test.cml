{
    include: [
        "//sdk/lib/sys/component/realm_builder.shard.cml",
        "sys/testing/elf_test_runner.shard.cml",
        "syslog/client.shard.cml",
    ],
    program: {
        binary: "bin/perf_event_open_integration_test_rustc",
    },
    children: [
        {
            name: "kernel",
            url: "starnix_kernel#meta/starnix_kernel.cm",
        },
        {
            name: "container",
            url: "debian#meta/debian_container.cm",
            environment: "#starnix_kernel_env",
        },
    ],
    collections: [
        {
            name: "starnix_container_children",
            environment: "#container_env",
            durability: "single_run",
        },
    ],
    use: [
        {
            protocol: [ "fuchsia.component.Realm" ],
            from: "framework",
        },
        {
            event_stream: [ "stopped" ],
        },
    ],
    offer: [
        {
            protocol: [ "fuchsia.kernel.VmexResource" ],
            from: "parent",
            to: "#kernel",
        },
        {
            directory: "boot-kernel",
            from: "parent",
            to: "#kernel",
        },
        {
            protocol: [ "fuchsia.cpu.profiler.Session" ],
            from: "parent",
            to: "#kernel",
        },
        {
            protocol: [ "fuchsia.logger.LogSink" ],
            from: "parent",
            to: [
                "#container",
                "#kernel",
            ],
        },
    ],
    environments: [
        {
            name: "starnix_kernel_env",
            extends: "realm",
            runners: [
                {
                    runner: "starnix",
                    from: "#kernel",
                },
            ],
        },
        {
            name: "container_env",
            extends: "realm",
            runners: [
                {
                    runner: "starnix_container",
                    from: "#container",
                },
            ],
        },
    ],
}
