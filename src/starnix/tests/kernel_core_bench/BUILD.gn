import("//build/components.gni")
import("//build/rust/rustc_binary.gni")
import("//build/testing/perf/test.gni")

group("kernel_core_bench") {
  public_deps = [ ":benchmarks" ]
  testonly = true
}

group("benchmarks") {
  deps = [ ":pkg" ]
  testonly = true
}

rustc_binary("bin") {
  output_name = "starnix_kernel_core_bench"
  testonly = true
  edition = "2024"
  sources = [ "src/main.rs" ]
  deps = [
    "//sdk/rust/zx",
    "//src/developer/fuchsia-criterion",
    "//src/lib/fuchsia-runtime",
    "//src/starnix/kernel/core",
  ]
  configs += [ "//build/config/rust/lints:deny_unused_results" ]
}

fuchsia_package_with_single_component("pkg") {
  package_name = "starnix_kernel_core_bench"
  component_name = "starnix_kernel_core_bench"
  manifest = "meta/benchmarks.cml"
  deps = [ ":bin" ]
  testonly = true
}
