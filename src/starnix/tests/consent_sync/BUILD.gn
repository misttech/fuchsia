import("//build/components.gni")
import("//build/rust/rustc_test.gni")
import("//src/starnix/build/starnix_linux_executable.gni")
import("//src/starnix/kernel/starnix.gni")

group("tests") {
  testonly = true
  deps = [ ":starnix_consent_sync_integration_test" ]
}

starnix_linux_executable("consent_sync_test_bin") {
  testonly = true
  sources = [ "src/main.cc" ]
}

fuchsia_component("consent_sync_test") {
  testonly = true
  manifest = "meta/consent_sync_test.cml"
  deps = [ ":consent_sync_test_bin" ]
}

fuchsia_component("realm") {
  testonly = true
  manifest = "meta/realm.cml"
}

fuchsia_component("test_container") {
  testonly = true
  manifest = "meta/test_container.cml"
}

rustc_test("consent_sync_integration_test_runner") {
  edition = "2024"
  source_root = "src/driver.rs"
  sources = [ "src/driver.rs" ]
  deps = [
    "//sdk/fidl/fuchsia.logger:fuchsia.logger_rust",
    "//sdk/fidl/fuchsia.settings:fuchsia.settings_rust",
    "//sdk/fidl/fuchsia.sys2:fuchsia.sys2_rust",
    "//src/lib/fidl/rust/fidl",
    "//src/lib/fuchsia-async",
    "//src/lib/fuchsia-component",
    "//src/lib/fuchsia-component-test",
    "//src/lib/fuchsia-sync",
    "//third_party/rust_crates:anyhow",
    "//third_party/rust_crates:futures",
  ]
}

fuchsia_test_component("test_runner_component") {
  testonly = true
  manifest = "meta/integration_test.cml"
  component_name = "integration_test"
  test_type = "starnix"
  deps = [ ":consent_sync_integration_test_runner" ]
}

fuchsia_test_package("starnix_consent_sync_integration_test") {
  test_components = [ ":test_runner_component" ]
  deps = [
    ":consent_sync_test",
    ":realm",
    ":test_container",
    "//src/starnix/containers/debian:container_resources",
  ]
  subpackages = [ "//src/starnix/kernel:starnix_kernel_package" ]
}
