{
    actions: [
        {
            type: "expect_pass",
            matchers: [],
        },
        {
            type: "expect_failure",
            matchers: [
                //TODO(https://fxbug.dev/445523586): failing tests in kselftest
                "binderfs",
                "capabilities_test_execve",
                "kcmp_kcmp_test",
                "mm_mremap_test",
                "net_psock_tpacket",
                "ptrace_peeksiginfo",
                "rtc_rtctest",
                "seccomp_seccomp_bpf",
                "splice_default_file_splice_read.sh",
                "timers_posix_timers",
                "timers_set_tai",
                "timers_valid_adjtimex",
                "vDSO_kselftest_vdso_test_abi",
            ],
        },
        {
            type: "skip",
            matchers: [
                //TODO(https://fxbug.dev/484431306): test unable to find files
                "cpu_hotplug_cpu_on_off_test",

                // TODO(https://fxbug.dev/444478449): futex_wait_requeue_pi unimplemented function blocking kselftest test
                "futex_functional_run.sh",

                // TODO(https://fxbug.dev/444498716): timers_set_timer_lat hangs at wait_signaled_sync, instance of HR_TIMER_BUG
                "timers_set_timer_lat",

                // TODO(https://fxbug.dev/449164060): De-flake and re-enable
                "timers_nanosleep",
            ],
        },
    ],
}
