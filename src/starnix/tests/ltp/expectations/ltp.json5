{
    actions: [
        {
            type: "expect_pass",
            matchers: [
                "*",
            ],
        },
        {
            type: "expect_failure",
            matchers: [
                "add_key01",
                "add_key03",
                "adjtimex01",
                "adjtimex02",
                "adjtimex03",

                // This test checks that you cannot trick the kernel into chmoding a symlink node
                // directly by opening a O_NOFOLLOW fd, and then chmoding that fd via a path in /proc.
                //
                // Right now Starnix actually chmods the underlying file, because it ends up following
                // the entire symlink chain even when chmoding through proc. However, the test also
                // verifies that the underlying file was not chmod'ed, in addition to the symlink, so it
                // still fails.
                "chmod09",
                "clock_adjtime01",
                "clock_adjtime02",
                "clock_settime01",
                "clock_settime02",
                "clock_settime04",

                // TODO(https://fxbug.dev/42066087): Requires CLONE_VM without CLONE_THREAD.
                // Currently, we implement this combination of flags by making a copy-on-write
                // clone of the VM, which is insufficient to pass this test because the test uses
                // a volatile write to communicate the status of the child process.
                "clone05",

                // Requires CLONE_NEWNET. In order to implement CLONE_NEWNET, we would need to
                // support network namespaces. Additionally, even if we supported network
                // namespaces, this test would still fail until we implement CLONE_VM without
                // CLONE_THREAD because the test uses a shared VM to send back the result.
                "clone09",
                "cpuacct_1_1",
                "cve-2015-7550",
                "cve-2016-5195",
                "cve-2016-9604",
                "cve-2016-9793",
                "cve-2017-12192",
                "cve-2017-12193",
                "cve-2017-15274",
                "cve-2017-15299",
                "cve-2017-15951",
                "cve-2017-17807",
                "cve-2017-18075",
                "cve-2017-6951",
                "cve-2017-7308",
                "cve-2017-7472",
                "cve-2018-1000199",
                "cve-2018-11508",
                "cve-2018-19854",
                "cve-2018-5803",
                "cve-2018-8897",
                "cve-2018-9568",
                "cve-2020-11494",
                "cve-2021-4034",
                "cve-2022-2590",

                // TODO(https://fxbug.dev/465930802)
                "epoll_pwait06",

                // Requires SEEK_HOLE.
                "fallocate04",

                // Fails due to: "No supported filesystems"
                "getxattr03",

                // Does not run on tmpfs.
                "fcntl24",
                "fcntl24_64",

                // Does not run on tmpfs.
                "fcntl25",
                "fcntl25_64",

                // Does not run on tmpfs.
                "fcntl26",
                "fcntl26_64",

                // 31 requires F_SETSIG.
                "fcntl31",
                "fcntl31_64",

                // Does not run on tmpfs.
                "fcntl32",
                "fcntl32_64",

                // 33 requires F_GETSIG.
                "fcntl33",
                "fcntl33_64",

                // Skipped with tmpfs.
                "fdatasync03",
                "fsetxattr02",
                "futimesat01",
                "getitimer01",

                // TODO: https://fxbug.dev/287118373 - depends on PRIO_PGRP and PRIO_USER support.
                "getpriority01", // https://fxbug.dev/287118373
                "getpriority02", // https://fxbug.dev/287118373

                // Skipped with tmpfs.
                "ioctl_loop05",
                "ioprio_get01",
                "ioprio_set01",
                "ioprio_set02",
                "ioprio_set03",
                "keyctl01",
                "keyctl03",
                "keyctl05",
                "keyctl06",
                "leapsec01",
                "madvise02",
                "madvise08",
                "membarrier01",
                "mincore01",
                "mincore02",
                "mincore03",
                "mincore04",
                "mlock201",
                "mlock203",
                "mlockall01",
                "mlockall02",
                "mlockall03",
                "mmap12",
                "mmap14",
                "mount02",
                "mprotect01",
                "mprotect05",
                "msync03",
                "msync04",
                "munlockall01",

                // Needs /proc/sys/fs/pipe-user-pages-soft
                "pipe15",
                "pivot_root01",
                "prctl01",
                "prctl02",
                "prctl08",
                "prctl10",
                "ptrace10",
                "pwritev03",
                "pwritev03_64",
                "quotactl04",
                "quotactl08",
                "quotactl09",

                // Depends on IO stats in /proc/<pid>/io .
                "readahead02",
                "remap_file_pages02",
                "request_key01",
                "request_key02",
                "request_key03",
                "request_key04",
                "request_key05",
                "request_key06",
                "runpwtests03",
                "runpwtests06",

                // TODO: https://fxbug.dev/287120797 - maybe we'll implement sched_getattr?
                "sched_getattr01", // https://fxbug.dev/287120797
                "sched_getattr02", // https://fxbug.dev/287120797

                // TODO: https://fxbug.dev/297292100 - maybe we'll implement sched_rr_get_interval?
                "sched_rr_get_interval02", // https://fxbug.dev/297292100
                "sched_rr_get_interval03", // https://fxbug.dev/297292100

                // TODO: https://fxbug.dev/287114492 - maybe we'll implement sched_setattr?
                "sched_setattr01", // https://fxbug.dev/287114492
                "seccomp01",
                "send02",
                "setitimer01",
                "setitimer02",

                // TODO: https://fxbug.dev/287121196 - depends on PRIO_PGRP and PRIO_USER support.
                "setpriority01", // https://fxbug.dev/287121196
                "setrlimit03",
                "settimeofday01",
                "settimeofday02",
                "setxattr03",
                "splice07",
                "sockioctl01",
                "statx04",
                "statx06",
                "statx11",

                // This test fails because we do not limit the amount of swap files according to the
                // size mount flag.
                "sync01",
                "time-schedule01",

                // Depends on real contents in /proc/sys/kernel/perf_event_mlock_kb
                "cve-2015-3290",

                // Needs working sched_getcpu()
                "perf_event_open02",

                // https://fxbug.dev/42078242
                "times03",
                "umount2_01",
                "umount2_02",

                // These tests fail when an init is run in the container to set up /apex.
                // TODO(https://fxbug.dev/42080241) re-enable these tests
                "mmapstress04",

                // TODO(https://fxbug.dev/349188105) these need CLOCK_{PROCESS,THREAD}_CPUTIME_ID
                "timer_create01",
                "timer_delete01",
                "timer_settime02",

                // TODO(https://fxbug.dev/374802310)
                "inotify03",

                // TODO(https://fxbug.dev/377877724)
                "getsockopt01",
                "mlock05",

                // Requires FS_APPEND_FL and FS_IMMUTABLE_FL
                // We can implement these for tmpfs, but getting them to persist in fxfs is
                // non-trivial.
                "unlink09",

                // TODO(https://fxbug.dev/399387742): fix invocation path and re-enable
                "vma05",

                // TODO(https://fxbug.dev/297431387): Require more io_uring feature
                "cve-2020-29373",

                // TODO(https://fxbug.dev/496317235): Upstream LTP roll, require investigation
                "clone11",
                "clone304",
                "file_attr05",
                "name_to_handle_at03",
            ],
        },
        {
            type: "skip",
            matchers: [
                // Flaky tests.
                "cve-2017-17052",
                "io_pgetevents01",
                "ptrace06",
                "recvmsg01",
                "rename14",

                // TODO(https://fxbug.dev/534918239): This test intentionally exhausts disk space to
                // verify fallocate behavior under that condition. Intentionally exhausting space in
                // Starnix causes an OOM and subsequent crash of the test environment.
                "fallocate05",

                // These tests hang
                "fork14",

                // TODO(https://fxbug.dev/322874889) requires a working sched_setaffinity
                "getcpu01",

                // Makes all following tests to fail.
                "kill10",

                // Times out.
                "cve-2017-10661",

                // These tests are time-consuming, so they often cause timeouts in the
                // corresponding suites. Consider moving them to separate bundles.
                "cve-2011-0999",
                "cve-2014-0196",
                "cve-2016-7117",
                "fs_fill",
                "fs_inod01",
                "hackbench01",
                "hackbench02",
                "linker01",
                "mtest06",
                "nanosleep01",

                // Test sometimes timeout instead of failing
                "starvation",

                // TODO(https://fxbug.dev/328694820) Re-enable once flake is resolved.
                "ptrace01",

                // TODO(https://fxbug.dev/353535860) deflake and enable
                "pidfd_open03",

                // TODO(https://fxbug.dev/) fix upstream test and enable
                "mmap04",

                // TODO(https://fxbug.dev/374984756) Crashes the kernel in debug builds
                // (cycle in mutex deps).
                "inotify08",

                // TODO(https://fxbug.dev/403612570): This test requires CLONE_INTO_CGROUP.
                "clone303",

                // TODO(https://fxbug.dev/390870202): Re-enable once flake is resolved.
                "clock_nanosleep02",

                // TODO(https://fxbug.dev/395053835): Re-enable once flake is resolved.
                "setrlimit01",

                // TODO(https://fxbug.dev/442531248): Seems premised on getting the scheduling of
                // a process that may be alive or may be a zombie; since we don't (yet?) support
                // the latter, this flakes.
                "sched_setscheduler04",

                // TODO(https://fxbug.dev/287114514)
                "userfaultfd01",
                "userfaultfd02",
                "userfaultfd03",
                "userfaultfd04",
                "userfaultfd05",

                // Flaking, see b/457451482.
                "fork06",

                // Times out, see b/457525944
                "epoll01",

                // TODO(https://fxbug.dev/465929299): Requires __NR_file_[getattr|setattr].
                "file_attr01",
                "file_attr02",
                "file_attr03",
                "file_attr04",

                // TODO(https://fxbug.dev/465929750): Requires CONFIG_AF_UNIX_OOB.
                "cve-2025-38236",

                // Temporarily skipping until a roll containing these tests is available.
                "cve.cve-2025-21756",
                "ioctl10",
                "ioctl_pidfd01",
                "ioctl_pidfd02",
                "ioctl_pidfd03",
                "ioctl_pidfd04",
                "ioctl_pidfd05",
                "ioctl_pidfd06",
                "landlock09",
                "landlock10",
                "listxattr04",
                "lsm_get_self_attr01",
                "lsm_get_self_attr02",
                "lsm_get_self_attr03",
                "lsm_list_modules01",
                "lsm_list_modules02",
                "lsm_set_self_attr01",
                "mount04",
                "mount08",
                "mount_setattr02",
                "munmap04",
                "set_thread_area02",
                "statmount09",
                "unshare05",

                // TODO(https://fxbug.dev/496317235): Temporarily skip since
                // this fails with the currently rolled LTP and will pass with
                // the next. We don't have a better way to indicate "pass or
                // fail, but don't crash" in the expectation system.
                "swapon03",
            ],
        },
    ],
}
