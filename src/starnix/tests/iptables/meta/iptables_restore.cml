{
    include: [ "syslog/client.shard.cml" ],
    program: {
        runner: "starnix_container",
        binary: "data/xtables-legacy-multi",
        args: [ "iptables-restore" ],
        environ: [ "XTABLES_LOCKFILE=/tmp/xtables.lock" ],
        uid: "0",
    },
}
