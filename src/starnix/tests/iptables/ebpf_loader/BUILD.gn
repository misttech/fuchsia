import("//build/components.gni")
import("//src/starnix/build/starnix_linux_rustc_binary.gni")

starnix_linux_rustc_binary("ebpf_loader_bin") {
  testonly = true
  edition = "2024"
  output_name = "ebpf_loader"
  source_root = "ebpf_loader.rs"
  sources = [ source_root ]
  deps = [
    "//src/starnix/lib/ebpf",
    "//src/starnix/lib/linux_uapi",
    "//third_party/rust_crates:libc",
    "//third_party/rust_crates:zerocopy",
  ]
}

fuchsia_component("ebpf_loader") {
  testonly = true
  manifest = "meta/ebpf_loader.cml"
  deps = [ ":ebpf_loader_bin" ]
}
