import("//build/components.gni")
import("//build/rust/rustc_test.gni")
import("//src/starnix/tests/starnix_test_subpackages.gni")

resource("iptables_binary") {
  sources = [ "//prebuilt/third_party/3pp/iptables/linux-${current_cpu}/bin/xtables-legacy-multi" ]
  outputs = "data/{{source_file_part}}"
}

fuchsia_test_component("iptables_restore") {
  manifest = "meta/iptables_restore.cml"
  test_type = "starnix"
  deps = [ ":iptables_binary" ]
}

fuchsia_test_component("ip6tables_restore") {
  manifest = "meta/ip6tables_restore.cml"
  test_type = "starnix"
  deps = [ ":iptables_binary" ]
}

fuchsia_test_component("iptables_test") {
  manifest = "meta/iptables_test.cml"
  test_type = "starnix"
  deps = [ "//src/connectivity/network/tests/iptables:iptables_test" ]
}

fuchsia_test_component("realm") {
  manifest = "meta/realm.cml"
}

fuchsia_test_package("iptables_tests") {
  test_components = [ ":iptables_test" ]

  subpackages = starnix_test_subpackages +
                [ "//src/starnix/containers/debian:debian_package" ]

  deps = [
    ":ip6tables_restore",
    ":iptables_restore",
    ":realm",
  ]

  test_specs = {
    # TODO(https://fxbug.dev/354754795): remove this when the starnix kernel no
    # longer panics during this test.
    log_settings = {
      max_severity = "ERROR"
    }
  }
}

group("tests") {
  testonly = true
  deps = []

  # We don't have `iptables` prebuilt for RISC-V.
  if (target_cpu != "riscv64") {
    deps += [ ":iptables_tests" ]
  }
}
