{
    actions: [
        {
            type: "expect_pass",
            matchers: [
                "*",
            ],
        },
        {
            type: "skip",
            matchers: [
                // TODO(https://fxbug.dev/445433238): Connect syscall to a vsock not supported.
                "socket_spec.socket_spec_listen_connect_vsock_success",
            ],
        },
    ],
}
