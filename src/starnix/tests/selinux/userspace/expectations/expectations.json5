{
    actions: [
        {
            type: "expect_pass",
            matchers: [
                "*",
            ],
        },
        {
            type: "expect_failure",
            matchers: [
                // TODO: https://fxbug.dev/514584319 - Fails on Starnix because it succeeds instead
                // of returning EINVAL.
                "BpfFcntlLockTestSuite/BpfFcntlLockTest.DoesNotRequireFileLock/SETLEASE",

                // TODO: https://fxbug.dev/422968534 - Make (SE)Starnix match the (SE)Linux behavior
                // regarding opening binder.
                "BinderTest/CallPermission.DoCall/0",
                "BinderTest/CallPermission.DoCall/1",

                // TODO(https://fxbug.dev/398654361)
                "BinderTest/ManagerProviderClientTest/0.SameOperationsAsSELinuxTestSuiteBinderTestSubTestOne",

                // TODO: https://fxbug.dev/322843830 - Make (SE)Starnix match the (SE)Linux behavior
                // demonstrated in this test.
                "InheritTest.ExecutableFdRemappedToNull",

                // TODO: https://fxbug.dev/492550768 - Apply filesystem { relabelfrom relabelto }
                // checks when mounting with fscontext= or context=.
                "MountTest.FsContextRequiresRelabelFromAndTo",

                // TODO: https://fxbug.dev/334094811 - Reject SELinux mount options before a
                // policy is loaded.
                "MountTests/MountOptionValidationTest.RejectedBeforePolicyLoad/*",

                // TODO: https://fxbug.dev/334094811 - Return EINVAL when mounting with an
                // invalid Security Context.
                "MountTests/MountOptionValidationTest.RejectedWhenInvalid/*",

                // TODO: https://fxbug.dev/409256444 - Make (SE)Starnix match the (SE)Linux behavior
                // demonstrated in this test.
                "MProtectExecmod/MProtectExecmod.ExecMod/ExecmodYes_PrivateMapping_Modification_MprotectSuccess",
                "MProtectExecmod/MProtectExecmod.ExecMod/ExecmodNo_SharedMapping_Modification_MprotectSuccess",
                "MProtectExecmod/MProtectExecmod.ExecMod/ExecmodNo_PrivateMapping_NoModification_MprotectSuccess",

                // TODO: https://fxbug.dev/501038871 - Make (SE)Starnix match the (SE)Linux behavior
                // regarding perf_event_open with invalid tracepoint ID.
                "PerfEventTest.InvalidTracepointIdAndNoPermission",

                // TODO: https://fxbug.dev/297440106 - Fix zombies to remain in "/proc/<pid>" with correct labels.
                "ProcAttrTest.ZombieProcPid",
                "ProcAttrTest.ZombieCurrentAttr",

                // TODO: https://fxbug.dev/361552580 - Fix SELinuxFS API handling of unknown policy class Ids.
                "SeLinuxFsCreate.InvalidComputeCreateClassId",
                "SeLinuxFsAccess.UnknownClassIdIsAccepted",

                // TODO: https://fxbug.dev/361552580 - Fix SELinuxFS API validation of fields.
                "SeLinuxFsAccess.ClassIdMayHaveTrailingNonNumericData",
                "SeLinuxFsAccess.FourthArgumentIsNotValidated",

                // TODO: https://fxbug.dev/455799917 - Fix test setup for Starnix to match Linux.
                "UnlabeledFsTest.CreateFileInUnlabeledFs",

                // TODO: https://fxbug.dev/509488263 - Make (SE)Starnix match the (SE)Linux behavior
                // demonstrated in this test.
                "BpfMapCreateTestSuite/BpfMapCreateTest.Create/0",

                // TODO: https://fxbug.dev/514690213 - Make Starnix check SELinux capability permissions.
                "PtraceTest.PtraceAttachDeniedWithoutSelinuxCapSysPtrace",
            ],
        },
        {
            type: "skip",
            matchers: [
                // TODO: https://fxbug.dev/451606455 - Wait on `PTRACE_ATTACH` to finish.
                "PtraceTest.PtraceAttachAllowed",
                "PtraceTest.PtraceAttachThenExecDenied",
                "PtraceTest.PtraceAttachThenExecAllowed",
            ],
        },
    ],
}
