{
    include: [ "//src/starnix/containers/container.shard.cml" ],
    program: {
        runner: "starnix",
        features: [
            "container",
            "rootfs_rw",
            "selinux",
            "selinux_test_suite",
        ],
        init: [],
        kernel_cmdline: "audit=1 audit_backlog_limit=0",
        mounts: [ "/:remote_pkg_subdir::nosuid,nodev,relatime" ],
        name: "sestarnix_userspace_test_container",
        startup_file_path: "",
        default_uid: "0",
        default_seclabel: "#kernel",
        default_ns_mount_options: [
            "#container:context=system_u:object_r:test_pkg_file_t:s0",
            "#component_tmpfs:context=system_u:object_r:unconfined_t:s0",
            "/data:context=system_u:object_r:unconfined_t:s0",
            "/pkg:context=system_u:object_r:test_pkg_file_t:s0",
            "/test_data:context=system_u:object_r:unconfined_t:s0",
        ],
    },
}
