  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/audit_access_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/binder_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/bpf_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/capabilities_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/fcntl_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/file_transition_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/genfscon_create_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/inherit_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/io_uring_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/ioctl_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/memfd_class_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/memfd_transition_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/minimal_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/mount_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/mprotect_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/netlink_audit_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/netlink_xperms_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/open_perms_policy",
