  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/userspace_initial_context_policy",
  "//src/starnix/lib/selinux/testdata/composite_policies/compiled/xattr_access_policy",
]

resource("policies") {
  sources = policy_files
  outputs = "data/policies/{{source_file_part}}"
}

# Merge the audit expectations with skipped and expected failures.
json_merge("audit_expectations.json") {
  sources = [
    "expectations/audit_failure.json",
    "expectations/audit_skip.json",
    "expectations/audit_success.json",
  ]
  minify = true
  relaxed_input = true
}

# Audit expectations to be checked.
resource("audit_expectations") {
  deps = [ ":audit_expectations.json" ]

  sources = [ "$target_out_dir/audit_expectations.json" ]
  outputs = "data/audit_expectations/{{source_file_part}}"
}

test_subprograms = []
test_resources = []
foreach(executable_name, test_subprogram_names) {
  test_subprograms += [ ":${executable_name}" ]
  executable("${executable_name}") {
    testonly = true

    # TODO: https://fxbug.dev/297293167 - enable ASan instrumentation for Linux binaries in Starnix
    exclude_toolchain_tags = [ "instrumented" ]
    sources = [
      "tests/test_subprograms/${executable_name}.cc",
      "util.cc",
      "util.h",
    ]
    deps = [
      "//sdk/lib/fit",
      "//src/lib/files",
      "//src/starnix/tests/syscalls/cpp:test_utils",
      "//third_party/googletest:gmock",
      "//third_party/googletest:gtest",
    ]
    output_name = "${executable_name}_bin"
    configs += [ ":rpath_config" ]
  }

  test_resources += [ ":${executable_name}_bin" ]

  resource("${executable_name}_bin") {
    testonly = true
    out_dir = get_label_info(":${executable_name}($target_linux_toolchain)",
                             "root_out_dir")
    deps = [ ":${executable_name}($target_linux_toolchain)" ]
    sources = [ "${out_dir}/${executable_name}_bin" ]
    outputs = "data/bin/${executable_name}_bin"
  }
}

copy("expectations") {
  sources = [ "expectations/expectations.json5" ]
  outputs = [ "${target_gen_dir}/{{source_file_part}}" ]
}

test_component_targets = []
foreach(test_name, test_names) {
  test_component_targets += [ ":${test_name}" ]

  executable("${test_name}_bin") {
    testonly = true
    sources = [ "tests/${test_name}.cc" ]
    deps = [
      ":userspace_test_main",
      "//sdk/lib/fit",
      "//src/lib/files",
      "//src/lib/fxl",
      "//src/starnix/tests/syscalls/cpp:test_utils",
      "//third_party/googletest:gtest",
      "//zircon/system/ulib/fbl",
    ]
    configs += [ ":rpath_config" ]

    # LeakSanitizer fails on the test binaries from trying to clone with
    # CLONE_UNTRACED.
    exclude_toolchain_tags = [ "lsan" ]
  }

  generated_file("${test_name}.cml") {
    outputs = [ "${target_gen_dir}/${test_name}.cml" ]
    output_conversion = "json"

    contents = {
      include = [ "//src/starnix/tests/selinux/userspace/meta/sestarnix_userspace_test.shard.cml" ]
      program = {
        binary = "data/tests/${test_name}_bin"
      }
    }
  }

  starnix_linux_test_component("${test_name}") {
    test_label = ":${test_name}_bin"
    test_binary = "${test_name}_bin"
    test_type = "starnix"
    deps = [
      ":${test_name}.cml",
      ":audit_expectations",
      ":expectations",
      ":policies",
    ]
    manifest = "${target_gen_dir}/${test_name}.cml"
    uses_expectations = true
    generated_expectations = ":expectations"
  }
}

fuchsia_test_package("sestarnix_userspace_tests") {
  test_components = test_component_targets
  subpackages =
      starnix_test_subpackages + [ ":sestarnix_userspace_test_container" ]
  deps = test_resources
}

group("tests") {
  testonly = true
  deps = [ ":sestarnix_userspace_tests" ]
  if (host_os == "linux" && host_cpu == "x64" &&
      enable_sestarnix_userspace_tests_on_linux) {
    deps += [ ":sestarnix_userspace_tests_on_linux($host_toolchain)" ]
  }
}

if (is_host) {
  host_test_data("qemu") {
    sources = [
      "//prebuilt/third_party/qemu/linux-x64/bin/qemu-system-x86_64",
      "//prebuilt/third_party/qemu/linux-x64/share/qemu/bios-256k.bin",
      "//prebuilt/third_party/qemu/linux-x64/share/qemu/efi-e1000.rom",
      "//prebuilt/third_party/qemu/linux-x64/share/qemu/kvmvapic.bin",
      "//prebuilt/third_party/qemu/linux-x64/share/qemu/linuxboot_dma.bin",
    ]
    outputs = [ "$target_out_dir/qemu/{{source_file_part}}" ]
  }

  host_test_data("policies_host") {
    sources = policy_files
    outputs = [ "$target_out_dir/policies/{{source_file_part}}" ]
  }

  host_test_data("audit_expectations_host") {
    deps = [ ":audit_expectations.json" ]
    sources = [ "$target_out_dir/audit_expectations.json" ]
    outputs = [ "$target_out_dir/audit_expectations/{{source_file_part}}" ]
  }

  host_test_data("expectations_host") {
    sources = [ "expectations/expectations.json5" ]
    outputs = [ "$target_out_dir/expectations/{{source_file_part}}" ]
  }

  host_test_data("gki_prebuilt") {
    sources = [
      "//prebuilt/starnix/internal/gki/x86_64/bzImage",
      "//prebuilt/starnix/internal/gki/x86_64/virtio_console.ko",
      "//prebuilt/starnix/internal/gki/x86_64/virtio_pci.ko",
      "//prebuilt/starnix/internal/gki/x86_64/virtio_pci_legacy_dev.ko",
      "//prebuilt/starnix/internal/gki/x86_64/virtio_pci_modern_dev.ko",
    ]
    outputs = [ "$target_out_dir/gki/{{source_file_part}}" ]
  }

  host_test_data("init_for_linux_host") {
    out_dir = get_label_info(":init_for_linux($target_linux_toolchain)",
                             "root_out_dir")
    deps = [ ":init_for_linux($target_linux_toolchain)" ]
    sources = [ "${out_dir}/init_for_linux" ]
    outputs = [ "$target_out_dir/linux_x64/init_for_linux" ]
  }

  action_foreach("libs_copy") {
    script = "//build/toolchain/copy.py"
    sources = []
    foreach(lib, host_lib_names) {
      sources += [ sysroot_libs + "/$lib" ]
    }
    outputs = [ "$target_gen_dir/libs/{{source_file_part}}" ]
    args = [
      "{{source}}",
      rebase_path(target_gen_dir + "/libs/{{source_file_part}}",
                  root_build_dir),
    ]
  }

  host_test_data("libs_host") {
    deps = [ ":libs_copy" ]
    sources = []
    foreach(lib, host_lib_names) {
      sources += [ "$target_gen_dir/libs/$lib" ]
    }
    outputs = [ "$target_out_dir/libs/{{source_file_part}}" ]
  }

  generated_file("test_list") {
    outputs = [ "$target_gen_dir/test_list.json" ]
    output_conversion = "json"
    contents = test_names
  }

  host_test_data("test_list_data") {
    sources = [ "$target_gen_dir/test_list.json" ]
    outputs = [ "$target_out_dir/test_list.json" ]
    deps = [ ":test_list" ]
  }

  generated_file("files_map") {
    testonly = true
    outputs = [ "$target_gen_dir/files_map.json" ]
    output_conversion = "json"
    data_keys = [ "distribution_entries" ]
    deps = [ ":sestarnix_userspace_tests" ]
  }

  host_test_data("files_map_data") {
    sources = [ "$target_gen_dir/files_map.json" ]
    outputs = [ "$target_out_dir/files_map.json" ]
    deps = [ ":files_map" ]
  }

  host_test_data_targets = []
  foreach(name, test_subprogram_names) {
    target_name = "${name}_host"
    host_test_data_targets += [ ":$target_name" ]
    host_test_data(target_name) {
      testonly = true
      out_dir =
          get_label_info(":${name}($target_linux_toolchain)", "root_out_dir")
      deps = [ ":${name}($target_linux_toolchain)" ]
      sources = [ "${out_dir}/${name}_bin" ]
      outputs = [ "$target_out_dir/linux_x64/${name}_bin" ]
    }
  }
  foreach(name, test_names) {
    target_name = "${name}_bin_host"
    host_test_data_targets += [ ":$target_name" ]
    host_test_data(target_name) {
      testonly = true
      out_dir = get_label_info(":${name}_bin($target_linux_toolchain)",
                               "root_out_dir")
      deps = [ ":${name}_bin($target_linux_toolchain)" ]
      sources = [ "${out_dir}/${name}_bin" ]
      outputs = [ "$target_out_dir/linux_x64/${name}_bin" ]
    }
  }

  python_host_test("sestarnix_userspace_tests_on_linux") {
    main_source = "run_on_linux.py"
    deps = [ ":sestarnix_userspace_tests" ]
    test_data_deps = [
                       ":audit_expectations_host",
                       ":expectations_host",
                       ":files_map_data",
                       ":gki_prebuilt",
                       ":init_for_linux_host",
                       ":libs_host",
                       ":policies_host",
                       ":qemu",
                       ":test_list_data",
                     ] + host_test_data_targets
  }
}
