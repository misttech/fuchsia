  "append",
  "audit_access",
  "binder",
  "bpf",
  "capabilities",
  "fcntl",
  "genfscon_create",
  "inherit",
  "io_uring",
  "ioctl",
  "load_policy",
  "memfd",
  "memfd_class",
  "mount",
  "mprotect",
  "netlink_audit",
  "netlink_xperms",
  "open_perms",
  "overlayfs",
  "perf_event",
  "pipe",
  "procattr",
  "ptrace",
  "selinuxfs",
  "socket",
  "sys_power",
  "syslog",
  "timerslack",
  "tun_tap",
  "unlabeled_fs",
  "userspace_initial_context",
  "xattr_access",

  # keep-sorted end
]

# List of subprograms launched by tests.
test_subprogram_names = [
  # keep-sorted start
  "fuse_memfs",
  "has_blocked_signals",
  "has_ignored_signals",
  "has_pending_signals",
  "is_at_secure_set",
  "is_current_domain",
  "is_duplicated_fd",
  "is_fd_valid",
  "is_itimer_real_reset",
  "is_selinux_null_inode",
  "is_soft_rlimit_reset",
  "ptrace_traceme",
  "stop",
  "true",

  # keep-sorted end
]

# Policies made available to the tests.
