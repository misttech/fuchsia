import("//build/components.gni")
import("//build/rust/rustc_binary.gni")
import("//build/testing/perf/test.gni")

group("benchmarks") {
  testonly = true
  deps = [
    ":selinux_bench",
    ":sestarnix_memory_bench",
  ]
}

rustc_binary("bin") {
  output_name = "selinux_bench"
  edition = "2024"
  testonly = true

  source_root = "src/main.rs"
  sources = [ "src/main.rs" ]

  # Disable LTO to keep compile/link times fast when linking starnix_core, and
  # to prevent cross-crate optimizations from skewing the microbenchmark
  # measurements.
  _lto_config = [ "//build/config/lto" ]
  _thinlto_config = [ "//build/config/lto:thinlto" ]
  if (configs + _lto_config - _lto_config != configs) {
    configs -= _lto_config
  }
  if (configs + _thinlto_config - _thinlto_config != configs) {
    configs -= _thinlto_config
  }

  deps = [
    "//src/developer/fuchsia-criterion",
    "//src/lib/fuchsia-async",
    "//src/starnix/kernel/core",
    "//src/starnix/lib/selinux",
    "//src/starnix/lib/starnix_uapi",
    "//third_party/rust_crates:criterion",
  ]

  inputs = [ "//src/starnix/lib/selinux/testdata/policies/aosp_sepolicy" ]

  configs += [ "//src/starnix/build:kernel_library_config" ]
}

fuchsia_component("selinux_bench_component") {
  testonly = true
  component_name = "selinux_bench"
  manifest = "meta/selinux_bench.cml"
  deps = [ ":bin" ]
}

fuchsia_package("selinux_bench_pkg") {
  testonly = true
  deps = [ ":selinux_bench_component" ]
}

fuchsia_component_perf_test("selinux_bench") {
  package = ":selinux_bench_pkg"
  component_name = "selinux_bench"
  test_type = "starnix"
  expected_metric_names_filepath =
      "//src/tests/end_to_end/perf/expected_metric_names/fuchsia.sestarnix.txt"
}

rustc_binary("memory_bench_bin") {
  output_name = "sestarnix_memory_bench"
  edition = "2024"
  testonly = true

  source_root = "src/memory_bench.rs"
  sources = [ "src/memory_bench.rs" ]

  deps = [
    "//src/performance/lib/fuchsiaperf",
    "//src/starnix/lib/selinux",
    "//third_party/rust_crates:serde_json",
  ]

  inputs = [ "//src/starnix/lib/selinux/testdata/policies/aosp_sepolicy" ]
}

fuchsia_component("sestarnix_memory_bench_component") {
  testonly = true
  component_name = "sestarnix_memory_bench"
  manifest = "meta/sestarnix_memory_bench.cml"
  deps = [ ":memory_bench_bin" ]
}

fuchsia_package("sestarnix_memory_bench_pkg") {
  testonly = true
  deps = [ ":sestarnix_memory_bench_component" ]
}

fuchsia_component_perf_test("sestarnix_memory_bench") {
  package = ":sestarnix_memory_bench_pkg"
  component_name = "sestarnix_memory_bench"
  test_type = "starnix"
  expected_metric_names_filepath = "//src/tests/end_to_end/perf/expected_metric_names/fuchsia.sestarnix_memory.txt"
}
