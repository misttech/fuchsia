{
    actions: [
        {
            type: "expect_pass",
            matchers: [
                "*",
            ],
        },
        {
            type: "expect_failure",
            matchers: [
                // keep-sorted start
                "binder", // TODO: https://fxbug.dev/398654361
                "bounds", // TODO: https://fxbug.dev/398652722
                "capable_file", // TODO: https://fxbug.dev/398652723
                "cgroupfs_label", // TODO: https://fxbug.dev/398662840
                "checkreqprot", // TODO: https://fxbug.dev/398662842
                "extended_socket_class", // TODO: https://fxbug.dev/398699131
                "file", // TODO: https://fxbug.dev/398696731
                "filesystem", // TODO: https://fxbug.dev/398699133
                "fs_filesystem", // TODO: https://fxbug.dev/398696732
                "glblub", // TODO: https://fxbug.dev/398699134
                "inet_socket/tcp", // TODO: https://fxbug.dev/398663317
                "inet_socket/udp", // TODO: https://fxbug.dev/398663317
                "ioctl", // TODO: https://fxbug.dev/398663318
                "key_socket", // TODO: https://fxbug.dev/398696734
                "keys", // TODO: https://fxbug.dev/398699136
                "mac_admin", // TODO: https://fxbug.dev/398698176
                "memfd", // TODO: https://fxbug.dev/448793897
                "mmap", // TODO: https://fxbug.dev/398707795
                "msg", // TODO: https://fxbug.dev/398663319
                "nlmsg", // TODO: https://fxbug.dev/448793080
                "nnp_nosuid", // TODO: https://fxbug.dev/398696737
                "notify", // TODO: https://fxbug.dev/398696738
                "overlay", // TODO: https://fxbug.dev/398696739
                "perf_event", // TODO: https://fxbug.dev/398663320
                "sem", // TODO: https://fxbug.dev/398696740
                "shm", // TODO: https://fxbug.dev/398696741
                "sysctl", // TODO: https://fxbug.dev/398696742
                "tun_tap", // TODO: https://fxbug.dev/398663323
                "userfaultfd", // TODO: https://fxbug.dev/398707804
                "watchkey", // TODO: https://fxbug.dev/398711590

                // keep-sorted end
            ],
        },
        {
            type: "skip",
            matchers: [
                // TODO: https://fxbug.dev/319480589 - Starnix does not support dynamic kernel module loading.
                "module_load",
            ],
        },
    ],
}
