import("//build/components.gni")
import("//build/rust/rustc_binary.gni")
import("//src/starnix/build/starnix_linux_rustc_binary.gni")
import("//src/starnix/kernel/starnix.gni")

group("tests") {
  testonly = true
  deps = [ ":starnix_thermal_module_test" ]
}

rustc_binary("bin") {
  testonly = true
  edition = "2024"
  output_name = "starnix_thermal_module_test"

  deps = [
    "//sdk/fidl/fuchsia.power.battery:fuchsia.power.battery_rust",
    "//sdk/fidl/fuchsia.power.cpu:fuchsia.power.cpu_rust",
    "//sdk/fidl/fuchsia.thermal:fuchsia.thermal_rust",
    "//src/lib/fuchsia",
    "//src/lib/fuchsia-component",
    "//src/lib/fuchsia-component-test",
    "//src/sys/lib/component-events",
    "//third_party/rust_crates:anyhow",
    "//third_party/rust_crates:futures",
    "//third_party/rust_crates:log",
  ]
  sources = [
    "src/fake_battery.rs",
    "src/main.rs",
  ]
}

fuchsia_test_component("integration_test") {
  manifest = "meta/integration_test.cml"
  deps = [ ":bin" ]
  test_type = "starnix"
}

starnix_linux_rustc_binary("thermal_client_bin") {
  testonly = true
  edition = 2021
  source_root = "src/thermal_client.rs"
  sources = [ "src/thermal_client.rs" ]
  deps = [
    "//src/starnix/lib/linux_uapi",
    "//src/starnix/lib/third_party/rust_netlink/netlink_packet_core",
    "//src/starnix/lib/third_party/rust_netlink/netlink_packet_generic",
    "//src/starnix/modules/thermal:thermal-netlink",
    "//third_party/rust_crates:assert_matches",
    "//third_party/rust_crates:libc",
    "//third_party/rust_crates:nix",
  ]
}

fuchsia_component("container_with_thermal_client") {
  testonly = true
  manifest = "meta/container_with_thermal_client.cml"
}

fuchsia_component("thermal_client") {
  testonly = true
  manifest = "meta/thermal_client.cml"
  deps = [ ":thermal_client_bin" ]
}

fuchsia_component("thermal_container") {
  testonly = true
  manifest = "meta/thermal_container.cml"
}

fuchsia_package("thermal_container_pkg") {
  testonly = true
  deps = [
    ":thermal_container",
    "//src/starnix/containers/debian:container_resources",
  ]
}

fuchsia_test_package("starnix_thermal_module_test") {
  test_components = [ ":integration_test" ]
  deps = [
    ":container_with_thermal_client",
    ":thermal_client",
    ":thermal_container",
    "//src/starnix/containers/debian:container_resources",
  ]
  subpackages = [
    "//src/starnix/kernel:starnix_kernel_package",
    "//src/power/testing/fake-domain-controller:package",
    "//src/power/testing/fake-thermal-sensor-manager:package",
  ]
}
