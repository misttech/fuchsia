import("//build/components.gni")
import("//build/rust/rustc_test.gni")

rustc_test("starnix_core_unit_tests_bin") {
  edition = "2021"

  # TODO(https://fxbug.dev/42059075): Re-enable starnix in these environments.
  exclude_toolchain_tags = [
    "asan",
    "hwasan",
  ]

  sources = [
    "src/device/mod.rs",
    "src/device/remote_block_device.rs",
    "src/lib.rs",
  ]

  deps = [
    "//src/lib/fuchsia",
    "//src/starnix/kernel:starnix_core",
    "//src/starnix/lib/starnix_uapi",
    "//third_party/rust_crates:zerocopy",
  ]
}

fuchsia_unittest_package("starnix_core_unit_tests") {
  manifest = "meta/starnix_core_unit_tests.cml"
  deps = [ ":starnix_core_unit_tests_bin" ]
  test_type = "starnix"
}

group("tests") {
  testonly = true
  deps = [ ":starnix_core_unit_tests" ]
}
