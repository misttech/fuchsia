        {
            type: "expect_failure",
            matchers: [
                // affinity_test
                "AffinityTest.LargeCpuMask",
                "AffinityTest.NewThread",
                "AffinityTest.Sanity",

                // cgroup_test
                "CPUAcctCgroup.CPUAcctStat",
                "CPUAcctCgroup.CPUAcctUsage",
                "CPUAcctCgroup.HierarchicalAccounting",
                "CPUAcctCgroup.IndirectCharge",
                "CPUAcctCgroup.NoDoubleAccounting",
