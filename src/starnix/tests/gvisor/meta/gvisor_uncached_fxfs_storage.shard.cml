{
    program: {
        environ: [
            "TEST_TMPDIR={component_path}/data",
            "TEST_ON_GVISOR=starnix",
            "TEST_SRCDIR={pkg_path}/data/tests",
            "BENCHMARK_FORMAT=json",
            "BENCHMARK_OUT={component_path}/test_data/benchmark.json",
        ],
    },
    children: [
        {
            name: "uncached_config",
            url: "#meta/uncached_config.cm",
        },
        {
            name: "test-fxfs",
            url: "test-fxfs#meta/test-fxfs.cm",
        },
    ],
    use: [
        {
            directory: "data",
            from: "#test-fxfs",
            rights: [ "rw*" ],
            path: "/data",
        },
    ],
    offer: [
        {
            protocol: "fuchsia.fshost.StarnixVolumeProvider",
            from: "#test-fxfs",
            to: [ "#container" ],
        },
        {
            config: "fuchsia.test.fxfs.DirentCacheSize",
            from: "#uncached_config",
            to: [ "#test-fxfs" ],
        },
    ],
}
