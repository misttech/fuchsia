{
    include: [
        "//src/lib/testing/expectation/meta/client.shard.cml",
        "//src/starnix/tests/starnix_test_common.shard.cml",
        "//src/storage/fxfs/test-fxfs/meta/test-fxfs.shard.cml",
    ],
    program: {
        test_type: "gunit",
    },
    children: [
        {
            name: "uncached_config",
            url: "#meta/uncached_config.cm",
        },
    ],
    offer: [
        {
            storage: "data",
            from: "self",
            to: [ "#container" ],
        },
        {
            protocol: "fuchsia.fshost.StarnixVolumeProvider",
            from: "#test-fxfs",
            to: [ "#container" ],
        },
        {
            config: "fuchsia.test.fxfs.DirentCacheSize",
            from: "#uncached_config",
            to: [ "#test-fxfs" ],
        },
    ],
}
