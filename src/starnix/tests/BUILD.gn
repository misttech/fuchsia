import("//build/components.gni")
import("//build/testing/environments.gni")
import("//src/starnix/tests/build/starnix_host_test_component.gni")
import("//src/starnix/tests/build/starnix_linux_test_component.gni")
import("//src/starnix/tests/starnix_test_subpackages.gni")
import("//tools/cmc/build/expect_includes.gni")

group("tests") {
  testonly = true

  deps = [
    "alpine:tests",
    "consent_sync:tests",
    "crash_reports:tests",
    "diagnostics:tests",
    "fp_stack_glue:tests",
    "gvisor:tests",
    "iptables:tests",
    "memory_attribution:tests",
    "nanohub:tests",
    "perf_event_open:tests",
    "psi:tests",
    "qipcrtr:tests",
    "reboot:tests",
    "remotevol:tests",
    "scheduler:tests",
    "selinux/userspace:tests",
    "shutdown:tests",
    "suspend:tests",
    "syscalls:tests",
    "sysrq:tests",
    "thermal:tests",
  ]

  if (target_cpu == "riscv64") {
    # TODO(b/297312145): Enable all tests on RISC-V.
    deps -= [ "gvisor:tests" ]
  }

  # TODO(https://fxbug.dev/42067974): Remove !is_asan check when Starnix can run binaries built for
  # ASAN.
  if (!is_asan) {
    if (target_cpu == "x64" && host_os == "linux" && host_cpu == "x64") {
      deps += [ ":starnix_user_tests" ]
    }

    deps += [
      ":starnix_kgsl_tests",
      ":starnix_magma_tests",
    ]

    if (target_cpu == "arm64") {
      deps += [ ":starnix_kgsl_tests_32" ]
    }
  }
}

group("benchmarks") {
  testonly = true
  deps = [
    "ebpf_bench:benchmarks",
    "gvisor:benchmarks",
    "kernel_core_bench:benchmarks",
    "selinux/bench:benchmarks",
  ]
}

# Top-level test group for Linux VM tests. Developers can target this group
# using --with to build and run the tests across a variety of Fuchsia products
# and configurations. Infra uses a layer of misdirection at
# //bundles/buildbot/virtualization to target these tests, so that we can
# isolate the product bundle and avoid unnecessary build and runtime bloat.
group("linux_vm_tests") {
  testonly = true
  deps = [
    "syscalls:linux_vm_tests",

    # This group of tests is not directly dependent on the
    # interactive_debian_guest_pkg, but pulling this dependency here ensures
    # that local developers have built the package, and have it available at
    # runtime for the repo server. Adding this dependency in the correct place
    # within the Starnix test runner would add blanket size bloat (+240 MB)
    # across infra.
    "//src/virtualization/lib/guest_interaction/interactive_guest:interactive_guest_pkg",
  ]
}

# Tests that use starnix_test_runner should depend on one of these.
expect_includes("starnix_test") {
  includes = [ "starnix_test.shard.cml" ]
}

expect_includes("starnix_test_with_expectations") {
  includes = [ "starnix_test_with_expectations.shard.cml" ]
}

expect_includes("starnix_benchmark") {
  includes = [ "starnix_benchmark.shard.cml" ]
}

if (host_os == "linux" && host_cpu == "x64") {
  starnix_host_test_component("fdio_test") {
    test_label = "//sdk/lib/fdio/tests:fdio-test"
    test_type = "starnix"
    test_binary = "fdio-test"
  }

  fuchsia_test_package("starnix_user_tests") {
    test_components = [ ":fdio_test" ]

    subpackages = starnix_test_subpackages +
                  [ "//src/starnix/containers/debian:debian_package" ]
    test_specs = {
      package_resolution_timeout_secs = 660
    }
  }
}

starnix_linux_test_component("kgsl_unit_tests_32") {
  test_label = "//src/graphics/magma/tests_linux/unit_tests:kgsl_unit_tests"
  test_type = "starnix"
  test_toolchain = target_linux_arch32_toolchain
  test_binary = "kgsl_unit_tests"
  manifest = "meta/kgsl_unit_tests.cml"
}

fuchsia_test_package("starnix_kgsl_tests_32") {
  test_components = [ ":kgsl_unit_tests_32" ]

  subpackages = starnix_test_subpackages + [
                  "//src/starnix/containers/debian:debian_package",
                  "//src/ui/testing/test_ui_stack:test-ui-stack",
                ]

  test_specs = {
    log_settings = {
      max_severity = "ERROR"
    }
    environments = [ sorrel_env ]

    package_resolution_timeout_secs = 660
  }
}

starnix_linux_test_component("kgsl_unit_tests") {
  test_label = "//src/graphics/magma/tests_linux/unit_tests:kgsl_unit_tests"
  test_type = "starnix"
}

fuchsia_test_package("starnix_kgsl_tests") {
  test_components = [ ":kgsl_unit_tests" ]

  subpackages = starnix_test_subpackages + [
                  "//src/starnix/containers/debian:debian_package",
                  "//src/ui/testing/test_ui_stack:test-ui-stack",
                ]

  test_specs = {
    log_settings = {
      max_severity = "ERROR"
    }
    environments = [ sorrel_env ]
    package_resolution_timeout_secs = 660
  }
}

starnix_linux_test_component("virtmagma_conformance_tests") {
  test_label =
      "//src/graphics/magma/tests/integration:virtmagma_conformance_tests"
  test_type = "starnix"
}

starnix_linux_test_component("virtmagma_sync_file_tests") {
  test_label =
      "//src/graphics/magma/tests/integration:virtmagma_sync_file_tests"
  test_type = "starnix"
}

starnix_linux_test_component("virtmagma_unit_tests") {
  test_label =
      "//src/graphics/magma/tests_linux/unit_tests:virtmagma_unit_tests"
  test_type = "starnix"
}

fuchsia_test_package("starnix_magma_tests") {
  test_components = [
    ":virtmagma_conformance_tests",
    ":virtmagma_unit_tests",
    ":virtmagma_sync_file_tests",
  ]

  subpackages = starnix_test_subpackages + [
                  "//src/starnix/containers/debian:debian_package",
                  "//src/ui/testing/test_ui_stack:test-ui-stack",
                ]

  test_specs = {
    log_settings = {
      max_severity = "ERROR"
    }
    environments = [
      atlas_env,
      nuc7_env,
      nuc11_env,
      sorrel_env,
      vim3_env,
    ]
    package_resolution_timeout_secs = 660
  }
}

# Used in hermetic Starnix tests to subpackage a netstack component.
# TODO(vickiecheng): Update starnix_test_common.shard.cml to launch netstack as
# a subpackaged child once every test includes this package.
fuchsia_package("netstack_package") {
  package_name = "netstack"
  testonly = true
  deps = [ "//src/connectivity/network/netstack3:component-dropin" ]
}
