import("//build/rust/rustc_library.gni")

rustc_library("wakeup_test") {
  name = "starnix-modules-wakeup-test"
  edition = "2024"
  sources = [
    "src/device.rs",
    "src/input.rs",
    "src/ioctl.rs",
    "src/lib.rs",
    "src/tracing.rs",
  ]
  deps = [
    "//sdk/fidl/fuchsia.input.report:fuchsia.input.report_rust",
    "//sdk/fidl/fuchsia.ui.test.input:fuchsia.ui.test.input_rust",
    "//sdk/rust/zx",
    "//src/lib/fidl/rust/fidl",
    "//src/lib/fuchsia-async",
    "//src/lib/fuchsia-component",
    "//src/lib/trace/rust:trace",
    "//src/starnix/kernel/core",
    "//src/starnix/lib/linux_uapi",
    "//src/starnix/lib/starnix_logging",
    "//src/starnix/lib/starnix_syscalls",
    "//src/starnix/lib/starnix_uapi",
    "//third_party/rust_crates:anyhow",
    "//third_party/rust_crates:zerocopy",
  ]
}
