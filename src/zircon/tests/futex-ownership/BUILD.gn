import("//build/components/fuchsia_unittest_package.gni")
import("//build/test.gni")
import("//build/testing/bootfs_test.gni")

group("tests") {
  testonly = true

  # Note: Tests specified using `bootfs_test` are included via
  # //products/bringup_with_tests and not this target.
  deps = [ ":futex-ownership-test" ]
}

test("futex-ownership") {
  configs += [ "//build/config:all_source" ]
  sources = [
    "bad-handle.cc",
    "ownership.cc",
    "utils.cc",
  ]
  deps = [
    "//sdk/lib/fdio",
    "//sdk/lib/stdcompat",
    "//src/zircon/lib/zircon",
    "//zircon/system/ulib/fbl",
    "//zircon/system/ulib/zx",
    "//zircon/system/ulib/zxtest",
  ]
}

fuchsia_unittest_package("futex-ownership-test") {
  deps = [ ":futex-ownership" ]
  manifest = "meta/futex-ownership-test.cml"
}

bootfs_test("futex-ownership-bootfs-test") {
  name = "futex-ownership"
  deps = [ ":futex-ownership" ]
}
