{
    include: [
        "//src/recovery/system/meta/shards/system_recovery.shard.cml",
        "//src/recovery/system/meta/shards/ui.shard.cml",
    ],
    program: {
        runner: "elf",
        binary: "bin/system_recovery_android",
        forward_stderr_to: "log",
        forward_stdout_to: "log",
    },
    children: [
        {
            name: "pkg-recovery",
            url: "#meta/pkg.cm",
        },
    ],
    capabilities: [
        {
            directory: "system-blob",
            rights: [ "r*" ],
            path: "/blob",
        },
        {
            directory: "system-blob-exec",
            rights: [
                "execute",
                "rw*",
            ],
            path: "/blob",
        },
        {
            protocol: [
                "fuchsia.fxfs.BlobCreator",
                "fuchsia.fxfs.BlobReader",
                "fuchsia.recovery.android.Updater",
            ],
        },
    ],
    use: [
        {
            protocol: [
                "fuchsia.hardware.power.statecontrol.Admin",
                "fuchsia.paver.Paver",
            ],
        },
        {
            protocol: [ "fuchsia.fshost.Recovery" ],
            availability: "optional",
        },
        {
            directory: "build-info",
            from: "parent",
            rights: [ "r*" ],
            path: "/config/build-info",
        },
        {
            protocol: "fuchsia.update.installer.Installer",
            from: "#pkg-recovery",
        },
        {
            protocol: "fuchsia.sys2.LifecycleController",
            from: "framework",
        },
    ],
    offer: [
        {
            directory: [
                "build-info",
                "config-data",
                "root-ssl-certificates",
            ],
            from: "parent",
            to: "#pkg-recovery",
        },
        {
            protocol: [
                "fuchsia.boot.Arguments",
                "fuchsia.net.http.Loader",
                "fuchsia.net.name.Lookup",
                "fuchsia.paver.Paver",
                "fuchsia.posix.socket.Provider",
            ],
            from: "parent",
            to: "#pkg-recovery",
        },
        {
            directory: "system-blob",
            from: "self",
            as: "blob",
            to: "#pkg-recovery",
            dependency: "weak",
        },
        {
            directory: "system-blob-exec",
            from: "self",
            as: "blob-exec",
            to: "#pkg-recovery",
            dependency: "weak",
        },
        {
            protocol: [
                "fuchsia.fxfs.BlobCreator",
                "fuchsia.fxfs.BlobReader",
            ],
            from: "self",
            to: "#pkg-recovery",
            dependency: "weak",
        },
    ],
    expose: [
        {
            protocol: "fuchsia.recovery.android.Updater",
            from: "self",
        },
    ],
}
