import("//build/python/python_host_test.gni")
import("//build/testing/environments.gni")
import("//build/testing/host_test_data.gni")
import("//build/zircon/tools.gni")

if (is_host) {
  python_host_test("memory_bootfs_size_test") {
    main_source = "memory_bootfs_size_test.py"
    libraries = [ "//build/python/tests/lib" ]
    extra_args = [
      "--zbi_tool",
      rebase_path(zbi_tool_path, root_build_dir),
      "--zbi_image",
      "fuchsia.zbi",
      "--far_tool",
      rebase_path(get_label_info("//src/sys/pkg/bin/far:host", "root_out_dir"),
                  root_build_dir) + "/far",
    ]

    test_data_deps = [
      ":memory_bootfs_size_test_data",
      "//build/images/fuchsia:fuchsia_zbi_for_host_tests",
    ]
  }

  host_test_data("memory_bootfs_size_test_data") {
    sources = [
      "$host_out_dir/far",
      "$host_out_dir/zbi",
    ]
    deps = [
      "//src/sys/pkg/bin/far:bin",
      zbi_tool_target,
    ]
  }
}

group("tests") {
  testonly = true
  public_deps = [ ":memory_bootfs_size_test($host_toolchain)" ]
}
