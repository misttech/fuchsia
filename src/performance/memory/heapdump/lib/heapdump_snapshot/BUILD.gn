import("//build/components.gni")
import("//build/rust/rustc_library.gni")
import("//build/test.gni")
import("//tools/fidl/measure-tape/measure_tape.gni")

measure_tape("measure_tape_for_snapshot_element") {
  target_binding = "rust"
  target_types = [ "fuchsia.memory.heapdump.client/SnapshotElement" ]
  fidls = [ "//sdk/fidl/fuchsia.memory.heapdump.client" ]
}

template("heapdump_snapshot_lib") {
  rustc_library(target_name) {
    edition = "2024"
    with_unit_tests = true

    sources = [
      "src/lib.rs",
      "src/snapshot.rs",
      "src/streamer.rs",
    ]

    deps = [
      ":measure_tape_for_snapshot_element",
      "//sdk/rust/zx-status",
      "//sdk/rust/zx-types",
      "//src/lib/fidl/rust/fidl",
      "//third_party/rust_crates:futures",
      "//third_party/rust_crates:thiserror",
    ]
    if (defined(invoker.deps)) {
      deps += invoker.deps
    }

    test_deps = [
      "//src/lib/fuchsia-async",
      "//third_party/rust_crates:assert_matches",
      "//third_party/rust_crates:maplit",
      "//third_party/rust_crates:test-case",
    ]
    if (defined(invoker.test_deps)) {
      test_deps += invoker.test_deps
    }

    features = []
    if (defined(invoker.features)) {
      features += invoker.features
    }
  }
}

heapdump_snapshot_lib("heapdump_snapshot") {
  deps = [ "//sdk/fidl/fuchsia.memory.heapdump.client:fuchsia.memory.heapdump.client_rust_flex" ]
}

heapdump_snapshot_lib("heapdump_snapshot_fdomain") {
  deps = [
    "//sdk/fidl/fuchsia.memory.heapdump.client:fuchsia.memory.heapdump.client_rust_fdomain_flex",
    "//src/lib/fdomain/client",
  ]
  test_deps = [ "//src/lib/fdomain/local" ]
  features = [ "fdomain" ]
}

fuchsia_unittest_package("heapdump-snapshot-tests") {
  package_name = "heapdump-snapshot-tests"
  deps = [ ":heapdump_snapshot_test" ]
}

group("tests") {
  testonly = true
  deps = [
    ":heapdump-snapshot-tests",
    ":heapdump_snapshot_fdomain_test($host_toolchain)",
  ]
}
