group("stacktrack") {
  deps = [
    "collector",
    "instrumentation",
  ]
}

group("tests") {
  testonly = true
  deps = [
    "collector:tests",
    "instrumentation:tests",
    "lib/stacktrack_snapshot:tests",
    "lib/stacktrack_vmo:tests",
  ]
}
