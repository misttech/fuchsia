{
    include: [
        "//src/sys/test_runners/gtest/default.shard.cml",
        "syslog/client.shard.cml",
    ],
    program: {
        binary: "bin/ktrace_provider_integration_test",
    },
    children: [
        {
            name: "trace_manager",
            url: "#meta/trace_manager.cm",
        },
        {
            name: "ktrace-provider",
            url: "ktrace_provider#meta/ktrace_provider.cm",
            startup: "eager",
        },
    ],
    use: [
        {
            protocol: "fuchsia.tracing.controller.Provisioner",
            from: "#trace_manager",
        },
        { protocol: "fuchsia.kernel.TracingResource" },
    ],
    offer: [
        {
            protocol: [ "fuchsia.tracing.provider.Registry" ],
            from: "#trace_manager",
            to: "#ktrace-provider",
        },
        {
            protocol: [ "fuchsia.kernel.TracingResource" ],
            from: "parent",
            to: [ "#ktrace-provider" ],
        },
    ],
}
