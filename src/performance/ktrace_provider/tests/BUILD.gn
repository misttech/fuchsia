import("//build/components.gni")
import("//build/test.gni")

executable("ktrace_provider_integration_test_bin") {
  testonly = true
  output_name = "ktrace_provider_integration_test"
  sources = [ "integration_test.cc" ]
  deps = [
    "//sdk/fidl/fuchsia.kernel:fuchsia.kernel_cpp",
    "//sdk/fidl/fuchsia.tracing.controller:fuchsia.tracing.controller_cpp",
    "//sdk/lib/async-loop:async-loop-cpp",
    "//sdk/lib/async-loop:async-loop-default",
    "//sdk/lib/component/incoming/cpp",
    "//sdk/lib/syslog/cpp",
    "//src/lib/fxl/test:gtest_main",
    "//third_party/googletest:gtest",
    "//zircon/system/ulib/trace-reader",
    "//zircon/system/ulib/zircon-internal",
  ]
}

fuchsia_test_component("ktrace_provider_integration_test_component") {
  component_name = "ktrace_provider_integration_test"
  manifest = "meta/ktrace_provider_integration_test.cml"
  deps = [
    ":ktrace_provider_integration_test_bin",
    "//src/performance/trace_manager:component_hermetic",
  ]
  test_type = "system"
}

fuchsia_test_package("ktrace-provider-tests") {
  test_components = [ ":ktrace_provider_integration_test_component" ]
  subpackages = [ "//src/performance/ktrace_provider" ]
  test_specs = {
    parallel = 1
  }
}

group("tests") {
  testonly = true
  deps = [ ":ktrace-provider-tests" ]
}
