[
    {
        type: "SyscallHandler",
        name: "syscall_handler",
        config: {
            use_fake_cpu_resource: true,
        },
    },
    {
        type: "CpuStatsHandler",
        name: "cpu_stats",
        config: {
            cpu_load_cache_duration_ms: 100,
        },
    },
    {
        type: "CpuDeviceHandler",
        name: "cpu_handler",
        config: {
            total_domain_count: 1,
            perf_rank: 0,
        },
    },
    {
        type: "CpuManagerMain",
        name: "cpu_manager_main",
        config: {
            sustainable_power: 100.0,
            power_gain: 1.0,
            min_power_for_boost: 100.0, // no boost
            clusters: [
                {
                    name: "cluster0",
                    cluster_index: 0,
                    handler: "cpu_handler",
                    logical_cpu_numbers: [
                        0,
                        1,
                        2,
                        3,
                    ],
                    normperfs_per_ghz: 1.0,
                },
            ],
            thermal_states: [
                {
                    cluster_opps: [
                        0,
                        0,
                    ],
                    min_performance_normperfs: 0.0,
                    static_power_w: 100.0,
                    dynamic_power_per_normperf_w: 1,
                },
            ],
        },
        dependencies: {
            cpu_device_handlers: [
                "cpu_handler",
            ],
            cpu_stats_handler: "cpu_stats",
            syscall_handler: "syscall_handler",
        },
    },
    {
        type: "DomainController",
        name: "domain_controller",
        dependencies: {
            cpu_manager_main_node: "cpu_manager_main",
        },
    },
]
