import("//build/components.gni")

fuchsia_unittest_package("power_observability_state_recorder_cpp_test") {
  test_specs = {
    log_settings = {
      max_severity = "ERROR"
    }
  }
  deps = [ ":state_recorder_test" ]
}

executable("state_recorder_test") {
  testonly = true
  sources = [ "state_recorder_test.cc" ]
  deps = [
    "//sdk/lib/inspect/component/cpp",
    "//sdk/lib/inspect/testing/cpp",
    "//src/lib/fxl/test:gtest_main",
    "//src/lib/testing/loop_fixture",
    "//src/power/observability/cpp:state_recorder",
    "//third_party/googletest:gtest",
  ]
}

group("tests") {
  testonly = true
  deps = [ ":power_observability_state_recorder_cpp_test" ]
}
