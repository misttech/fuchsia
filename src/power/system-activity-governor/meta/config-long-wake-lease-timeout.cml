{
    capabilities: [
        {
            config: "fuchsia.power.LongWakeLeaseTimeout",
            type: "uint32",
            value: 300,
        },
    ],
    expose: [
        {
            config: "fuchsia.power.LongWakeLeaseTimeout",
            from: "self",
        },
    ],
}
