import("//build/components.gni")
import("//build/rust/rustc_binary.gni")

rustc_binary("bin") {
  edition = "2024"
  output_name = "fake-shutdown-shim"
  with_unit_tests = true
  sources = [ "src/main.rs" ]
  deps = [
    "//sdk/fidl/fuchsia.hardware.power.statecontrol:fuchsia.hardware.power.statecontrol_rust",
    "//src/lib/fuchsia",
    "//src/lib/fuchsia-component",
    "//third_party/rust_crates:anyhow",
    "//third_party/rust_crates:futures",
    "//third_party/rust_crates:log",
  ]
  test_deps = [
    "//src/lib/fidl/rust/fidl",
    "//src/lib/fuchsia-async",
  ]
}

fuchsia_component("fake-shutdown-shim") {
  manifest = "meta/fake-shutdown-shim.cml"
  deps = [ ":bin" ]
}

fuchsia_package("package") {
  package_name = "fake-shutdown-shim"
  deps = [ ":fake-shutdown-shim" ]
}

fuchsia_unittest_package("fake-shutdown-shim-tests") {
  deps = [ ":bin_test" ]
}

group("tests") {
  testonly = true
  deps = [ ":fake-shutdown-shim-tests" ]
}
