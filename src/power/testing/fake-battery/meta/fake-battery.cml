{
    include: [
        "driver_component/driver.shard.cml",
        "syslog/client.shard.cml",
    ],
    program: {
        runner: "driver",
        binary: "driver/fake_battery.so",
        bind: "meta/bind/fake-battery.bindbc",
    },
    capabilities: [
        {
            protocol: [ "fuchsia.power.battery.BatteryInfoProvider" ],
        },
        {
            service: [
                "fuchsia.hardware.power.battery.Service",
                "fuchsia.power.battery.InfoService",
                "test.hardwarepowercontrol.Service",
            ],
        },
    ],
    expose: [
        {
            service: [
                "fuchsia.hardware.power.battery.Service",
                "fuchsia.power.battery.InfoService",
                "test.hardwarepowercontrol.Service",
            ],
            from: "self",
        },
    ],
}
