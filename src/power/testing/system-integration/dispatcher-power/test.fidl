library test.power.dispatcher;

@discoverable
open protocol TestController {
    /// Reports that the recurring task has executed.
    strict ReportRecurringTaskRun();

    /// Reports that the wake vector wait callback has executed.
    strict ReportWakeVectorTriggered();

    /// Reports that the non-wake wait callback has executed.
    strict ReportNonWakeWaitTriggered();

    /// Reports that SystemResume was called.
    strict ReportSystemResume(struct {
        has_lease bool;
    });
};
