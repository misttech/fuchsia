{
    include: [
        "driver_component/driver.shard.cml",
        "driver_component/power_managed_dispatchers.shard.cml",
        "inspect/client.shard.cml",
        "syslog/client.shard.cml",
    ],
    program: {
        runner: "driver",
        binary: "driver/dispatcher-power-test-driver.so",
        bind: "meta/bind/dispatcher-power-test-driver.bindbc",
    },
    use: [
        {
            protocol: [ "test.power.dispatcher.TestController" ],
            availability: "optional",
        },
    ],
}
