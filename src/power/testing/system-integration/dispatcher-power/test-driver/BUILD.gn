import("//build/drivers.gni")

driver_bind_rules("bind") {
  rules = "meta/driver.bind"
  deps = [ "//src/devices/bind/fuchsia.test" ]
  bind_output = "dispatcher-power-test-driver.bindbc"
}

fuchsia_cc_driver("driver") {
  output_name = "dispatcher-power-test-driver"
  sources = [ "driver.cc" ]
  deps = [
    "//sdk/fidl/fuchsia.power.broker:fuchsia.power.broker_cpp",
    "//sdk/fidl/fuchsia.power.system:fuchsia.power.system_cpp",
    "//sdk/lib/driver/component/cpp",
    "//src/devices/lib/driver:driver_runtime",
    "//src/power/testing/system-integration/dispatcher-power:test.power.dispatcher_cpp",
  ]
}

fuchsia_driver_component("component") {
  manifest = "meta/driver.cml"
  component_name = "dispatcher-power-test-driver"
  deps = [
    ":bind",
    ":driver",
  ]
  info = "meta/info.json"
}

fuchsia_driver_package("dispatcher-power-test-driver") {
  driver_components = [ ":component" ]
}
