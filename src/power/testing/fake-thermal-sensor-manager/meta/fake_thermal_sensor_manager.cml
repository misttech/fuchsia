{
    include: [ "syslog/client.shard.cml" ],
    program: {
        runner: "elf",
        binary: "bin/fake_thermal_sensor_manager",
    },
    capabilities: [
        {
            protocol: [ "fuchsia.thermal.SensorManager" ],
        },
    ],
    expose: [
        {
            protocol: [ "fuchsia.thermal.SensorManager" ],
            from: "self",
        },
    ],
}
