import("//build/components.gni")
import("//build/fidl/fidl.gni")
import("//build/rust/rustc_binary.gni")

rustc_test("bin") {
  name = "fake_thermal_sensor_manager_integration_test"
  testonly = true
  edition = "2021"
  deps = [
    "//sdk/fidl/fuchsia.thermal:fuchsia.thermal_rust",
    "//sdk/rust/zx",
    "//src/lib/fidl/rust/fidl",
    "//src/lib/fuchsia",
    "//src/lib/fuchsia-component-test",
    "//src/power/testing/fake-thermal-sensor-manager:component",
    "//third_party/rust_crates:log",
  ]

  sources = [ "src/lib.rs" ]
}

fuchsia_unittest_package("fake-thermal-sensor-manager-integration-test") {
  manifest = "meta/test.cml"
  deps = [ ":bin" ]
  test_specs = {
    environments = basic_envs
  }
}

group("tests") {
  testonly = true
  deps = [ ":fake-thermal-sensor-manager-integration-test" ]
}
