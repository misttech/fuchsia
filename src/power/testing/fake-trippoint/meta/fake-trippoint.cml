{
    include: [
        "driver_component/driver.shard.cml",
        "inspect/client.shard.cml",
        "syslog/client.shard.cml",
    ],
    program: {
        runner: "driver",
        binary: "driver/fake_trippoint.so",
        bind: "meta/bind/fake-trippoint.bindbc",
    },
    capabilities: [
        { service: "fuchsia.hardware.temperature.Service" },
        { service: "test.trippoint.Service" },
    ],
    expose: [
        {
            service: "fuchsia.hardware.temperature.Service",
            from: "self",
        },
        {
            service: "test.trippoint.Service",
            from: "self",
        },
    ],
}
