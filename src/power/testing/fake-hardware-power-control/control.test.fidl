library test.hardwarepowercontrol;

using fuchsia.hardware.power.battery;
using fuchsia.hardware.power.source;

const DEFAULT_LEVEL_PERCENT float32 = 98.7;
const DEFAULT_ROUNDED_LEVEL_PERCENT float32 = 99.0;
const DEFAULT_PRESENT_VOLTAGE_MV uint32 = 4752;
const DEFAULT_REMAINING_CHARGE_UAH uint32 = 382000;
const DEFAULT_FULL_CAPACITY_UAH uint32 = 420000;
const DEFAULT_TEMPERATURE_MC int32 = 380;
const DEFAULT_CHARGING_CURRENT_UA int32 = 250014;

@discoverable
closed protocol Control {
    /// Sets the status returned by fuchsia.hardware.power.battery/Battery.Watch.
    /// If `status.source_status` is omitted, the previously established source status
    /// is preserved.
    strict SetBatteryStatus(struct {
        status fuchsia.hardware.power.battery.Status;
    }) -> ();

    /// Sets the status returned by fuchsia.hardware.power.source/Source.Watch.
    strict SetSourceStatus(struct {
        status fuchsia.hardware.power.source.Status;
    }) -> ();
};

service Service {
    control client_end:Control;
};
