{
    include: [
        "driver/platform-device.shard.cml",
        "driver_component/driver.shard.cml",
    ],
    program: {
        binary: "driver/test-power.so",
        bind: "meta/bind/test-power-bind.bindbc",
        colocate: "true",
        default_dispatcher_opts: [ "allow_sync_calls" ],
    },
    capabilities: [
        { service: "fuchsia.hardware.power.DomainMetadata" },
    ],
    expose: [
        {
            service: "fuchsia.hardware.power.DomainMetadata",
            from: "self",
        },
    ],
}
