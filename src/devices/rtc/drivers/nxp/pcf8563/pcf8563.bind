composite pcf8563;

primary parent "i2c" {
  fuchsia.hardware.i2c.Service == fuchsia.hardware.i2c.Service.ZirconTransport;
}

parent "devicetree" {
  fuchsia.devicetree.FIRST_COMPATIBLE == "nxp,pcf8563";
}
