library fuchsia.hardware.usb.virtualbustest;

using zx;

closed protocol BusTest {
    strict Control(struct {
        is_in bool;
        out_data vector<uint8>:MAX;
    }) -> (struct {
        in_data vector<uint8>:MAX;
    }) error zx.Status;

    strict Out(struct {
        data vector<uint8>:MAX;
    }) -> (struct {
        actual uint64;
    }) error zx.Status;

    strict In(struct {
        size uint64;
    }) -> (struct {
        data vector<uint8>:MAX;
    }) error zx.Status;
};

closed protocol ExpectBusTest {
    strict ExpectControl(struct {
        is_in bool;
        in_data vector<uint8>:MAX;
    }) -> (struct {
        out_data vector<uint8>:MAX;
    }) error zx.Status;

    strict ExpectOut() -> (struct {
        data vector<uint8>:MAX;
    }) error zx.Status;

    strict ExpectIn(struct {
        data vector<uint8>:MAX;
    }) -> (struct {
        actual uint64;
    }) error zx.Status;

    /// Used to sync, i.e. call `Sync()` after `ExpectControl()` to
    /// ensure that `ExpectControl()` has arrived before calling
    /// `Control()`.
    strict Sync() -> ();

    strict Connect(struct {
        connect bool;
    }) -> ();
};

service BusTestService {
    device client_end:BusTest;
};

service ExpectBusTestService {
    device client_end:ExpectBusTest;
};
