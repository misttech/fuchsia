import("//build/components.gni")
import("//build/drivers.gni")

driver_bind_rules("usb-virtual-bus-tester-function-bind") {
  testonly = true
  rules = "meta/usb-virtual-bus-tester-function.bind"
  deps = [
    "..:fuchsia.usb.test",
    "//src/devices/bind/fuchsia.usb",
  ]
}

source_set("virtual-bus-tester-function-common") {
  testonly = true
  sources = [ "peripheral.cc" ]
  public_deps = [
    ":usb-virtual-bus-tester-function-bind",
    "..:fuchsia.hardware.usb.virtualbustest_cpp",
    "//sdk/banjo/fuchsia.hardware.usb:fuchsia.hardware.usb_banjo_cpp",
    "//sdk/banjo/fuchsia.hardware.usb.request:fuchsia.hardware.usb.request_banjo_cpp",
    "//sdk/fidl/fuchsia.hardware.usb.descriptor:fuchsia.hardware.usb.descriptor_cpp",
    "//sdk/lib/driver/compat/cpp",
    "//sdk/lib/driver/component/cpp",
    "//src/devices/usb/lib/usb:usb-dfv2-compat-logging",
  ]
}

fuchsia_cc_driver("virtual-bus-tester-function-driver") {
  testonly = true
  output_name = "virtual-bus-tester-function"
  sources = [ "peripheral-fidl.cc" ]
  deps = [
    ":virtual-bus-tester-function-common",
    "//sdk/fidl/fuchsia.hardware.usb.function:fuchsia.hardware.usb.function_cpp",
    "//src/devices/usb/lib/usb-endpoint:usb-endpoint-client-dfv2-compat-logging",
  ]
}

fuchsia_driver_component("virtual-bus-tester-function") {
  testonly = true
  info = "meta/virtual-bus-tester-function-info.json"
  component_name = "virtual-bus-tester-function"
  deps = [ ":virtual-bus-tester-function-driver" ]
  manifest = "meta/virtual-bus-tester-function-fidl.cml"
}
