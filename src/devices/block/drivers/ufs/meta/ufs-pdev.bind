composite ufs_pdev;


primary parent "pdev" {
  fuchsia.devicetree.FIRST_COMPATIBLE == "google,ufshc";
}

parent "phy" {
  fuchsia.hardware.ufs.phy.Service == fuchsia.hardware.ufs.phy.Service.ZirconTransport;
}
