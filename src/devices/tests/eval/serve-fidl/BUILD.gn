import("//build/components.gni")
import("//build/rust/rustc_test.gni")

group("drivers") {
  testonly = true
  deps = [
    "cpp:component",
    "rust:component",
  ]
}

rustc_test("bin") {
  edition = "2024"
  testonly = true
  output_name = "eval_driver_serve_fidl_test_bin"
  source_root = "test.rs"
  sources = [ "test.rs" ]
  deps = [
    "//examples/fidl/fuchsia.examples:fuchsia.examples_rust",
    "//sdk/fidl/fuchsia.driver.test:fuchsia.driver.test_rust",
    "//sdk/lib/driver_test_realm/realm_builder/rust:rust_no_driver_manager",
    "//src/lib/fuchsia-async",
    "//src/lib/fuchsia-component",
    "//src/lib/fuchsia-component-test",
    "//third_party/rust_crates:anyhow",
  ]
}

# Creates a test package target of `bin` for testing a specific driver.
#
# Args:
#   driver_component: The component of the driver to test.
template("eval_driver_serve_fidl_test_package") {
  fuchsia_unittest_package(target_name) {
    deps = [
      ":bin",
      "//sdk/lib/driver_test_realm:driver_manager_test_rust",
      "//sdk/lib/driver_test_realm:driver_test_realm_component",
      invoker.driver_component,
    ]
  }
}

eval_driver_serve_fidl_test_package("eval_driver_serve_fidl_test_cpp") {
  driver_component = "cpp:component"
}

eval_driver_serve_fidl_test_package("eval_driver_serve_fidl_test_rust") {
  driver_component = "rust:component"
}
