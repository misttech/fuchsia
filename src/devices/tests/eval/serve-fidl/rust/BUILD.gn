import("//build/bind/bind.gni")
import("//build/components.gni")
import("//build/drivers.gni")

driver_bind_rules("bind") {
  rules = "meta/driver-serve-fidl.bind"
  bind_output = "driver-serve-fidl.bindbc"
  deps = [
    "//src/devices/bind/fuchsia",
    "//src/devices/bind/fuchsia.test",
  ]
}

fuchsia_rust_driver("driver") {
  edition = "2024"
  testonly = true

  output_name = "eval_driver_serve_fidl"
  sources = [ "src/lib.rs" ]
  deps = [
    "//sdk/lib/driver/component/rust",
    "//sdk/rust/zx",
    "//src/lib/fuchsia-async",
    "//src/lib/fuchsia-component",
    "//third_party/rust_crates:futures",
    "//third_party/rust_crates:log",
  ]
}

fuchsia_driver_component("component") {
  testonly = true
  component_name = "eval_driver_serve_fidl"
  manifest = "meta/driver-serve-fidl.cml"
  deps = [
    ":bind",
    ":driver",
  ]
  info = "meta/component-info.json"
}
