import("//build/components.gni")
import("//build/devicetree/devicetree.gni")
import("//build/drivers.gni")
import("//build/rust/rustc_test.gni")

group("tests") {
  testonly = true
  deps = [ ":simple-dt-eval-test" ]
}

group("drivers") {
  testonly = true
  deps = [
    "dt-eval-driver:dt-eval-driver-component",
    "fake-board:fake-board-component",
  ]
}

rustc_test("test-bin") {
  edition = "2024"
  source_root = "dt-eval-test.rs"
  sources = [ "dt-eval-test.rs" ]
  deps = [
    "//sdk/fidl/fuchsia.driver.test:fuchsia.driver.test_rust",
    "//sdk/lib/driver_test_realm/realm_builder/rust",
    "//sdk/rust/zx",
    "//src/devices/tests/fidl-service:echo_rust",
    "//src/lib/fuchsia-async",
    "//src/lib/fuchsia-component",
    "//src/lib/fuchsia-component-test",
    "//third_party/rust_crates:anyhow",
  ]
}

fuchsia_unittest_component("test-component") {
  manifest = "meta/dt-eval-test.cml"
  deps = [ ":test-bin" ]
}

# Template to generate a test package for a specific devicetree. The fake board
# driver will create child nodes based off the provided devicetree during the
# test.
# Parameters:
#   dts: Path to the .dts source file.
#   golden: Path to the golden .dts file.
template("dt_eval_test_package") {
  assert(defined(invoker.dts), "Must specify dts file")
  assert(defined(invoker.golden), "Must specify golden file")

  dt_target = "${target_name}-dt"
  resource_target = "${target_name}-resource"

  devicetree(dt_target) {
    sources = [ invoker.dts ]
    golden = invoker.golden
  }

  resource(resource_target) {
    sources = [ "$target_out_dir/${dt_target}.dtb" ]
    outputs = [ "test-data/test-device.dtb" ]
    deps = [ ":$dt_target" ]
  }

  fuchsia_test_package(target_name) {
    test_components = [ ":test-component" ]
    deps = [
      ":$resource_target",
      "dt-eval-driver:dt-eval-driver-component",
      "fake-board:fake-board-component",
      "//src/lib/fuchsia-component-test/realm_builder_server:realm_builder_server_component",
    ]
    subpackages = [ "//sdk/lib/driver_test_realm:package" ]
    test_specs = {
      environments = []
    }
  }
}

dt_eval_test_package("simple-dt-eval-test") {
  dts = "devicetrees/simple.dts"
  golden = "devicetrees/simple.golden.dts"
}
