import("//build/bind/bind.gni")
import("//build/drivers.gni")

driver_bind_rules("dt-eval-driver-bind") {
  testonly = true
  rules = "meta/dt-eval-driver.bind"
  deps = [ "//src/devices/bind/fuchsia.devicetree" ]
}

fuchsia_rust_driver("dt-eval-driver-driver") {
  testonly = true
  output_name = "dt_eval_driver"
  edition = "2024"
  source_root = "src/lib.rs"
  sources = [ "src/lib.rs" ]
  deps = [
    ":dt-eval-driver-bind",
    "//sdk/fidl/fuchsia.driver.framework:fuchsia.driver.framework_rust",
    "//sdk/lib/driver/component/rust",
    "//sdk/rust/zx",
    "//src/devices/tests/fidl-service:echo_rust",
    "//src/lib/fidl/rust/fidl",
    "//src/lib/fuchsia-async",
    "//src/lib/fuchsia-component",
    "//third_party/rust_crates:futures",
  ]
}

fuchsia_driver_component("dt-eval-driver-component") {
  testonly = true
  info = "meta/dt-eval-driver-info.json"
  component_name = "dt-eval-driver"
  deps = [
    ":dt-eval-driver-bind",
    ":dt-eval-driver-driver",
  ]
  manifest = "meta/dt-eval-driver.cml"
}
