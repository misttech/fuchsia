{
    include: [ "syslog/client.shard.cml" ],
    program: {
        runner: "driver",
        binary: "driver/dt_eval_driver.so",
        bind: "meta/bind/dt-eval-driver-bind.bindbc",
        colocate: "true",
    },
    capabilities: [
        { service: "fidl.examples.echo.EchoService" },
    ],
    expose: [
        {
            service: "fidl.examples.echo.EchoService",
            from: "self",
        },
    ],
}
