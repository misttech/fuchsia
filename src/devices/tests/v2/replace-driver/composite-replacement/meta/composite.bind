composite H_replaced;


parent "D_replaced" {
  fuchsia.reloaddriverbind.test.TEST_BIND_PROPERTY ==
    fuchsia.reloaddriverbind.test.TEST_BIND_PROPERTY.COMPOSITE_PARENT_D;
}

primary parent "E_replaced" {
  fuchsia.reloaddriverbind.test.TEST_BIND_PROPERTY ==
    fuchsia.reloaddriverbind.test.TEST_BIND_PROPERTY.COMPOSITE_PARENT_E;
}

parent "F_replaced" {
  fuchsia.reloaddriverbind.test.TEST_BIND_PROPERTY ==
    fuchsia.reloaddriverbind.test.TEST_BIND_PROPERTY.COMPOSITE_PARENT_F;
}
