library fuchsia.dictionaryoffers.test;

using fuchsia.driver.framework;

closed protocol ControlPlane {
    strict AddChild(resource struct {
        args fuchsia.driver.framework.NodeAddArgs;
    }) -> () error fuchsia.driver.framework.NodeError;
};

@discoverable
closed protocol DataPlane {
    strict DataDo() -> ();
};

service ControlService {
    control client_end:ControlPlane;
};

service DataService {
    data client_end:DataPlane;
};
