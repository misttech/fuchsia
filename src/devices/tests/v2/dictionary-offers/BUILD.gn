import("//build/components.gni")
import("//build/drivers.gni")
import("//build/rust/rustc_test.gni")

group("tests") {
  testonly = true
  deps = [ ":dictionary_offers_test" ]
}

fidl("fuchsia.dictionaryoffers.test") {
  testonly = true
  sources = [ "dictionary_offers.test.fidl" ]
  public_deps = [ "//sdk/fidl/fuchsia.driver.framework" ]
}

driver_bind_rules("root_bind") {
  disable_autobind = true
  bind_output = "dictionary_offers_root.bindbc"
}

fuchsia_cc_driver("root_driver") {
  testonly = true
  output_name = "dictionary_offers_root"
  sources = [ "root_driver.cc" ]
  deps = [
    ":fuchsia.dictionaryoffers.test_cpp",
    ":root_bind",
    "//sdk/fidl/fuchsia.component.decl:fuchsia.component.decl_cpp",
    "//sdk/lib/driver/component/cpp",
    "//src/devices/lib/driver:driver_runtime",
    "//src/devices/tests/v2/node_group:fuchsia.nodegroupbind.test_cpp",
  ]
}

fuchsia_driver_component("root") {
  testonly = true
  manifest = "meta/root.cml"
  deps = [ ":root_driver" ]
  info = "meta/root-info.json"
}

driver_bind_rules("child_bind") {
  testonly = true
  deps = [ ":fuchsia.dictionaryoffers.test_bindlib" ]
  rules = "meta/child.bind"
  bind_output = "dictionary_offers_child.bindbc"
}

driver_bind_rules("composite_child_bind") {
  testonly = true
  deps = [
    ":fuchsia.dictionaryoffers.test_bindlib",
    "//src/devices/tests/v2/node_group:fuchsia.nodegroupbind.test",
  ]
  rules = "meta/composite-child.bind"
  bind_output = "dictionary_offers_composite_child.bindbc"
}

fuchsia_cc_driver("child_driver") {
  testonly = true
  output_name = "dictionary_offers_child"
  sources = [ "child_driver.cc" ]
  deps = [
    ":fuchsia.dictionaryoffers.test_cpp",
    "//sdk/fidl/fuchsia.component.decl:fuchsia.component.decl_cpp",
    "//sdk/lib/driver/component/cpp",
    "//src/devices/lib/driver:driver_runtime",
  ]
}

fuchsia_driver_component("child") {
  testonly = true
  manifest = "meta/child.cml"
  deps = [
    ":child_bind",
    ":child_driver",
  ]
  info = "meta/child-info.json"
}

fuchsia_driver_component("composite_child") {
  testonly = true
  manifest = "meta/composite-child.cml"
  deps = [
    ":child_driver",
    ":composite_child_bind",
  ]
  info = "meta/child-info.json"
}

rustc_test("bin") {
  edition = "2024"
  testonly = true
  output_name = "dictionary_offers_bin"
  source_root = "test.rs"
  sources = [ "test.rs" ]
  deps = [
    ":fuchsia.dictionaryoffers.test_rust",
    "//sdk/fidl/fuchsia.component:fuchsia.component_rust",
    "//sdk/fidl/fuchsia.component.decl:fuchsia.component.decl_rust",
    "//sdk/fidl/fuchsia.driver.framework:fuchsia.driver.framework_rust",
    "//sdk/fidl/fuchsia.driver.test:fuchsia.driver.test_rust",
    "//sdk/lib/driver_test_realm/realm_builder/rust",
    "//src/devices/tests/v2/node_group:fuchsia.nodegroupbind.test_rust",
    "//src/lib/fidl/rust/fidl",
    "//src/lib/fuchsia",
    "//src/lib/fuchsia-async",
    "//src/lib/fuchsia-component",
    "//src/lib/fuchsia-component-test",
    "//third_party/rust_crates:anyhow",
    "//third_party/rust_crates:futures",
  ]
}

fuchsia_unittest_package("dictionary_offers_test") {
  deps = [
    ":bin",
    ":child",
    ":composite_child",
    ":root",
    "//sdk/lib/driver_test_realm:driver_test_realm_component",
  ]
}
