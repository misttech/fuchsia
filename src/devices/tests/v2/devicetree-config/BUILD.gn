import("//build/components.gni")
import("//build/drivers.gni")

import("//build/devicetree/devicetree.gni")
import("//build/rust/rustc_test.gni")

group("tests") {
  testonly = true
  deps = [ ":devicetree_config_test-rust" ]
}

group("drivers") {
  deps = [
    ":board_driver",
    ":child_driver",
  ]
}

# Board Driver
driver_bind_rules("board_bind") {
  rules = "board.bind"
  bind_output = "board.bindbc"
  deps = [ "//src/devices/bind/fuchsia" ]
}

fuchsia_cc_driver("board_driver_bin") {
  output_name = "devicetree_config_board"
  sources = [ "board_driver.cc" ]
  deps = [
    ":board_bind",
    "//sdk/lib/driver/component/cpp",
    "//sdk/lib/driver/devicetree/manager",
    "//sdk/lib/driver/devicetree/visitors:registry",
    "//sdk/lib/driver/devicetree/visitors/default/bind-property",
    "//sdk/lib/driver/devicetree/visitors/drivers/fuchsia-config:fuchsia-config-impl",
    "//sdk/lib/driver/logging/cpp",
    "//src/devices/lib/driver:driver_runtime",
  ]
}

fuchsia_driver_component("board_driver") {
  component_name = "devicetree-config"
  manifest = "board_driver.cml"
  deps = [
    ":board_bind",
    ":board_driver_bin",
  ]
  info = "board-info.json"
}

# Child Driver
driver_bind_rules("child_driver_bind") {
  rules = "child.bind"
  bind_output = "child_driver.bindbc"
  deps = [ "//src/devices/bind/fuchsia.devicetree" ]
}

fuchsia_rust_driver("child_driver_bin") {
  output_name = "devicetree_config_child"
  edition = "2024"
  source_root = "child_driver.rs"
  sources = [ "child_driver.rs" ]
  deps = [
    "//sdk/fidl/fuchsia.driver.metadata:fuchsia.driver.metadata_rust",
    "//sdk/fidl/fuchsia.hardware.platform.device:fuchsia.hardware.platform.device_rust",
    "//sdk/fidl/fuchsia.io:fuchsia.io_rust",
    "//sdk/lib/driver/component/rust",
    "//sdk/lib/driver/metadata/rust",
    "//sdk/lib/driver/platform-device/rust:pdev",
    "//sdk/rust/zx",
    "//src/lib/fidl/rust/fidl",
    "//src/lib/fuchsia-async",
    "//src/lib/fuchsia-component",
    "//third_party/rust_crates:log",
    "//third_party/rust_crates:serde",
  ]
}

fuchsia_driver_component("child_driver") {
  component_name = "child_driver"
  manifest = "child_driver.cml"
  deps = [
    ":child_driver_bin",
    ":child_driver_bind",
  ]
  info = "child-info.json"
}

# DTB
dtb("devicetree-config-dtb") {
  sources = [ "devicetree-config.dts" ]
}

resource("devicetree-config-dtb-resource") {
  sources = get_target_outputs(":devicetree-config-dtb")
  outputs = [ "test-data/devicetree-config.dtb" ]
  deps = [ ":devicetree-config-dtb" ]
}

# Test
executable("integration_test_bin") {
  testonly = true
  sources = [ "integration_test.cc" ]
  deps = [
    "//sdk/lib/async-loop:async-loop-cpp",
    "//sdk/lib/async-loop:async-loop-default",
    "//sdk/lib/driver/devicetree/testing:board-test-helper",
    "//src/lib/fxl/test:gtest_main",
    "//third_party/googletest:gtest",
  ]
}

fuchsia_unittest_package("devicetree_config_test-rust") {
  deps = [
    ":board_driver",
    ":child_driver",
    ":devicetree-config-dtb-resource",
    ":integration_test_bin",
    "//sdk/lib/driver_test_realm:driver_manager_test",
    "//sdk/lib/driver_test_realm/realm_builder:client_includes",
  ]
  subpackages = [ "//sdk/lib/driver_test_realm:package" ]
}
