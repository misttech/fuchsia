[
    {
        "parent": "pdev",
        "tests": [
            {
                "device": {
                    "fuchsia.BIND_PROTOCOL": "fuchsia.platform.BIND_PROTOCOL.DEVICE",
                    "fuchsia.BIND_PLATFORM_DEV_DID": "fuchsia.amlogic.platform.BIND_PLATFORM_DEV_DID.THERMISTOR",
                    "fuchsia.BIND_PLATFORM_DEV_PID": "fuchsia.google.platform.BIND_PLATFORM_DEV_PID.ASTRO",
                    "fuchsia.BIND_PLATFORM_DEV_VID": "fuchsia.google.platform.BIND_PLATFORM_DEV_VID.GOOGLE"
                },
                "expected": "match",
                "name": "SuccessAstro"
            },
            {
                "device": {
                    "fuchsia.BIND_PROTOCOL": "fuchsia.platform.BIND_PROTOCOL.DEVICE",
                    "fuchsia.BIND_PLATFORM_DEV_DID": "fuchsia.amlogic.platform.BIND_PLATFORM_DEV_DID.THERMISTOR",
                    "fuchsia.BIND_PLATFORM_DEV_PID": "fuchsia.google.platform.BIND_PLATFORM_DEV_PID.ASTRO",
                    "fuchsia.BIND_PLATFORM_DEV_VID": "fuchsia.platform.BIND_PLATFORM_DEV_VID.GENERIC"
                },
                "expected": "abort",
                "name": "WrongVid"
            },
            {
                "device": {
                    "fuchsia.BIND_PROTOCOL": "fuchsia.platform.BIND_PROTOCOL.DEVICE",
                    "fuchsia.BIND_PLATFORM_DEV_DID": "fuchsia.amlogic.platform.BIND_PLATFORM_DEV_DID.THERMISTOR",
                    "fuchsia.BIND_PLATFORM_DEV_PID": "fuchsia.google.platform.BIND_PLATFORM_DEV_PID.SHERLOCK",
                    "fuchsia.BIND_PLATFORM_DEV_VID": "fuchsia.google.platform.BIND_PLATFORM_DEV_VID.GOOGLE"
                },
                "expected": "match",
                "name": "SuccessSherlock"
            },
            {
                "device": {
                    "fuchsia.BIND_PROTOCOL": "fuchsia.platform.BIND_PROTOCOL.DEVICE",
                    "fuchsia.BIND_PLATFORM_DEV_DID": "fuchsia.google.platform.BIND_PLATFORM_DEV_DID.ASTRO_GOODIXTOUCH",
                    "fuchsia.BIND_PLATFORM_DEV_PID": "fuchsia.google.platform.BIND_PLATFORM_DEV_PID.ASTRO",
                    "fuchsia.BIND_PLATFORM_DEV_VID": "fuchsia.google.platform.BIND_PLATFORM_DEV_VID.GOOGLE"
                },
                "expected": "abort",
                "name": "WrongDid"
            },
            {
                "device": {
                    "fuchsia.BIND_PROTOCOL": "fuchsia.platform.BIND_PROTOCOL.BUS",
                    "fuchsia.BIND_PLATFORM_DEV_DID": "fuchsia.amlogic.platform.BIND_PLATFORM_DEV_DID.THERMISTOR",
                    "fuchsia.BIND_PLATFORM_DEV_PID": "fuchsia.google.platform.BIND_PLATFORM_DEV_PID.SHERLOCK",
                    "fuchsia.BIND_PLATFORM_DEV_VID": "fuchsia.google.platform.BIND_PLATFORM_DEV_VID.GOOGLE"
                },
                "expected": "abort",
                "name": "WrongProtocol"
            },
            {
                "device": {
                    "fuchsia.BIND_PLATFORM_DEV_VID": "fuchsia.platform.BIND_PLATFORM_DEV_VID.GENERIC",
                    "fuchsia.BIND_PLATFORM_DEV_DID": "fuchsia.platform.BIND_PLATFORM_DEV_DID.DEVICETREE",
                    "fuchsia.devicetree.FIRST_COMPATIBLE": "\"google,astro-thermistor\""
                },
                "expected": "match",
                "name": "DevicetreeAstroMatch"
            },
            {
                "device": {
                    "fuchsia.BIND_PLATFORM_DEV_VID": "fuchsia.platform.BIND_PLATFORM_DEV_VID.GENERIC",
                    "fuchsia.BIND_PLATFORM_DEV_DID": "fuchsia.platform.BIND_PLATFORM_DEV_DID.DEVICETREE",
                    "fuchsia.devicetree.FIRST_COMPATIBLE": "\"google,sherlock-thermistor\""
                },
                "expected": "match",
                "name": "DevicetreeSherlockMatch"
            },
            {
                "device": {
                    "fuchsia.BIND_PLATFORM_DEV_VID": "fuchsia.platform.BIND_PLATFORM_DEV_VID.GENERIC",
                    "fuchsia.BIND_PLATFORM_DEV_DID": "fuchsia.platform.BIND_PLATFORM_DEV_DID.DEVICETREE",
                    "fuchsia.devicetree.FIRST_COMPATIBLE": "\"google,nelson-thermistor\""
                },
                "expected": "match",
                "name": "DevicetreeNelsonMatch"
            },
            {
                "device": {
                    "fuchsia.BIND_PLATFORM_DEV_VID": "fuchsia.platform.BIND_PLATFORM_DEV_VID.GENERIC",
                    "fuchsia.BIND_PLATFORM_DEV_DID": "fuchsia.platform.BIND_PLATFORM_DEV_DID.DEVICETREE",
                    "fuchsia.devicetree.FIRST_COMPATIBLE": "\"google,wrong-thermistor\""
                },
                "expected": "abort",
                "name": "DevicetreeWrongCompatible"
            },
            {
                "device": {
                    "fuchsia.BIND_PLATFORM_DEV_VID": "fuchsia.platform.BIND_PLATFORM_DEV_VID.GENERIC",
                    "fuchsia.BIND_PLATFORM_DEV_DID": "fuchsia.amlogic.platform.BIND_PLATFORM_DEV_DID.THERMISTOR"
                },
                "expected": "abort",
                "name": "DevicetreeGenericWrongDid"
            }
        ]
    },
    {
        "parent": "adc-0",
        "tests": [
            {
                "device": {
                    "fuchsia.hardware.adc.Service": "fuchsia.hardware.adc.Service.ZirconTransport",
                    "fuchsia.adc.FUNCTION": "fuchsia.adc.FUNCTION.THERMISTOR",
                    "fuchsia.adc.CHANNEL": "0"
                },
                "expected": "match",
                "name": "SuccessAdc"
            }
        ]
    }
]
