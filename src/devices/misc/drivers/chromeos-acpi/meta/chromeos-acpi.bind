composite chromeos_acpi;


primary parent "acpi" {
  fuchsia.BIND_PROTOCOL == fuchsia.acpi.BIND_PROTOCOL.DEVICE;
  accept fuchsia.acpi.HID {
    "GOOG0016",
    "GGL0001",
  }
}

parent "irq000" {
  fuchsia.hardware.interrupt.Service == fuchsia.hardware.interrupt.Service.ZirconTransport;
}
