composite generic_suspend;


primary parent "pdev" {
    // TODO(b/374801168): Remove `amlogic,suspend` once the drive is soft transitioned.
    accept fuchsia.devicetree.FIRST_COMPATIBLE {
        "generic,suspend",
        "amlogic,suspend",
    }
}
