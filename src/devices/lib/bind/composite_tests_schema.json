{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "items": {
        "additionalProperties": false,
        "properties": {
            "node": {
                "type": "string"
            },
            "parent": {
                "type": "string"
            },
            "tests": {
                "items": {
                    "additionalProperties": false,
                    "properties": {
                        "device": {
                            "additionalProperties": {
                                "type": "string"
                            },
                            "type": "object"
                        },
                        "expected": {
                            "enum": [
                                "match",
                                "abort"
                            ],
                            "type": "string"
                        },
                        "name": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "name",
                        "expected",
                        "device"
                    ],
                    "type": "object"
                },
                "type": "array"
            }
        },
        "anyOf": [
            {
                "required": [
                    "node"
                ]
            },
            {
                "required": [
                    "parent"
                ]
            }
        ],
        "required": [
            "tests"
        ],
        "type": "object"
    },
    "type": "array"
}
