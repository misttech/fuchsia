config("headers.config") {
  include_dirs = [ "include" ]
}

sdk_source_set("mmio") {
  api = "//sdk/lib/mmio/mmio.api"
  category = "partner"
  sdk_name = "mmio"
  stable = true
  public = [
    "include/lib/mmio/mmio-buffer.h",
    "include/lib/mmio/mmio-ops.h",
    "include/lib/mmio/mmio-pinned-buffer.h",
    "include/lib/mmio/mmio-view.h",
    "include/lib/mmio/mmio.h",
  ]
  public_configs = [ ":headers.config" ]
  public_deps = [
    # <lib/mmio/mmio.h> has #include <lib/mmio-ptr/mmio-ptr.h>.
    "//zircon/system/ulib/mmio-ptr",

    # <lib/mmio/mmio.h> has #include <lib/zx/bti.h>.
    # <lib/mmio/mmio-buffer.h> has #include <lib/zx/result.h>.
    "//sdk/lib/driver/mmio/cpp",
    "//zircon/system/ulib/zx",
  ]
}

sdk_source_set("test_helper") {
  category = "internal"
  sdk_name = "mmio-test-helper"
  sources = [ "test-helper.h" ]
  deps = [ "//sdk/lib/driver/mmio/testing/cpp" ]

  # We want internal SDK elements to have their include path similar when
  # used through an SDK (eg Bazel SDk) or directly (GN/Ninja), so that source
  # code doesn't need to be changed when switching from one to the other.
  include_base = "//"
}
