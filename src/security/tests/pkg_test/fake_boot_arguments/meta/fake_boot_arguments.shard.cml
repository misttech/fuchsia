{
    include: [ "syslog/client.shard.cml" ],
    program: {
        runner: "elf",
        binary: "bin/fake_boot_arguments",

        // Note: Manifests including this shard must provide args:
        //   --system-image-path
    },
    capabilities: [
        {
            protocol: [ "fuchsia.boot.Items" ],
        },
        {
            dictionary: "boot_args",
            path: "/svc/fuchsia.component.runtime.DictionaryRouter",
        },
    ],
    use: [
        {
            protocol: [ "fuchsia.component.runtime.Capabilities" ],
            from: "framework",
        },
    ],
    expose: [
        {
            protocol: "fuchsia.boot.Items",
            from: "self",
        },
        {
            dictionary: "boot_args",
            from: "self",
        },
    ],
}
