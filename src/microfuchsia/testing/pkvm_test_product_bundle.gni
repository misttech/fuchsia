import("//build/assembly/assembled_system.gni")
import("//build/assembly/product_bundle.gni")
import("//zircon/kernel/phys/phys_executable.gni")  # For phys_toolchain

# Defines a product bundle intended for testing under pKVM, and in particular
# composition with gki_pkvm_boot_test(). It consists of the general arm64 boot
# shim and the provided ZBI.
#
# Parameters:
#
#  * zbi:
#    - Required: The ZBI to boot under pKVM.
#    - Type: label
#
template("pkvm_test_product_bundle") {
  assert(current_cpu == "arm64",
         "pKVM is not yet supported on non-arm64 architectures")

  assert(defined(invoker.zbi),
         "gki_pkvm_boot_test(${target_name}): `zbi` must be defined")

  main_target = target_name
  assembled_system_target =
      "_pkvm_test_product_bundle.${target_name}.assembled_system"

  assembled_system_namespace = "${target_name}.assembled_system"
  assembled_system(assembled_system_target) {
    visibility = [ ":*" ]
    testonly = true

    image_name = "fuchsia"
    namespace = assembled_system_namespace

    product_assembly_config_label = "//build/testing/boot_tests:product_config"
    assembly_mode = "test-zbi"

    # Generate pVM-style VBMeta.
    board_config_label = "//boards/pkvm:arm64"

    # The general arm64 linux boot shim is what we would use in practice under
    # pKVM.
    qemu_kernel = "//zircon/kernel/arch/arm64/phys/boot-shim:linux-arm64-boot-shim(${phys_toolchain})"
    kernel_zbi = invoker.zbi
  }

  product_bundle(main_target) {
    testonly = true
    name = main_target
    deps = [ ":${assembled_system_target}" ]
    system_a = "${target_out_dir}/${assembled_system_namespace}"
  }
}
