import("//build/components/fuchsia_unittest_package.gni")
import("//build/test.gni")

# Provides the additional_restricted_cpu variable.
import("//src/bringup/lib/restricted-machine/loadable.gni")
group("tests") {
  testonly = true
  deps = [
    ":example-gtests-package",
    ":example-tests-package",
    ":loadable-tests-package",
    ":machine-tests-package",
  ]
}

fuchsia_unittest_package("machine-tests-package") {
  deps = [ ":machine-tests" ]
  manifest = "meta/machine-tests.cml"
  test_specs = {
    log_settings = {
      max_severity = "ERROR"
    }
  }
}

test("machine-tests") {
  output_name = "machine-tests"

  sources = [ "machine-tests.cc" ]
  deps = [
    "//src/bringup/lib/restricted-machine",
    "//zircon/system/ulib/zxtest",
    "//zircon/system/ulib/zxtest:zxtest-streams",
  ]
}

fuchsia_unittest_package("loadable-tests-package") {
  deps = [ ":loadable-tests" ]
  manifest = "meta/loadable-tests.cml"
  test_specs = {
    log_settings = {
      max_severity = "ERROR"
    }
  }
}

test("loadable-tests") {
  output_name = "loadable-tests"

  sources = [ "loadable-tests.cc" ]
  deps = [
    "//sdk/fidl/fuchsia.ldsvc:fuchsia.ldsvc_cpp",
    "//sdk/lib/fdio",
    "//src/bringup/lib/restricted-machine",
    "//src/lib/symbolizer-markup",
    "//zircon/kernel/lib/arch",
    "//zircon/system/ulib/pretty",
    "//zircon/system/ulib/zxtest",
    "//zircon/system/ulib/zxtest:zxtest-streams",
  ]
  data_deps = [
    "loadable-tests-loadable:printf(//build/toolchain:linux_$current_cpu)",
    "loadable-tests-loadable(//build/toolchain:linux_$current_cpu)",
  ]
  if (additional_restricted_cpu != "") {
    data_deps += [
      "loadable-tests-loadable:printf(//build/toolchain:linux_$additional_restricted_cpu)",
      "loadable-tests-loadable(//build/toolchain:linux_$additional_restricted_cpu)",
    ]
  }
}

fuchsia_unittest_package("example-tests-package") {
  deps = [ ":example-tests" ]
  manifest = "meta/example-tests.cml"
}

test("example-tests") {
  output_name = "example-tests"

  sources = [ "example-tests.cc" ]
  deps = [
    "//src/bringup/lib/restricted-machine:zxtest",  # Use with zxtest logging
    "//zircon/system/ulib/affine",  # Target library under test
    "//zircon/system/ulib/zxtest",
    "//zircon/system/ulib/zxtest:zxtest-streams",
  ]
  data_deps = [ "example-loadable(//build/toolchain:linux_$current_cpu)" ]
  if (additional_restricted_cpu != "") {
    data_deps += [
      "example-loadable(//build/toolchain:linux_$additional_restricted_cpu)",
    ]
  }
}

fuchsia_unittest_package("example-gtests-package") {
  deps = [ ":example-gtests" ]
  manifest = "meta/example-gtests.cml"
}

test("example-gtests") {
  output_name = "example-gtests"

  sources = [ "example-gtests.cc" ]
  deps = [
    "//src/bringup/lib/restricted-machine",
    "//src/lib/fxl/test:gtest_main",
    "//zircon/system/ulib/affine",  # Target library under test
  ]
  data_deps = [ "example-loadable(//build/toolchain:linux_$current_cpu)" ]
  if (additional_restricted_cpu != "") {
    data_deps += [
      "example-loadable(//build/toolchain:linux_$additional_restricted_cpu)",
    ]
  }
}
