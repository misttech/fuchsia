import("//build/components.gni")
import("//build/rust/rustc_test.gni")

template("audio_device_registry_enumeration_test") {
  assert(defined(invoker.config),
         "config must be defined for audio_device_registry_enumeration_test")

  _test_component_target =
      "audio-device-registry-enumeration-test-${target_name}"
  _config_target = "${target_name}_config"
  _bin_target = "${target_name}_bin"

  rustc_test(_bin_target) {
    name = "audio_device_registry_enumeration_test_bin"
    edition = "2024"
    source_root = "//src/media/audio/services/device_registry/testing/enumeration/src/main.rs"
    sources = [ "//src/media/audio/services/device_registry/testing/enumeration/src/main.rs" ]
    deps = [
      "//sdk/fidl/fuchsia.audio.device:fuchsia.audio.device_rust",
      "//src/lib/fuchsia",
      "//src/lib/fuchsia-component",
      "//src/media/audio/lib/rust:fuchsia-audio",
      "//third_party/rust_crates:anyhow",
      "//third_party/rust_crates:log",
      "//third_party/rust_crates:serde",
      "//third_party/rust_crates:serde_json",
    ]
  }

  resource(_config_target) {
    sources = [ invoker.config ]
    outputs = [ "data/config.json" ]
  }

  fuchsia_test_component(_test_component_target) {
    manifest = "//src/media/audio/services/device_registry/testing/enumeration/meta/audio_device_registry_enumeration_test.cml"
    deps = [
      ":${_bin_target}",
      ":${_config_target}",
    ]

    # This test is intended to run against the live system audio stack
    test_type = "system"
  }

  _test_package_name = "audio_device_registry_enumeration_test_${target_name}"
  fuchsia_test_package(_test_package_name) {
    test_components = [ ":${_test_component_target}" ]
    if (defined(invoker.test_specs)) {
      test_specs = invoker.test_specs
    }
  }

  group(target_name) {
    testonly = true
    deps = [ ":${_test_package_name}" ]
  }
}
