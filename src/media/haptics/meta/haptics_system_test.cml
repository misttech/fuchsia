{
    include: [
        "sys/testing/rust_test_runner.shard.cml",
        "syslog/client.shard.cml",
    ],
    program: {
        binary: "bin/haptics_system_test_bin",
    },
    use: [
        {
            service: [ "fuchsia.hardware.haptics.Service" ],
            from: "parent",
        },
    ],
}
