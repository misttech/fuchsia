{
    include: [
        "//src/starnix/containers/container.shard.cml",
        "syslog/client.shard.cml",
    ],
    program: {
        runner: "starnix",
        features: [
            "container",
            "framebuffer",
        ],
        init: [],
        mounts: [
            "/:remote_bundle:data/system:nosuid,nodev,relatime",
            "/dev:devtmpfs::nosuid,relatime",
        ],
        rlimits: [ "RLIMIT_NOFILE=131072" ],
        name: "debian",
        startup_file_path: "",
    },

    // This child is created statically, to plumb Starnix into Fuchsia's
    // view system and input system.
    children: [
        {
            name: "launch_input",
            url: "#meta/launch_input.cm",
            startup: "eager",
            environment: "#daemon-env",
        },
    ],

    // This collection is where a starnix input test dynamically launches
    // `input_dump`, so that the test can have a handle to read the stdout
    // of `input_dump`.
    collections: [
        {
            name: "debian_userspace",
            environment: "#daemon-env",
            durability: "single_run",
        },
    ],
    use: [
        {
            protocol: [ "fuchsia.element.GraphicalPresenter" ],
            from: "parent",
        },
    ],
    expose: [
        {
            // Expose the `Realm` protocol, so that the starnix input test
            // can call `CreateChild()` to launch `input_dump.cm`.
            protocol: [ "fuchsia.component.Realm" ],
            from: "framework",
        },
    ],
}
