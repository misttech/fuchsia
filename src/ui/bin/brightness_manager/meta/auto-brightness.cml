{
    include: [ "syslog/client.shard.cml" ],
    program: {
        runner: "elf",
        binary: "bin/auto_brightness",
    },
    use: [
        { service: "fuchsia.hardware.backlight.Service" },
        { service: "fuchsia.hardware.light.LightService" },
        { service: "fuchsia.input.report.Service" },
    ],
}
