{
    include: [
        "//sdk/lib/sys/testing/elf_test_runner.shard.cml",
        "//sdk/lib/syslog/client.shard.cml",
    ],
    program: {
        binary: "bin/flatland-touch-integration-test-validator",

        // Exclude the transformed scene touch tests, so that this test component can run
        // within the test timeout.
        args: [ "--gtest_filter=-FlatlandTransformedTouchIntegrationTest.*" ],
    },
    use: [
        {
            protocol: [ "fuchsia.ui.test.context.ScenicRealmFactory" ],
        },
    ],
}
