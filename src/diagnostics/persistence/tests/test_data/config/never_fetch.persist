[
    {
        tag: 'test-component-metric',
        service_name: 'test-service',
        max_bytes: 10000,
        selectors: [
            'INSPECT:realm*/single_counter:root/samples:optional',
            'INSPECT:realm*/single_counter:root/samples:integer_1',
        ],

        // Set min_seconds_between_fetch to an outlandish duration such that
        // this tag will not be sampled again within a single test's runtime.
        min_seconds_between_fetch: 604800, // 1 week
    },
]
