[
    {
        tag: "reachability-link-state",
        service_name: "reachability",
        max_bytes: 20000,
        min_seconds_between_fetch: 60,
        selectors: [
            "INSPECT:core/network/reachability:root/telemetry/metadata/link_properties/index:*",
            "INSPECT:core/network/reachability:root/telemetry/metadata/link_state/index:*",
            "INSPECT:core/network/reachability:root/telemetry/time_series/link_properties_state/link_properties_v*_TYPE_wlanclient:*",
            "INSPECT:core/network/reachability:root/telemetry/time_series/link_properties_state/link_state_v*_TYPE_wlanclient:*",
        ],
    },
]
