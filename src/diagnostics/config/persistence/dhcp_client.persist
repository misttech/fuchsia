// TODO(https://fxbug.dev/42076420): Must be kept in sync with DHCP client's
// Inspect tree manually in lieu of automated testing solution.
[
    {
        tag: "clients",
        service_name: "dhcp-client",

        // Grows slowly: double and round observed max (4585 bytes)
        max_bytes: 10000,
        min_seconds_between_fetch: 60,
        selectors: [
            "INSPECT:core/network/netstack/dhcp-client:root/Clients",
        ],
    },
]
