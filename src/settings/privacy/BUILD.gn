import("//build/components.gni")
import("//build/rust/rustc_library.gni")

group("privacy") {
  testonly = true
  deps = [
    ":settings_privacy",
    ":tests",
  ]
}

rustc_library("settings_privacy") {
  name = "settings_privacy"
  with_unit_tests = true
  edition = "2024"

  visibility = [
    ":*",
    "//src/settings/service:*",
  ]

  deps = [
    "//sdk/fidl/fuchsia.settings:fuchsia.settings_rust",
    "//src/lib/async-utils",
    "//src/lib/fuchsia-async",
    "//src/settings/common:settings_common",
    "//src/settings/storage:settings_storage",
    "//third_party/rust_crates:anyhow",
    "//third_party/rust_crates:futures",
    "//third_party/rust_crates:log",
    "//third_party/rust_crates:serde",
    "//third_party/rust_crates:thiserror",
  ]

  sources = [
    "src/lib.rs",
    "src/privacy_controller.rs",
    "src/privacy_fidl_handler.rs",
    "src/types.rs",
  ]

  configs -= [ "//build/config/rust/lints:allow_unused_results" ]
  configs += [ "//build/config/rust/lints:clippy_warn_all" ]
}

fuchsia_unittest_package("settings_privacy_tests") {
  component_name = "settings_privacy_test"
  manifest = "meta/settings_privacy_tests.cml"
  deps = [ ":settings_privacy_test" ]
  test_specs = {
    log_settings = {
      max_severity = "ERROR"
    }
  }
}

group("tests") {
  testonly = true
  deps = [ ":settings_privacy_tests" ]
}
