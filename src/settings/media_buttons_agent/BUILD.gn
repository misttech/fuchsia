import("//build/components.gni")
import("//build/rust/rustc_library.gni")

group("media_buttons_agent") {
  testonly = true
  deps = [
    ":settings_media_buttons_agent",
    ":tests",
  ]
}

rustc_library("settings_media_buttons_agent") {
  name = "settings_media_buttons_agent"
  with_unit_tests = true
  edition = "2024"

  visibility = [
    ":*",
    "//src/settings/input:*",
    "//src/settings/service:*",
  ]

  deps = [
    "//sdk/fidl/fuchsia.ui.input:fuchsia.ui.input_rust",
    "//sdk/fidl/fuchsia.ui.policy:fuchsia.ui.policy_rust",
    "//src/lib/fidl/rust/fidl",
    "//src/lib/fuchsia-async",
    "//src/settings/common:settings_common",
    "//src/settings/media_buttons:settings_media_buttons",
    "//third_party/rust_crates:anyhow",
    "//third_party/rust_crates:futures",
    "//third_party/rust_crates:log",
  ]

  test_deps = [
    "//src/lib/fuchsia",
    "//src/settings/test_common:settings_test_common",
  ]

  sources = [ "src/lib.rs" ]

  configs -= [ "//build/config/rust/lints:allow_unused_results" ]
  configs += [ "//build/config/rust/lints:clippy_warn_all" ]
}

fuchsia_unittest_package("settings_media_buttons_agent_tests") {
  component_name = "settings_media_buttons_agent_test"
  manifest = "meta/settings_media_buttons_agent_tests.cml"
  deps = [ ":settings_media_buttons_agent_test" ]
  test_specs = {
    log_settings = {
      max_severity = "ERROR"
    }
  }
}

group("tests") {
  testonly = true
  deps = [ ":settings_media_buttons_agent_tests" ]
}
