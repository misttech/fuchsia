{
    include: [
        "//src/sys/test_runners/rust/default.shard.cml",
        "syslog/client.shard.cml",
    ],
    program: {
        binary: "bin/settings_common_lib_test",
    },
    use: [
        {
            directory: "pkg",
            from: "framework",
            rights: [ "r*" ],
            path: "/config/data",
            subdir: "settings_common_tests_config_data",
        },
    ],
}
