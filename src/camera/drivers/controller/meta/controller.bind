composite camera_controller;


primary parent "isp" {
  fuchsia.BIND_PROTOCOL == fuchsia.isp.BIND_PROTOCOL.DEVICE;
}

parent "gdc" {
  fuchsia.BIND_PROTOCOL == fuchsia.camera.BIND_PROTOCOL.GDC;
}

parent "ge2d" {
  fuchsia.BIND_PROTOCOL == fuchsia.camera.BIND_PROTOCOL.GE2D;
}
