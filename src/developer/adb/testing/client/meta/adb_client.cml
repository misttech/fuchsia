{
    include: [ "syslog/client.shard.cml" ],
    program: {
        runner: "elf",
        binary: "bin/adb_client",
    },
    capabilities: [
        { protocol: "fuchsia.testing.adb.Client" },
    ],
    use: [
        { service: "fuchsia.hardware.usb.device.Service" },
        { service: "fuchsia.hardware.usb.UsbService" },
    ],
    expose: [
        {
            protocol: "fuchsia.testing.adb.Client",
            from: "self",
        },
    ],
}
