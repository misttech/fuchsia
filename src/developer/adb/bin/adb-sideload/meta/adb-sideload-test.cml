{
    include: [
        "//src/connectivity/network/meta/isolated-network.shard.cml",
        "syslog/offer.shard.cml",
    ],
    children: [
        {
            name: "test_driver",
            url: "fuchsia-pkg://fuchsia.com/adb-sideload-test#meta/test-driver.cm",
        },
    ],
    offer: [
        {
            protocol: [ "fuchsia.posix.socket.Provider" ],
            from: "#netstack",
            to: "#test_driver",
        },
    ],
    expose: [
        {
            protocol: "fuchsia.test.Suite",
            from: "#test_driver",
        },
    ],
}
