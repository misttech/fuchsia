{
    offer: [
        {
            protocol: "fuchsia.posix.socket.Provider",
            from: "#network",
            to: "#adb-services",
        },
        {
            protocol: "fuchsia.recovery.android.Updater",
            from: "#system_recovery",
            to: "#adb-services",
        },
    ],
}
