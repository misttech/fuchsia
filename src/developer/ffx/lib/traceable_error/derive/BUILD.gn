import("//build/rust/rustc_macro.gni")

rustc_macro("lib") {
  name = "traceable_error_derive"
  version = "0.1.0"
  edition = "2024"

  deps = [
    "//third_party/rust_crates:proc-macro2",
    "//third_party/rust_crates:quote",
    "//third_party/rust_crates:syn",
  ]

  sources = [ "src/lib.rs" ]
}

group("tests") {
  testonly = true
  deps = [ "tests($host_toolchain)" ]
}
