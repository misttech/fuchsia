import("//src/developer/ffx/build/ffx_plugin.gni")

ffx_plugin("ffx_target_repository_rule") {
  sdk_category = "not-yet-specified"
  version = "0.1.0"
  edition = "2024"
  with_unit_tests = true

  plugin_deps = [ "replace:ffx_target_repository_rule_replace" ]

  args_sources = [ "src/args.rs" ]
  args_deps = [
    "//src/developer/ffx/core:lib",
    "//third_party/rust_crates:argh",
  ]
}

group("tests") {
  testonly = true

  deps = [ ":ffx_target_repository_rule_tests" ]
}
