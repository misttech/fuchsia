{
  "name": "structured-config",
  "description": "Verifies component configuration according to configured assertions.",
  "examples": [
    "To verify structured config on your current build:\n\n    $ ffx scrutiny verify structured-config \\\n        --product-bundle $(fx get-build-dir)/obj/build/images/fuchsia/product_bundle \\\n        --policy path/to/policy\n        --component_tree_config path/to/config"
  ],
