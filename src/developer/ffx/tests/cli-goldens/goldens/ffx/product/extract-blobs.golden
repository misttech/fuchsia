    {
      "kind": {
        "Option": {
          "arg_name": "delivery-blob-type"
        }
      },
      "optionality": "optional",
      "long": "--delivery-blob-type",
      "short": "d",
      "description": "specify the delivery blob type to compress extracted blobs to. If not specified, raw uncompressed blobs are returned.",
