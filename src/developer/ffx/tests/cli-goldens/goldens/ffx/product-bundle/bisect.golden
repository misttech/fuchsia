{
  "name": "bisect",
  "description": "Generate a list of released versions between [--from-success] and [--to-failure] for every artifact contained within the given product bundle (e.g. platform, product, board). Assemble intermediate product bundles using combinations of the artifacts, and facilitate running tests on those PBs to quickly identify which artifact is the source of a bug or behavior change.",
  "examples": [],
  "flags": [
    {
      "kind": "Switch",
      "optionality": "optional",
      "long": "--help",
      "short": null,
      "description": "display usage information",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "from-success"
        }
      },
      "optionality": "required",
      "long": "--from-success",
      "short": null,
      "description": "known-good version of the product bundle. The bisection search window begins here.",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "to-failure"
        }
      },
      "optionality": "required",
      "long": "--to-failure",
      "short": null,
      "description": "known-bad version of the product bundle. The bisection search window ends here.",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "slot"
        }
      },
      "optionality": "optional",
      "long": "--slot",
      "short": null,
      "description": "slot to bisect over (a or r). Defaults to slot A.",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "strategy"
        }
      },
      "optionality": "optional",
      "long": "--strategy",
      "short": null,
      "description": "search strategy to use. Defaults to \"AllDimensions\", which bisects across all pb artifact types (platform, product, board...) simultaneously.",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "out-dir"
        }
      },
      "optionality": "optional",
      "long": "--out-dir",
      "short": null,
      "description": "directory to write assembled images and other artifacts. Defaults to ~/<plan_directory>/out",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "gen-dir"
        }
      },
      "optionality": "optional",
      "long": "--gen-dir",
      "short": null,
      "description": "directory to write intermediate files. Defaults to ~/<plan_directory>/gen",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "auth"
        }
      },
      "optionality": "optional",
      "long": "--auth",
      "short": null,
      "description": "authentication method to use.",
      "hidden": false
    }
  ],
  "notes": [],
  "commands": [],
  "positionals": [
    {
      "name": "name",
      "description": "name of the product bundle being bisected.",
      "optionality": "required",
      "hidden": false
    }
  ],
  "error_codes": []
}