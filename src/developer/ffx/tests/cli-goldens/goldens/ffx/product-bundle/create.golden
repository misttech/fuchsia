{
  "name": "create",
  "description": "Construct a product bundle using a platform, product config, and board config.",
  "examples": [
    "// Create a minimal.arm64 product bundle in a local fuchsia checkout.\nffx product-bundle create --product-config minimal --board-config arm64\n\n// This is shorthand for the above command.\nffx product-bundle create minimal.arm64\n    ",
    "// Create a minimal.arm64 product bundle using prebuilts in CIPD.\nffx product-bundle create \\\n    --platform 29.20250826.6.1 \\\n    --product-config minimal \\\n    --board-config cipd://fuchsia/assembly/boards/arm64@29.20250826.6.1\n    "
  ],
  "flags": [
    {
      "kind": "Switch",
      "optionality": "optional",
      "long": "--help",
      "short": null,
      "description": "display usage information",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "platform"
        }
      },
      "optionality": "optional",
      "long": "--platform",
      "short": null,
      "description": "the platform artifacts to use. See PLATFORM_ARTIFACT below.",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "product-config"
        }
      },
      "optionality": "optional",
      "long": "--product-config",
      "short": null,
      "description": "the product config to use. See ARTIFACT below.",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "board-config"
        }
      },
      "optionality": "optional",
      "long": "--board-config",
      "short": null,
      "description": "the board config to use. See ARTIFACT below.",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "output-name"
        }
      },
      "optionality": "optional",
      "long": "--output-name",
      "short": null,
      "description": "the name to add to the output product bundle. Defaults to product_config.board_config.",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "output-version"
        }
      },
      "optionality": "optional",
      "long": "--output-version",
      "short": null,
      "description": "the version to add to the output product bundle.",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "tuf-keys"
        }
      },
      "optionality": "optional",
      "long": "--tuf-keys",
      "short": null,
      "description": "the tuf keys to use.",
      "hidden": false
    },
    {
      "kind": "Switch",
      "optionality": "optional",
      "long": "--stage",
      "short": null,
      "description": "prepare the assembly inputs, but do not run assembly yet.",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "out"
        }
      },
      "optionality": "optional",
      "long": "--out",
      "short": null,
      "description": "the location to write the product bundle to.",
      "hidden": false
    }
  ],
  "notes": [
    "PLATFORM_ARTIFACT formats:\n  <omitted>: in a fuchsia checkout, use locally built platform\n\n  latest: use latest prebuilt platform from CIPD\n\n  29.20250812.4.1: version of a prebuilt platform in\n    https://chrome-infra-packages.appspot.com/p/fuchsia/assembly/platform/\n\n  path/to/platform: local path to a platform\n    ",
    "ARTIFACT formats:\n  <name>: in a fuchsia checkout, use locally built artifact by its name\n\n  cipd://<cipd-package>@<cipd-tag>: cipd url for a prebuilt artifact.\n    `latest` can be used as <cipd-tag> to fetch the newest artifact.\n\n  path/to/artifact: a path to a locally built artifact\n    "
  ],
  "commands": [],
  "positionals": [
    {
      "name": "product_config_board_config_combo",
      "description": "product_config.board_config combination to build when inside a fuchsia checkout.",
      "optionality": "optional",
      "hidden": false
    }
  ],
  "error_codes": []
