{
  "name": "create",
  "description": "Construct a product bundle using a platform, product config, and board config.",
  "examples": [
    "// Create a minimal.arm64 product bundle in a local fuchsia checkout.\nffx product-bundle create --product-config minimal --board-config arm64\n\n// This is shorthand for the above command.\nffx product-bundle create minimal.arm64\n    ",
    "// Create a minimal.arm64 product bundle using prebuilts in CIPD.\nffx product-bundle create \\\n    --platform 29.20250826.6.1 \\\n    --product-config minimal \\\n    --board-config cipd://fuchsia/assembly/boards/arm64@29.20250826.6.1\n    ",
    "// Create a minimal.vim3 product bundle using a board config from MOS.\nffx product-bundle create \\\n    --platform 29.20250826.6.1 \\\n    --product-config minimal \\\n    --board-config mos://fuchsia/boards/vim3@29.20250916.6.1\n    "
  ],
  "flags": [
    {
      "kind": "Switch",
      "optionality": "optional",
      "long": "--help",
      "short": null,
      "description": "display usage information",
      "hidden": false
    },
    {
