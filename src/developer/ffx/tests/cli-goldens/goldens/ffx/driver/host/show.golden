{
  "name": "show",
  "description": "Show details about a specific drivers host",
  "examples": [
    "To show information about a specific driver host:\n\n    $ driver host show <PID>"
  ],
  "flags": [
    {
      "kind": "Switch",
      "optionality": "optional",
      "long": "--help",
      "short": null,
      "description": "display usage information",
      "hidden": false
    },
    {
      "kind": "Switch",
      "optionality": "optional",
      "long": "--select",
      "short": "s",
      "description": "if this exists, the user will be prompted for a component to select.",
      "hidden": false
    },
    {
      "kind": "Switch",
      "optionality": "optional",
      "long": "--runtime",
      "short": "r",
      "description": "whether to print driver runtime info for the driver host.",
      "hidden": false
    },
    {
      "kind": "Switch",
      "optionality": "optional",
      "long": "--stack-trace",
      "short": "t",
      "description": "whether to print stack traces for the driver host.",
      "hidden": false
    }
  ],
  "notes": [],
  "commands": [],
  "positionals": [
    {
      "name": "pid_or_name",
      "description": "the koid or name of the driver host to show.",
      "optionality": "required",
      "hidden": false
    }
  ],
  "error_codes": [
    {
      "code": 1,
      "description": "Failed to connect to the driver development service"
    }
  ]
}