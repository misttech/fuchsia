{
  "name": "enable",
  "description": "Enables the given driver, reverting a disable action.",
  "examples": [
    "To enable a driver\n\n    $ driver enable 'fuchsia-pkg://fuchsia.com/example_driver#meta/example_driver.cm'"
  ],
  "flags": [
    {
      "kind": "Switch",
      "optionality": "optional",
      "long": "--help",
      "short": null,
      "description": "display usage information",
      "hidden": false
    },
    {
      "kind": "Switch",
      "optionality": "optional",
      "long": "--select",
      "short": "s",
      "description": "if this exists, the user will be prompted for a component to select.",
      "hidden": false
    }
  ],
  "notes": [
    "This is only meant to revert a DisableDriver action. After this call, the driver will be considered for matching to nodes again."
  ],
  "commands": [],
  "positionals": [
    {
      "name": "url",
      "description": "component URL of the driver to be enabled.",
      "optionality": "required",
      "hidden": false
    }
  ],
  "error_codes": [
    {
      "code": 1,
      "description": "Failed to connect to the driver development service"
    }
  ]
}