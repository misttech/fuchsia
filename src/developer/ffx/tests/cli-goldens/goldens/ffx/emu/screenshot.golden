{
  "name": "screenshot",
  "description": "Take a screenshot of the emulator's primary display.",
  "examples": [
    "Capture a screenshot from the default emulator:\n  $ ffx emu screenshot --output capture.png\n\nCapture and save to a specific directory using the short flag:\n  $ ffx emu screenshot -o ./captures/debug.png\n\nCapture and save to an absolute path:\n  $ ffx emu screenshot --output /tmp/screenshot.png\n\nCapture from a specific emulator instance:\n  $ ffx emu screenshot --output result.png fuchsia-emulator"
  ],
  "flags": [
    {
      "kind": "Switch",
      "optionality": "optional",
      "long": "--help",
      "short": null,
      "description": "display usage information",
      "hidden": false
    },
    {
      "kind": {
        "Option": {
          "arg_name": "output"
        }
      },
      "optionality": "required",
      "long": "--output",
      "short": "o",
      "description": "path to save the screenshot. Relative (to the current directory) or absolute paths are both supported. The output will always be in PNG format.",
      "hidden": false
    }
  ],
  "notes": [
    "The screenshot is captured as a PNG file in RGB color space.\nThe resolution is the same as the emulator's primary display device.\n\nThis command will fail if:\n- The emulator is not in the 'Running' state.\n- A virtual display is not enabled in the emulator configuration.\n- The output path already exists.\n- The parent directory is not writable.\n\nIf the parent directory of the output path does not exist, ffx will\nattempt to create it automatically."
  ],
  "commands": [],
  "positionals": [
    {
      "name": "name",
      "description": "name of the emulator instance to take a screenshot on. If not specified, the default instance is used. See a list of available instances by running `ffx emu list`.",
      "optionality": "optional",
      "hidden": false
    }
  ],
  "error_codes": []
}