{
    capabilities: [
        { dictionary: "toolbox" },
        { dictionary: "toolbox-directories" },
    ],
    expose: [
        {
            dictionary: "toolbox",
            from: "self",
        },
        {
            dictionary: "toolbox-directories",
            from: "self",
        },
    ],
}
