group("debug") {
  testonly = true

  deps = [
    "debug_agent",
    "ipc",
    "shared",
  ]
}

group("tests") {
  testonly = true

  deps = [
    "debug_agent:tests",
    "e2e_tests/dap_integration_tests:tests",
    "zxdb:tests",
  ]
  if (target_cpu != "riscv64") {
    deps += [ "e2e_tests:tests" ]
  }
}
