{
    "name": "maximal_board",
    "arch": "arm64",
    "hardware_info": {
        "name": "maximal_hw",
        "vendor_id": 42,
        "product_id": 43,
        "revision": 44
    },
    "provided_features": [
        "feature1",
        "feature2"
    ],
    "zbi_extra_items": "zbi_extra_items.zbi",
    "devicetree": "devicetree.dtb",
    "devicetree_overlay": "devicetree_overlay.dtbo",
    "partitions_config": "partitions_config",
    "filesystems": {
        "zbi": {
            "compression": "zstd.12",
            "postprocessing_script": {
                "board_script_path": "scripts/postprocess.sh",
                "args": [
                    "arg1",
                    "arg2"
                ],
                "inputs": {
                    "scripts/input1.txt": "scripts/input1.txt"
                }
            }
        },
        "vbmeta": {
            "style": "android-pvm-auto",
            "key": "keys/vbmeta_key.pem",
            "key_metadata": "keys/vbmeta_key_metadata.bin",
            "additional_descriptors": [
                {
                    "name": "desc1",
                    "size": 1024,
                    "flags": 1,
                    "min_avb_version": "1.0"
                }
            ]
        },
        "fxfs": {
            "size_bytes": 1073741824,
            "size_checker_maximum_bytes": 1000000000,
            "blob_maximum_bytes": {
                "eng": 500000000,
                "userdebug": 400000000,
                "user": 300000000
            },
            "data_maximum_bytes": 200000000,
            "blob_format": "lz4"
        },
        "fvm": {
            "slice_size": 1048576,
            "truncate_to_length": 2147483648,
            "blobfs": {
                "size_checker_maximum_bytes": 800000000,
                "build_time_maximum_bytes": 700000000,
                "maximum_bytes": 900000000,
                "minimum_inodes": 1000,
                "minimum_data_bytes": 1000000
            },
            "minfs": {
                "maximum_bytes": 500000000
            },
            "sparse_output": {
                "max_disk_size": 4294967296
            },
            "nand_output": {
                "max_disk_size": 2147483648,
                "compress": true,
                "block_count": 2048,
                "oob_size": 64,
                "page_size": 4096,
                "pages_per_block": 64
            },
            "fastboot_output": {
                "compress": true,
                "truncate_to_length": 2147483648
            }
        },
        "gpt": "allow_multiple",
        "block_devices": [
            {
                "device": "device1",
                "from": {
                    "label": "label1",
                    "parent": "gpt"
                }
            }
        ],
        "watch_deprecated_v1_drivers": true,
        "gpt_all": true,
        "merge_super_and_userdata": true
    },
    "input_bundles": {
        "bundle1": "input_bundles/bundle1"
    },
    "kernel": {
        "contiguous_physical_pages": true,
        "serial_mode": "legacy",
        "quiet_early_boot": true,
        "arm64_event_stream_enable": true,
        "serial": "serial_port",
        "scheduler_prefer_little_cpus": true,
        "halt_on_panic": true,
        "allow_debug_uart_suspend": true
    },
    "platform": {
        "connectivity": {
            "network": {
                "netsvc_interface": "eth0"
            }
        },
        "development_support": {
            "enable_debug_access_port_for_soc": "amlogic-t931g"
        },
        "graphics": {
            "display": {
                "rotation": 90,
                "rounded_corners": true
            }
        },
        "sysmem_defaults": {
            "contiguous_memory_size": {
                "fixed": 1048576
            },
            "protected_memory_size": {
                "percent": 5
            },
            "contiguous_guard_pages_unused": true
        }
    },
    "global_platform_tee_trusted_app_guids": [
        "00000000-0000-0000-0000-000000000000"
    ],
    "release_info": {
        "info": {
            "name": "maximal_release",
            "repository": "fuchsia",
            "version": "1.0.0"
        },
        "bib_sets": [
            {
                "name": "maximal_bib_set",
                "repository": "fuchsia",
                "version": "1.0.0"
            }
        ]
    }
}
