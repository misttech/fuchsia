import("//build/components.gni")
import("//build/rust/rustc_binary.gni")
import("//build/rust/rustc_library.gni")
import("//build/rust/rustc_test.gni")

rustc_library("src_lib_fuchsia_testing") {
  edition = "2024"
  sources = [ "src/lib.rs" ]
  deps = [
    "//third_party/rust_crates:argh",
    "//third_party/rust_crates:log",
  ]
}

template("standalone_test") {
  assert(defined(invoker.type))

  if (invoker.type == "binary") {
    _template = "rustc_binary"
  } else if (invoker.type == "test") {
    _template = "rustc_test"
  } else {
    assert(false, "`type` must be either 'binary' or 'test'")
  }

  _test_name = "src_lib_fuchsia_${target_name}"
  _filename = target_name + ".rs"

  _extra_deps = []
  if (defined(invoker.deps)) {
    _extra_deps = invoker.deps
  } else {
    not_needed(invoker, "*")
  }

  target(_template, _filename) {
    edition = "2024"
    output_name = _test_name
    source_root = _filename
    sources = [ source_root ]
    deps = [
             ":src_lib_fuchsia_testing",
             "//src/lib/fuchsia",
           ] + _extra_deps
  }

  _manifest_name = _test_name + "_manifest"
  _manifest_path = "${target_gen_dir}/${_manifest_name}.cml"
  generated_file(_manifest_name) {
    testonly = true
    outputs = [ _manifest_path ]
    output_conversion = "json"
    contents = {
      include = [ "syslog/client.shard.cml" ]
      if (invoker.type == "binary") {
        include += [ "//sdk/lib/sys/testing/elf_test_runner.shard.cml" ]
      } else if (invoker.type == "test") {
        include += [ "//src/sys/test_runners/rust/default.shard.cml" ]
      }
      program = {
        binary = "bin/" + _test_name
      }
    }
  }

  _package_name = _test_name + "_package"
  fuchsia_unittest_package(_package_name) {
    package_name = _test_name
    manifest = _manifest_path
    deps = [
      ":$_filename",
      ":$_manifest_name",
    ]
  }

  group(target_name) {
    testonly = true
    deps = [
      ":${_filename}($host_toolchain)",
      ":${_package_name}",
    ]
  }
}

