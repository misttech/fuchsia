import("//build/components.gni")
import("//build/rust/rustc_binary.gni")
import("//build/rust/rustc_test.gni")

rustc_test("bin") {
  output_name = "log_return_value_test"
  edition = "2024"
  testonly = true
  deps = [
    "//src/lib/diagnostics/data/rust",
    "//src/lib/diagnostics/reader/rust",
    "//src/lib/fuchsia",
    "//src/lib/fuchsia-async",
    "//third_party/rust_crates:futures-util",
  ]

  sources = [ "src/lib.rs" ]
}

fuchsia_component("log_return_value_test") {
  testonly = true
  manifest = "meta/log_return_value_test.cml"
  deps = [ ":bin" ]
}

fuchsia_test_package("log_return_value_test_package") {
  deps =
      [ "//src/lib/fuchsia/tests/log_return_value/exit-with-error:component" ]
  test_specs = {
    log_settings = {
      max_severity = "ERROR"
    }
  }
  test_components = [ ":log_return_value_test" ]
}

group("tests") {
  testonly = true

  deps = [ ":log_return_value_test_package" ]
}
