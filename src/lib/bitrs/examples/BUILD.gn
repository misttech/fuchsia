import("//build/rust/rustc_binary.gni")

rustc_binary("basic-example") {
  edition = "2024"
  source_root = "basic.rs"
  sources = [ source_root ]
  deps = [ "//src/lib/bitrs" ]
}

group("examples") {
  testonly = true
  deps = [ ":basic-example" ]
}
