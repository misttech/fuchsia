import("//build/components.gni")
import("//build/rust/rustc_library.gni")

rustc_library("sorted_vec_map_rs") {
  edition = "2024"
  with_unit_tests = true

  sources = [
    "src/lib.rs",
    "src/sorted_vec_map.rs",
    "src/sorted_vec_set.rs",
  ]
  deps = [ "//third_party/rust_crates:serde" ]
  test_deps = [
    "//third_party/rust_crates:serde_json",
    "//third_party/rust_crates:test-case",
  ]
}

fuchsia_unittest_package("sorted_vec_map_rs_tests") {
  deps = [ ":sorted_vec_map_rs_test" ]
}

group("tests") {
  testonly = true

  deps = [ ":sorted_vec_map_rs_tests" ]
}
