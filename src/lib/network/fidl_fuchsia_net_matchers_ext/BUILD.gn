import("//build/components.gni")
import("//build/rust/rustc_library.gni")

template("fidl_fuchsia_net_matchers_ext_lib") {
  rustc_library(target_name) {
    if (defined(invoker.name)) {
      name = invoker.name
    }
    with_unit_tests = true
    edition = "2024"
    deps = [
             "//sdk/fidl/fuchsia.net:fuchsia.net_rust_common",
             "//sdk/fidl/fuchsia.net.interfaces:fuchsia.net.interfaces_rust_common",
             "//sdk/fidl/fuchsia.net.matchers:fuchsia.net.matchers_rust_common",
             "//src/connectivity/lib/net-types",
             "//src/lib/fidl/rust/fidl",
             "//src/lib/network/fidl_fuchsia_net_ext",
           ] + invoker.deps

    test_deps = [
      "//src/connectivity/lib/net-declare",
      "//third_party/rust_crates:test-case",
    ]
    if (defined(invoker.test_deps)) {
      test_deps += invoker.test_deps
    }

    if (defined(invoker.features)) {
      features = invoker.features
    }

    sources = [ "src/lib.rs" ]
    configs += [ "//build/config/rust/lints:deny_unused_results" ]
  }
}

fidl_fuchsia_net_matchers_ext_lib("fidl_fuchsia_net_matchers_ext") {
  deps = [
    "//src/lib/network/fidl_fuchsia_net_interfaces_ext",
    "//third_party/rust_crates:thiserror",
  ]
}

fidl_fuchsia_net_matchers_ext_lib("fidl_fuchsia_net_matchers_ext_fdomain") {
  features = [ "fdomain" ]
  deps = [
    "//src/lib/network/fidl_fuchsia_net_interfaces_ext:fidl_fuchsia_net_interfaces_ext_fdomain",
    "//third_party/rust_crates:thiserror",
  ]
}

fuchsia_unittest_package("fidl-fuchsia-net-matchers-ext-tests") {
  deps = [ ":fidl_fuchsia_net_matchers_ext_test" ]
}

fuchsia_unittest_package("fidl-fuchsia-net-matchers-ext-fdomain-tests") {
  deps = [ ":fidl_fuchsia_net_matchers_ext_fdomain_test" ]
}

group("tests") {
  testonly = true
  public_deps = [
    ":fidl-fuchsia-net-matchers-ext-fdomain-tests",
    ":fidl-fuchsia-net-matchers-ext-tests",
    ":fidl_fuchsia_net_matchers_ext_fdomain_test($host_toolchain)",
    ":fidl_fuchsia_net_matchers_ext_test($host_toolchain)",
  ]
}
