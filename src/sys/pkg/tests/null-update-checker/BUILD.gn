import("//build/components.gni")
import("//build/rust/rustc_test.gni")
import("//build/testing/environments.gni")

rustc_test("bin") {
  name = "null_update_checker_integration_test"
  edition = "2024"

  deps = [
    "//sdk/fidl/fuchsia.logger:fuchsia.logger_rust",
    "//sdk/fidl/fuchsia.update.channel:fuchsia.update.channel_rust",
    "//src/lib/fuchsia-async",
    "//src/lib/fuchsia-component-test",
    "//src/sys/lib/cm_rust",
    "//src/sys/lib/component-events",
    "//third_party/rust_crates:assert_matches",
    "//third_party/rust_crates:test-case",
  ]

  sources = [ "src/lib.rs" ]
  configs += [ "//build/config/rust/lints:clippy_warn_all" ]
}

fuchsia_test_component("component") {
  manifest = "meta/null-update-checker-integration-tests.cml"
  deps = [ ":bin" ]
  visibility = [ ":*" ]
}

fuchsia_test_package("package") {
  package_name = "null-update-checker-integration-tests"
  test_components = [ ":component" ]
  deps = [ "//src/sys/pkg/bin/null-update-checker:component" ]
}

group("hermetic_tests") {
  testonly = true
  public_deps = [ ":package" ]
}
