load("@platforms//host:constraints.bzl", "HOST_CONSTRAINTS")
load("//build/tools/bazel2gn/bazel_rules:defs.bzl", "idk_host_tool", "rustc_binary")

rustc_binary(
    name = "fake-omaha-client",
    srcs = [
        "src/main.rs",
    ],
    edition = "2021",
    target_compatible_with = HOST_CONSTRAINTS,
    with_unit_tests = True,
    deps = [
        "//src/lib/fuchsia-async",
        "//src/lib/fuchsia-hyper",
        "//third_party/rust_crates/vendor:argh",
        "//third_party/rust_crates/vendor:futures",
        "//third_party/rust_crates/vendor:hyper",
        "//third_party/rust_crates/vendor:hyper-rustls",
        "//third_party/rust_crates/vendor:omaha_client",
    ],
)

idk_host_tool(
    name = "bin",
    api_area = "Testing",
    category = "partner",
    idk_name = "fake-omaha-client",
    implementation_deps = [":fake-omaha-client"],
    target_compatible_with = HOST_CONSTRAINTS,
)
