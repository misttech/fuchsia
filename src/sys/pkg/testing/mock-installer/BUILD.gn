import("//build/components.gni")
import("//build/rust/rustc_library.gni")

template("mock_installer_library") {
  rustc_library(target_name) {
    version = "0.0.1"
    edition = "2024"
    with_unit_tests = true

    forward_variables_from(invoker,
                           [
                             "deps",
                             "test_deps",
                             "features",
                           ])

    deps += [
      "//src/lib/fuchsia-async",
      "//src/lib/fuchsia-sync",
      "//src/sys/pkg/lib/fidl-fuchsia-update-installer-ext",
      "//third_party/rust_crates:assert_matches",
      "//third_party/rust_crates:futures",
      "//third_party/rust_crates:pretty_assertions",
    ]

    sources = [ "src/lib.rs" ]
    configs += [ "//build/config/rust/lints:clippy_warn_all" ]
  }
}

mock_installer_library("mock-installer") {
  deps = [
    "//src/lib/fidl/rust/fidl",
    "//src/sys/pkg/fidl/fuchsia.update.installer:fuchsia.update.installer_rust_flex",
  ]

  test_deps = [ "//sdk/fidl/fuchsia.pkg:fuchsia.pkg_rust_flex" ]
}

mock_installer_library("mock-installer_fdomain") {
  deps = [
    "//src/lib/fdomain/client",
    "//src/sys/pkg/fidl/fuchsia.update.installer:fuchsia.update.installer_rust_fdomain_flex",
  ]
  test_deps = [
    "//sdk/fidl/fuchsia.pkg:fuchsia.pkg_rust_fdomain_flex",
    "//src/lib/fdomain/local",
  ]
  features = [ "fdomain" ]
}

group("hermetic_tests") {
  testonly = true
  deps = [ ":mock-installer-tests" ]
}

group("host_tests") {
  testonly = true
  deps = [ ":mock-installer_fdomain_test($host_toolchain)" ]
}

fuchsia_unittest_package("mock-installer-tests") {
  deps = [ ":mock-installer_test" ]
}
