// Fixed settings for use in Starnix syscall tests.
//
// Refer to //src/sys/time/timekeeper/config.shard.cml for the data schema.
{
    disable_delays: false,
    oscillator_error_std_dev_ppm: 15,
    max_frequency_error_ppm: 10,

    // Subpackage.
    primary_time_source_url: "dev_time_source#meta/dev_time_source.cm",
    initial_frequency_ppm: 1000000,
    monitor_uses_pull: false,
    back_off_time_between_pull_samples_sec: 500,

    // Effectively turn off the time source so that it does not introduce
    // added indeterminacy in the tests.
    first_sampling_delay_sec: 100000,
    primary_uses_pull: false,
    monitor_time_source_url: "",

    // The UTC vendor will start the clock.
    utc_start_at_startup: false,
    early_exit: false,
    power_topology_integration_enabled: false,

    // This is not used in Starnix.
    serve_test_protocols: false,

    // This should not be needed for tests.
    has_real_time_clock: false,
    utc_start_at_startup_when_invalid_rtc: false,

    // Required for Starnix tests.
    serve_fuchsia_time_alarms: true,
    has_always_on_counter: false,

    // Required for Starnix tests.
    serve_fuchsia_time_external_adjust: true,

    // We allow freely setting UTC within ~2-3 days of actual.
    utc_max_allowed_delta_past_sec: 200000,
    utc_max_allowed_delta_future_sec: 200000,
    use_connectivity: false,
}
