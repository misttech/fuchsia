import("//build/components.gni")
import("//build/rust/rustc_binary.gni")

group("utc-handle-vendor") {
  testonly = true
  deps = [
    ":bin",
    ":pkg",
    ":tests",
  ]
}

group("tests") {
  testonly = true
  public_deps = []
}

rustc_binary("bin") {
  name = "utc-handle-vendor"
  edition = "2021"

  sources = [ "src/main.rs" ]

  deps = [
    "//sdk/fidl/fuchsia.time:fuchsia.time_rust",
    "//sdk/rust/zx",
    "//src/lib/fuchsia",
    "//src/lib/fuchsia-component",
    "//src/lib/fuchsia-runtime",
    "//third_party/rust_crates:anyhow",
    "//third_party/rust_crates:futures",
    "//third_party/rust_crates:log",
  ]
}

fuchsia_component("default") {
  testonly = true
  manifest = "meta/default.cml"
  deps = [ ":bin" ]
}

# The resulting package URL will be:
#     fuchsia-pkg://fuchsia.com/utc-handle-vendor#meta/default.cm
fuchsia_package("pkg") {
  package_name = "utc-handle-vendor"
  testonly = true
  deps = [ ":default" ]
}
