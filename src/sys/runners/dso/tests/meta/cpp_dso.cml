{
    include: [ "syslog/client.shard.cml" ],
    program: {
        runner: "dso",
        binary: "lib/libcpp_dso.so",
        async: "true",

        // Currently, dso_runner is hard coded to expect this scheduler role
        scheduler_role: "fuchsia.ui.common_dispatcher",
    },
    capabilities: [
        { protocol: "fidl.test.dso.TestHelper" },
    ],
    use: [
        { protocol: "fidl.test.dso.TestHelper" },
    ],
    expose: [
        {
            protocol: "fidl.test.dso.TestHelper",
            from: "self",
        },
    ],
}
