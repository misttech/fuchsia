import("//build/components.gni")
import("//build/fidl/fidl.gni")
import("//build/rust/rustc_binary.gni")
import("//build/rust/rustc_test.gni")
import("//src/lib/dso/fuchsia_dso.gni")

fidl("fidl") {
  name = "fidl.test.dso"
  sources = [ "fidl/test.fidl" ]
}

fuchsia_rust_dso("rust_dso") {
  edition = "2024"
  sources = [ "src/rust_dso.rs" ]
  source_root = "src/rust_dso.rs"
  deps = [
    ":fidl_rust",
    "//sdk/fidl/fuchsia.process.lifecycle:fuchsia.process.lifecycle_rust",
    "//src/lib/fuchsia-component",
    "//third_party/rust_crates:anyhow",
    "//third_party/rust_crates:futures",
    "//third_party/rust_crates:log",
  ]
}

fuchsia_cc_dso("cpp_dso") {
  sources = [ "src/cpp_dso.cc" ]
  async = true
  deps = [
    ":fidl_cpp",
    "//sdk/fidl/fuchsia.process.lifecycle:fuchsia.process.lifecycle_cpp",
    "//sdk/lib/component/incoming/cpp",
    "//sdk/lib/component/outgoing/cpp",
    "//sdk/lib/syslog/cpp",
  ]
}

rustc_test("dso_integration_test_bin") {
  edition = "2024"
  source_root = "src/dso_integration_test.rs"
  sources = [ "src/dso_integration_test.rs" ]
  deps = [
    ":fidl_rust",
    "//sdk/fidl/fuchsia.component.decl:fuchsia.component.decl_rust",
    "//src/lib/fuchsia",
    "//src/lib/fuchsia-component",
    "//src/lib/fuchsia-component-test",
    "//src/sys/lib/cm_rust",
    "//third_party/rust_crates:futures",
  ]
}

fuchsia_component("dso_integration_test_component") {
  testonly = true
  manifest = "meta/dso_integration_test.cml"
  component_name = "dso_integration_test"
  deps = [ ":dso_integration_test_bin" ]
}

fuchsia_component("rust_dso_component") {
  testonly = true
  manifest = "meta/rust_dso.cml"
  component_name = "rust_dso"
  deps = [ ":rust_dso" ]
}

fuchsia_component("cpp_dso_component") {
  testonly = true
  manifest = "meta/cpp_dso.cml"
  component_name = "cpp_dso"
  deps = [ ":cpp_dso" ]
}

fuchsia_test_package("dso_runner_integration_tests") {
  test_components = [ ":dso_integration_test_component" ]
  deps = [
    ":cpp_dso_component",
    ":rust_dso_component",
    "//src/sys/runners/dso:component",
  ]
}

group("tests") {
  testonly = true
  deps = []

  # asan and coverage modes change the dso file paths, so just disable the test
  # on those builds. We could make it work by parameterizing the cml file to
  # account for the alternate paths, but it didn't seem worth the effort. We
  # still get coverage in these modes from the unit test.
  if (!is_asan && !is_coverage) {
    deps += [ ":dso_runner_integration_tests" ]
  }
}
