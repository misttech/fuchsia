{
    include: [ "syslog/client.shard.cml" ],
    program: {
        runner: "elf",
        binary: "bin/dict_trigger",
        args: [
            "--verify-dir",
            "/dict_dir",
        ],
    },
    capabilities: [
        { protocol: "fidl.test.components.Trigger" },
    ],
    use: [
        {
            directory: "dict_dir",
            from: "parent/outer",
            rights: [ "r*" ],
            path: "/dict_dir",
        },
        { protocol: "fidl.examples.routing.echo.Echo" },
        {
            protocol: "fuchsia.component.runtime.Capabilities",
            from: "framework",
        },
    ],
    expose: [
        {
            protocol: "fidl.test.components.Trigger",
            from: "self",
        },
    ],
}
