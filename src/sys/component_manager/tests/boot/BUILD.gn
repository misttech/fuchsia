import("//build/components.gni")
import("//build/rust/rustc_test.gni")

rustc_test("boot_integration_test_bin") {
  edition = "2024"
  testonly = true
  sources = [ "src/lib.rs" ]
  deps = [
    "//sdk/fidl/fuchsia.diagnostics:fuchsia.diagnostics_rust",
    "//sdk/fidl/fuchsia.sys2:fuchsia.sys2_rust",
    "//src/lib/diagnostics/reader/rust:lib",
    "//src/lib/fuchsia",
    "//src/lib/fuchsia-component-test",
    "//third_party/rust_crates:futures",
  ]
}

fuchsia_component("boot_test_realm") {
  testonly = true
  manifest = "meta/boot_test_realm.cml"
}

fuchsia_unittest_package("boot_integration_test") {
  manifest = "meta/boot_integration_test.cml"
  deps = [
    ":boot_integration_test_bin",
    ":boot_test_realm",
    "//src/diagnostics/archivist:archivist-for-embedding-bundle",
    "//src/sys/component_manager:component-manager-realm-builder-debug-cmp",
  ]
}

group("tests") {
  testonly = true
  deps = [ ":boot_integration_test" ]
}
