import("//build/go/go_library.gni")
import("//build/go/go_test.gni")

group("tests") {
  testonly = true
  deps = []
  if (host_os == "linux") {
    deps += [ ":power_reboot_bringup_test($host_toolchain)" ]
  }
}

if (is_linux) {
  go_library("lib") {
    testonly = true
    deps = [ "//src/tests/reboot:reboottest" ]
    sources = [ "power_reboot_bringup_test.go" ]
  }

  go_test("power_reboot_bringup_test") {
    embed = [ ":lib" ]
    non_go_deps =
        [ "//build/images/bringup:default_product_bundle_for_emulator.go" ]
  }
}
