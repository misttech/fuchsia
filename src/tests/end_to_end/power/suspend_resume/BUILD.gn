import("//build/testing/environments.gni")

import("//build/python/python_library.gni")
import("//build/python/python_mobly_test.gni")

assert(is_host, "the Python driver of the e2e test can only be run on the host")

# Test suite library. This isn't a complete test, it's a "mix-in" that provides
# a set of test cases without setup and teardown. To make an actual test, you
# need to create a separate `python_mobly_test` that extends
# `SuspendResumeTestSuite`.
python_library("suite") {
  library_name = "suspend_resume_suite"
  sources = [
    "__init__.py",
    "suite.py",
  ]
  testonly = true
  library_deps = [
    "//src/testing/end_to_end/honeydew",
    "//src/testing/end_to_end/mobly_base_tests/fuchsia_base_test",
  ]
}

python_mobly_test("suspend_resume_test") {
  main_source = "test.py"
  libraries = [ ":suite" ]

  environments = [ nelson_env ]
}
