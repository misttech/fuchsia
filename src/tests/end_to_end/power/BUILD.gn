import("//build/python/python_binary.gni")

source_set("power_utils") {
  testonly = true
  sources = [
    "power_utils.cc",
    "power_utils.h",
  ]
}

python_binary("monsoon_measure_power") {
  testonly = true
  main_source = "monsoon_measure_power.py"

  enable_mypy = false

  deps = [ "//third_party/PyMonsoon" ]
}
