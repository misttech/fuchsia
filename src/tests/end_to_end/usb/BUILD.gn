group("tests") {
  testonly = true
  deps = [
    "functional:tests",
    "stress:tests",
  ]
}

# For backward compatibility if anyone references these directly
group("usb_test") {
  testonly = true
  public_deps = [ "functional:usb_test($host_toolchain)" ]
}

group("usb_virtual_disconnect_test") {
  testonly = true
  public_deps = [ "stress:usb_virtual_disconnect_test($host_toolchain)" ]
}

group("usb_disconnect_test") {
  testonly = true
  public_deps = [ "stress:usb_disconnect_test($host_toolchain)" ]
}
