library test.conformance;

type Length2StringWrapper = struct {
    length_2_string string:2;
};

type StringWrapper = struct {
    str string;
};

type OptionalStringWrapper = struct {
    str string:optional;
};

type StringWithLimitInVector = struct {
    v vector<string:<2, optional>>;
};

type StringWithLimitInArray = struct {
    a array<string:2, 2>;
};

type StringWithLimitInTable = struct {
    t @generated_name("TableWithStringWithLimit") table {
        1: s string:2;
    };
};

type StringWithLimitInUnion = struct {
    u @generated_name("UnionWithStringWithLimit") flexible union {
        1: s string:2;
    };
};
