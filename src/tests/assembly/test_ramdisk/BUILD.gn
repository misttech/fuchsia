import("//build/assembly/assembled_system.gni")
import("//build/assembly/board_configuration.gni")
import("//build/assembly/product_assembly_configuration.gni")
import("//build/host.gni")

assert(!is_host, "This test must run in the default toolchain")

assembled_system("test_ramdisk") {
  testonly = true
  assembly_mode = "test-ramdisk"
  board_config_label = ":test_ramdisk_board"
  product_assembly_config_label = ":test_ramdisk_product"
  qemu_kernel = ":bootshim"
  kernel_zbi = ":ramdisk"
}

generated_file("bootshim") {
  contents = "bootshim"
  outputs = [ "$target_out_dir/bootshim" ]

  metadata = {
    emulator_support_aib_input = [
      {
        label = get_label_info(":ramdisk", "label_with_toolchain")
        path = rebase_path(outputs[0], root_build_dir)
      },
    ]
  }
}

generated_file("ramdisk") {
  contents = "ramdisk"
  outputs = [ "$target_out_dir/ramdisk" ]

  metadata = {
    kernel_aib_input = [
      {
        label = get_label_info(":ramdisk", "label_with_toolchain")
        zbi = rebase_path(outputs[0], root_build_dir)
      },
    ]
  }
}

product_assembly_configuration("test_ramdisk_product") {
  platform = {
    build_type = "eng"

    # assembly_mode=test-ramdisk requires image_mode=no_image.
    storage = {
      filesystems = {
        image_mode = "no_image"
      }
    }
  }
}

board_configuration("test_ramdisk_board") {
  partitions_config = "//boards/partitions:default"
  version = "test"
}
