import("//build/go/go_library.gni")
import("//build/go/go_test.gni")

group("tests") {
  testonly = true

  deps = []

  if (host_os == "linux") {
    deps += [ ":oom_tests($host_toolchain)" ]
  }
}

if (is_host) {
  go_test("oom_tests") {
    sources = [ "oom_test.go" ]
    deps = [ "//tools/emulator/emulatortest" ]
    non_go_deps = [ "//build/images/fuchsia:fuchsia_zbi_for_host_tests" ]
  }
}
