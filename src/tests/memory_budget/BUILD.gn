import("//build/go/go_library.gni")
import("//build/go/go_test.gni")
import("//build/images/paths.gni")

group("tests") {
  testonly = true

  deps = []

  if (host_os == "linux") {
    deps += [ ":memory_budget_tests($host_toolchain)" ]
  }
}

if (is_linux) {
  host_test_data("host_fvm") {
    visibility = [ ":*" ]

    deps = [ "//src/storage/bin/fvm" ]

    sources = [ "$root_out_dir/fvm" ]
    outputs = [ "$root_out_dir/test_data/tools/{{source_file_part}}" ]
  }

  host_test_data("vm_config") {
    visibility = [ ":*" ]

    sources = [ "test_data/vm_config.json" ]
    outputs = [ "$root_out_dir/test_data/config/{{source_file_part}}" ]
  }

  host_test_data("memory_budget_pb_data") {
    sources = [ files.product_bundle_dir ]
    deps = [ "//build/images/fuchsia:default_product_bundle_for_emulator.go" ]
  }

  go_library("lib") {
    testonly = true

    deps = [
      "//tools/emulator",
      "//tools/emulator/emulatortest",
      "//tools/lib/jsonutil",
      "//tools/virtual_device:proto",
    ]

    sources = [ "boot_test.go" ]
  }

  go_test("memory_budget_tests") {
    embed = [ ":lib" ]
    args = [
      "-product-bundle",
      rebase_path(files.product_bundle_dir, root_build_dir),
    ]
    non_go_deps = [
      ":host_fvm",
      ":memory_budget_pb_data",
      ":vm_config",
      "//src/storage/lib/sparse/rust:simg2img_sources",
    ]
  }
}
