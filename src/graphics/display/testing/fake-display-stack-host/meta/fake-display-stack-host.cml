{
    include: [
        "inspect/client.shard.cml",
        "syslog/client.shard.cml",
        "trace/use.shard.cml",
    ],
    program: {
        runner: "elf",
        binary: "bin/fake-display-stack-host",
    },
    capabilities: [
        { service: "fuchsia.hardware.display.Service" },
    ],
    use: [
        {
            protocol: [ "fuchsia.sysmem2.Allocator" ],
            from: "parent",
        },
    ],
    expose: [
        {
            service: "fuchsia.hardware.display.Service",
            from: "self",
        },
    ],
}
