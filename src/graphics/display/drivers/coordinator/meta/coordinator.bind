using fuchsia.display;
using fuchsia.hardware.display.engine;

if fuchsia.hardware.display.engine.Service == fuchsia.hardware.display.engine.Service.DriverTransport {
  true;
} else {
  fuchsia.BIND_PROTOCOL == fuchsia.display.BIND_PROTOCOL.ENGINE;
}
