{
    include: [ "syslog/client.shard.cml" ],
    program: {
        runner: "elf",
        binary: "bin/display-test",
    },
    use: [
        { service: "fuchsia.hardware.display.Service" },
        {
            protocol: [
                "fuchsia.sysinfo.SysInfo",
                "fuchsia.sysmem2.Allocator",
            ],
        },
    ],
}
