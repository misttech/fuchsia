{
    include: [
        // TODO(https://fxbug.dev/441642041): Stabilize zx_iob_create_shared_region
        // We use the zxtest runner for VDSO next which is currently required
        // for some of the IOB API which is used by logging fakes. We can switch
        // back to the default runner when it is stabilised.
        "//src/sys/test_runners/gtest/zxtest.shard.cml",
        "syslog/client.shard.cml",
    ],
    use: [
        {
            protocol: [
                "fuchsia.sysmem2.Allocator",
                "fuchsia.tracing.provider.Registry",
            ],
        },
        {
            protocol: [ "fuchsia.gpu.magma.test.VendorHelper" ],
            from: "parent",
        },
        {
            service: [
                "fuchsia.gpu.magma.PerformanceCounterService",
                "fuchsia.gpu.magma.Service",
                "fuchsia.gpu.magma.TrustedService",
            ],
        },
        {
            config: "fuchsia.gpu.test.GpuVendorId",
            from: "parent",
            key: "gpu_vendor_id_int",
            type: "uint32",
        },
        {
            config: "fuchsia.gpu.test.GpuVendorIdString",
            from: "parent",
            key: "gpu_vendor_id",
            type: "string",
            max_size: 128,
        },
        {
            config: "fuchsia.gpu.test.DisabledTestPattern",
            from: "parent",
            key: "disabled_test_pattern",
            type: "string",
            max_size: 1024,
        },
    ],
}
