import("//build/components.gni")
import("//src/lib/vulkan/vulkan.gni")

executable("vkconnect_bin") {
  testonly = true
  output_name = "vkconnect"
  sources = [ "vkconnect.cc" ]
  deps = [
    "//src/graphics/tests/common",
    "//src/graphics/tests/common:gtest_main",
    "//third_party/googletest:gtest",
  ]
}

fuchsia_test_component("vkconnect_test") {
  manifest = "meta/vkconnect.cml"
  test_type = "device"
  deps = [ ":vkconnect_bin" ]
}

fuchsia_test_package("vkconnect") {
  test_components = [ ":vkconnect_test" ]
  test_specs = {
    environments = vulkan_envs
  }
}
