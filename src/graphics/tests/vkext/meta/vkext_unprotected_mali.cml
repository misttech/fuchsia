{
    include: [
        "syslog/client.shard.cml",
        "vulkan/offer.shard.cml",
    ],
    children: [
        {
            name: "test",
            url: "vkext-test#meta/vkext-test-child.cm",
        },
    ],
    capabilities: [
        {
            config: "fuchsia.gpu.test.SupportSysmemYuv",
            type: "bool",
            value: true,
        },
        {
            config: "fuchsia.gpu.test.SupportSysmemYv12",
            type: "bool",
            value: true,
        },
    ],
    offer: [
        {
            config: "fuchsia.gpu.test.SupportSysmemYuv",
            from: "self",
            to: "#test",
        },
        {
            config: "fuchsia.gpu.test.SupportSysmemYv12",
            from: "self",
            to: "#test",
        },
    ],
    expose: [
        {
            protocol: "fuchsia.test.Suite",
            from: "#test",
        },
    ],
}
