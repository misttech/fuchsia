{
    children: [
        {
            name: "block-relay",
            url: "#meta/block-relay.cm",

            // Eager startup is required because block-relay does not expose any capabilities to
            // fshost.
            startup: "eager",
        },
    ],
    capabilities: [
        {
            // Export the volume Service to block-relay.  At most one instance will be published,
            // representing the device which contains the system partition table.
            service: [ "fuchsia.hardware.block.volume.Service" ],
        },
    ],
    offer: [
        {
            directory: [ "block" ],
            from: "self",
            to: [ "#block-relay" ],
        },
        {
            service: [ "fuchsia.hardware.block.volume.Service" ],
            from: "self",
            to: [ "#block-relay" ],
        },
    ],
    expose: [
        {
            // Also expose the volume Service to the test harness.
            service: [ "fuchsia.hardware.block.volume.Service" ],
            from: "self",
        },
    ],
}
