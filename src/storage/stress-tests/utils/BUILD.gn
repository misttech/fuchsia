import("//build/rust/rustc_library.gni")

rustc_library("utils") {
  name = "storage_stress_test_utils"
  edition = "2024"
  source_root = "mod.rs"
  testonly = true

  deps = [
    "//sdk/fidl/fuchsia.io:fuchsia.io_rust",
    "//sdk/fidl/fuchsia.storage.block:fuchsia.storage.block_rust",
    "//sdk/rust/zx",
    "//src/lib/fidl/rust/fidl",
    "//src/lib/fuchsia-fs",
    "//src/storage/fidl/fuchsia.fs.startup:fuchsia.fs.startup_rust",
    "//src/storage/lib/fs_management/rust:fs_management",
    "//src/storage/lib/ramdevice_client",
    "//src/storage/testing/rust:storage-isolated-driver-manager",
    "//third_party/rust_crates:log",  # for recording messages
    "//third_party/rust_crates:rand",
  ]

  sources = [
    "data.rs",
    "fvm.rs",
    "io.rs",
    "mod.rs",
  ]
}
