{
    include: [
        "inspect/client.shard.cml",
        "syslog/client.shard.cml",
    ],
    program: {
        runner: "driver",
        binary: "driver/toy_driver.so",
        bind: "meta/bind/toy-driver.bindbc",
    },
    capabilities: [
        { service: "fuchsia.testing.simple.Service" },
    ],
    use: [
        { service: "fuchsia.hardware.block.volume.Service" },
    ],
    expose: [
        {
            service: "fuchsia.testing.simple.Service",
            from: "self",
        },
    ],
}
