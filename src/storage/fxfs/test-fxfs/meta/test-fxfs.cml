{
    include: [
        "//src/storage/fs_test/meta/fxfs_crypt_test.shard.cml",
        "inspect/client.shard.cml",
        "syslog/client.shard.cml",
    ],
    program: {
        runner: "elf",
        binary: "bin/test-fxfs",
        use_next_vdso: "true",
    },
    children: [
        {
            name: "test-fxfs",
            url: "test-fxfs#meta/test-fxfs.cm",
        },
    ],
    capabilities: [
        {
            directory: "data",
            rights: [ "rw*" ],
            path: "/data",
        },
        {
            protocol: [
                "fuchsia.fshost.StarnixVolumeProvider",
                "fuchsia.test.fxfs.StarnixVolumeAdmin",
            ],
        },
        { dictionary: "starnix-volume" },
    ],
    use: [
        {
            config: "fuchsia.test.fxfs.DirentCacheSize",
            key: "dirent_cache_limit",
            type: "uint64",
            default: 2000,

            // Transitional is what's needed for component starts to not fail if not offered.
            availability: "transitional",
        },
    ],
    offer: [
        {
            protocol: "fuchsia.fshost.StarnixVolumeProvider",
            from: "self",
            to: "self/starnix-volume",
        },
    ],
    expose: [
        {
            directory: "data",
            from: "self",
        },
        {
            dictionary: "starnix-volume",
            from: "self",
        },
        {
            protocol: "fuchsia.test.fxfs.StarnixVolumeAdmin",
            from: "self",
        },
    ],
}
