import("//build/dist/resource.gni")

# An uncompressed erofs image with a few files in the root directory.
resource("simple_erofs_image") {
  sources = [
    "data/simple.erofs",
    "data/simple_512.erofs",
  ]
  outputs = [ "data/{{source_file_part}}" ]
}

# The raw source files that were packed into simple.erofs.
resource("simple_raw_files") {
  sources = [
    "data/simple/file1",
    "data/simple/photosynthesis",
    "data/simple/quantum",
  ]
  outputs = [ "data/simple/{{source_file_part}}" ]
}
