import "pw_bluetooth/hci_common.emb" as hci

[$default byte_order: "LittleEndian"]
[(cpp) namespace: "bt_hci_broadcom"]


enum BroadcomOpCode:
  [maximum_bits: 16]
  SET_BAUD_RATE                    = 0xFC18
  WRITE_SLEEP_MODE                 = 0xFC27
  LAUNCH_RAM                       = 0xFC4E
  READ_VERBOSE_CONFIG_VERSION_INFO = 0xFC79
  SET_DOWNLOAD_CONFIG              = 0xFE72
  SET_POWER_CAP                    = 0xFF00


struct CommandHeader:
  -- HCI Command packet header.
  0     [+2]  BroadcomOpCode  opcode
  $next [+1]  UInt            parameter_total_size


enum SleepMode:
  [maximum_bits: 8]
  DISABLED = 0x00
  UART     = 0x01
  RESERVED = 0x02
  USB      = 0x03


struct WriteSleepModeCmd:
  let hdr_size = CommandHeader.$size_in_bytes
  let parameter_size = $size_in_bytes-hdr_size
  0     [+hdr_size]  CommandHeader  header
  $next [+1]         SleepMode      mode
  $next [+1]         UInt           idle_threshold_host
  $next [+1]         UInt           idle_threshold_device
  $next [+1]         UInt           bt_wake_polarity
  $next [+1]         UInt           host_wake_polarity
  $next [+1]         UInt           sleep_during_sco
  $next [+1]         UInt           combine_sleep_and_lpm
  $next [+1]         UInt           tri_state_uart_before_sleep
  $next [+3]         UInt:8[3]      usb_flags
  $next [+1]         UInt           pulsed_host_wake


struct SetDownloadConfigCommand:
  let hdr_size = CommandHeader.$size_in_bytes
  let parameter_size = $size_in_bytes-hdr_size
  0     [+hdr_size]  CommandHeader  header
  $next [+1]         UInt           command_version
  $next [+1]         UInt           fast_download_mode


struct SetBaudRateCommand:
  let hdr_size = CommandHeader.$size_in_bytes
  let parameter_size = $size_in_bytes-hdr_size
  0     [+hdr_size]  CommandHeader  header
  $next [+2]         UInt           unused
  $next [+4]         UInt           baud_rate


struct ReadVerboseConfigVersionInfoCommandCompleteEvent:
  let hdr_size = hci.CommandCompleteEvent.$size_in_bytes
  0     [+hdr_size]  hci.CommandCompleteEvent  command_complete
  $next [+1]         hci.StatusCode            status
  $next [+1]         UInt                      chip_id


enum SetPowerCapSubOpCode:
  [maximum_bits: 8]
  SET = 0x01


enum SetPowerCapCmdFormatOpCode:
  [maximum_bits: 16]
  FORMAT_2 = 0x0002


struct SetPowerCapCommand:
  let hdr_size = CommandHeader.$size_in_bytes
  let parameter_size = $size_in_bytes-hdr_size
  0     [+hdr_size]  CommandHeader              header
  $next [+1]         SetPowerCapSubOpCode       sub_opcode
  $next [+2]         SetPowerCapCmdFormatOpCode cmd_format_opcode
  $next [+1]         UInt           chain_0_power_limit_br
  $next [+1]         UInt           chain_0_power_limit_edr
  $next [+1]         UInt           chain_0_power_limit_ble
  $next [+1]         UInt           chain_1_power_limit_br
  $next [+1]         UInt           chain_1_power_limit_edr
  $next [+1]         UInt           chain_1_power_limit_ble
  $next [+6]         UInt:8[6]      beamforming_cap
