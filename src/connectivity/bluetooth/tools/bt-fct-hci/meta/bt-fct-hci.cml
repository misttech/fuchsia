{
    include: [ "syslog/client.shard.cml" ],
    program: {
        runner: "elf",
        binary: "bin/bt-fct-hci",
    },
    use: [
        {
            // This service replaces the directory capability above.
            service: "fuchsia.hardware.bluetooth.Service",
        },
    ],
}
