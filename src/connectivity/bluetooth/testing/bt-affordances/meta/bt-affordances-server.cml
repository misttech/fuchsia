{
    include: [ "syslog/client.shard.cml" ],
    program: {
        runner: "elf",
        binary: "bin/bt-affordances-server-bin",
    },
    capabilities: [
        {
            protocol: [
                "fuchsia.bluetooth.affordances.CentralController",
                "fuchsia.bluetooth.affordances.GattClientController",
                "fuchsia.bluetooth.affordances.HostController",
                "fuchsia.bluetooth.affordances.PeerController",
                "fuchsia.bluetooth.affordances.PeripheralController",
            ],
        },
    ],
    use: [
        {
            protocol: [
                "fuchsia.bluetooth.le.Central",
                "fuchsia.bluetooth.le.PrivilegedPeripheral",
                "fuchsia.bluetooth.sys.Access",
                "fuchsia.bluetooth.sys.AddressLookup",
                "fuchsia.bluetooth.sys.HostWatcher",
            ],
        },
    ],
    expose: [
        {
            protocol: [
                "fuchsia.bluetooth.affordances.CentralController",
                "fuchsia.bluetooth.affordances.GattClientController",
                "fuchsia.bluetooth.affordances.HostController",
                "fuchsia.bluetooth.affordances.PeerController",
                "fuchsia.bluetooth.affordances.PeripheralController",
            ],
            from: "self",
        },
    ],
}
