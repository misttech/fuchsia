{
    children: [
        {
            name: "bt-affordances-server",
            url: "fuchsia-pkg://fuchsia.com/bt-affordances-server#meta/bt-affordances-server.cm",
            environment: "#core-env",
        },
    ],
    offer: [
        {
            protocol: [
                "fuchsia.bluetooth.le.Central",
                "fuchsia.bluetooth.le.PrivilegedPeripheral",
                "fuchsia.bluetooth.sys.Access",
                "fuchsia.bluetooth.sys.AddressLookup",
                "fuchsia.bluetooth.sys.HostWatcher",
            ],
            from: "#bluetooth-core",
            to: "#bt-affordances-server",
            source_availability: "unknown",
        },
        {
            protocol: [
                "fuchsia.bluetooth.affordances.HostController",
                "fuchsia.bluetooth.affordances.PeerController",
            ],
            from: "#bt-affordances-server",
            to: "self/toolbox",
            target_availability: "unknown",
        },
    ],
}
