{
    include: [
        "inspect/client.shard.cml",
        "syslog/client.shard.cml",
    ],
    program: {
        runner: "driver",
        binary: "driver/wlantap.so",
        bind: "meta/bind/wlantap-driver.bindbc",
        colocate: "true",
    },
    capabilities: [
        { service: "fuchsia.wlan.softmac.Service" },
        { service: "fuchsia.wlan.phy.Service" },
        { service: "fuchsia.wlan.tap.Service" },
    ],
    expose: [
        {
            service: "fuchsia.wlan.softmac.Service",
            from: "self",
        },
        {
            service: "fuchsia.wlan.phy.Service",
            from: "self",
        },
        {
            service: "fuchsia.wlan.tap.Service",
            from: "self",
        },
    ],
}
