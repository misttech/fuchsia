load(
    "@rules_fuchsia//fuchsia:defs.bzl",
    "fuchsia_package_resource",
)
load("@rules_license//rules:license.bzl", "license")

package(
    default_applicable_licenses = [":license"],
    default_visibility = ["//visibility:public"],
)

license(
    name = "license",
    package_name = "iwlwifi firmware",
    license_text = "//:prebuilt/connectivity/wlan/firmware/intel/iwlwifi/LICENCE.iwlwifi_firmware",
)

fuchsia_package_resource(
    name = "iwlwifi-firmware-iwlwifi-7265D-29",
    src = "//:prebuilt/connectivity/wlan/firmware/intel/iwlwifi/iwlwifi-7265D-29.ucode",
    dest = "lib/firmware/iwlwifi/iwlwifi-7265D-29.ucode",
)

fuchsia_package_resource(
    name = "iwlwifi-firmware-iwlwifi-8265-31",
    src = "//:prebuilt/connectivity/wlan/firmware/intel/iwlwifi/iwlwifi-8265-31.ucode",
    dest = "lib/firmware/iwlwifi/iwlwifi-8265-31.ucode",
)

fuchsia_package_resource(
    name = "iwlwifi-firmware-iwlwifi-9260-th-b0-jf-b0-43",
    src = "//:prebuilt/connectivity/wlan/firmware/intel/iwlwifi/iwlwifi-9260-th-b0-jf-b0-43.ucode",
    dest = "lib/firmware/iwlwifi/iwlwifi-9260-th-b0-jf-b0-43.ucode",
)

fuchsia_package_resource(
    name = "iwlwifi-firmware-iwlwifi-QuZ-a0-hr-b0-71",
