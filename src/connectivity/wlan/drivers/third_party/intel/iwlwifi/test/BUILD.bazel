load(
    "@rules_fuchsia//fuchsia:defs.bzl",
    "fuchsia_cc_test",
    "fuchsia_component_manifest",
    "fuchsia_test_component",
    "fuchsia_test_package",
)

package(default_visibility = ["//visibility:public"])

# List to hold the list of tests.
iwlwifi_tests = []

