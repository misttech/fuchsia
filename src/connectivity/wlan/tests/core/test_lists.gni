# These lists provide a level of indirection that allows
# product_bundle_test_groups to optionally exclude some tests. This
# could be a permanent exclusion because the product is missing
# features for the test to pass, or a temporary exclusion because a
# bug is causing the test to fail too often.

# These tests run as a blocking tryjob against every single CL anywhere
# in the tree. Therefore, we need to be extremely conservative with
# the tests we choose to run here, ensuring they give us sufficient
# signal for the amount of testbed load they'll require.
# Consider instead putting your test in `tests_for_wlan_cq`
core_tests_for_general_cq = []

# Only tests which do not interact with a AP or SoftAP can be run
# without a shield box. These tests can run against any DUT in
# the infra pool of devices, which are much less capacity-limited
# than the WLAN-specific shielded testbeds.
core_tests_for_general_cq_no_shield_box = [
  "//src/connectivity/wlan/tests/core:create_ap_iface_with_null_mac_test",
  "//src/connectivity/wlan/tests/core:create_ap_iface_with_particular_mac_test",
  "//src/connectivity/wlan/tests/core:create_client_iface_with_null_mac_test",
  "//src/connectivity/wlan/tests/core:create_client_iface_with_particular_mac_test",
  "//src/connectivity/wlan/tests/core:phy_existence_test",
]

# These tests run in blocking CI (~once per hour) as well as a blocking
# tryjob on any CL with "wlan" in a file path. We should strive for a
# representative sample of tests here for all our functionality, but
# we should optimize for maximum bang for our buck (e.g. add a
# reboot test here, but only for wpa2, not for every single security type).
core_tests_for_wlan_cq = [
  "//src/connectivity/wlan/tests/core:connect_to_ap_test",
  "//src/connectivity/wlan/tests/core:firmware_power_modes_test",
  "//src/connectivity/wlan/tests/core:sar_setting_test",

  # Though this test is defined in honeydew, it exercises wlan core
  "//src/testing/end_to_end/honeydew/honeydew/affordances/connectivity/wlan/wlan_core/tests/functional_tests",
]

# If you're writing a new test, add it to FYI first until it has a sufficient
# number of passing runs (either here in FYI or via `fx test-remote`). Tests in
# FYI don't cause any alerting if they break, so having the test here doesn't
# provide much of a safety net. Consider moving it to one of the CQ groups
# above.
core_tests_for_fyi = [
  "//src/connectivity/wlan/tests/core:roam_request_test_should_succeed",
  "//src/connectivity/wlan/tests/core:wlan_scan_test",
]

# Tests longer than ~20 minutes consume significant resources and significantly
# lengthen the cadence of the test runs. Split these tests out so we can run
# them at reduced frequency.
core_tests_for_fyi_long = []
