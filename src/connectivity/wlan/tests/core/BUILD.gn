# This is a helper group so developers can easily add all tests to their build.
# It is not run by infra. You should not directly add tests here, but rather to
# one of the other groups below so it runs in infra.
group("tests_host") {
  testonly = true
  public_deps = [
    ":tests_for_fyi",
    ":tests_for_fyi_long",
    ":tests_for_general_cq",
    ":tests_for_general_cq_no_shield_box",
    ":tests_for_wlan_cq",
  ]
}

group("tests_for_general_cq") {
  testonly = true
  public_deps = core_tests_for_general_cq  # Edit in test_lists.gni
}

group("tests_for_general_cq_no_shield_box") {
  testonly = true
  public_deps =
      core_tests_for_general_cq_no_shield_box  # Edit in test_lists.gni
}

group("tests_for_wlan_cq") {
  testonly = true
  public_deps = core_tests_for_wlan_cq  # Edit in test_lists.gni
}

group("tests_for_fyi") {
  testonly = true
  public_deps = core_tests_for_fyi  # Edit in test_lists.gni
}

group("tests_for_fyi_long") {
  testonly = true
  public_deps = core_tests_for_fyi_long  # Edit in test_lists.gni
}
