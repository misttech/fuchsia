# These lists provide a level of indirection that allows
# product_bundle_test_groups to optionally exclude some tests. This
# could be a permanent exclusion because the product is missing
# features for the test to pass, or a temporary exclusion because a
# bug is causing the test to fail too often.

wlancfg_tests_for_general_cq = [
  "//src/connectivity/wlan/tests/wlancfg:start_stop_client_connections_test",
]

# Only tests which do not interact with an AP or SoftAP can be run
# without a shield box. This distinction only matters for general
# CQ, where capacity is lower.
