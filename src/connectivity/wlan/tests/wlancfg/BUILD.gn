import("//build/python/python_mobly_test.gni")
import("//build/testing/environments.gni")
import("//build/testing/host_test_data.gni")

import("//src/connectivity/wlan/tests/wlancfg/test_lists.gni")
import("//src/testing/end_to_end/antlion/antlion_host_test.gni")
import("//src/testing/end_to_end/antlion/environments.gni")

assert(is_host, "WLAN end-to-end tests only supported for host testing")

antlion_host_test("regulatory_recovery_test") {
  main_source =
      "//src/connectivity/wlan/tests/wlancfg/RegulatoryRecoveryTest.py"
  libraries = [
    "//src/testing/end_to_end/mobly_base_tests:fuchsia_wlan_base_test",
    "//sdk/fidl/fuchsia.wlan.policy:fuchsia.wlan.policy_python",
  ]
}

antlion_host_test("start_stop_client_connections_test") {
  main_source =
      "//src/connectivity/wlan/tests/wlancfg/StartStopClientConnectionsTest.py"
  libraries = [
    "//src/testing/end_to_end/mobly_base_tests:fuchsia_wlan_base_test",
    "//sdk/fidl/fuchsia.wlan.policy:fuchsia.wlan.policy_python",
  ]
}

antlion_host_test("suggest_ap_mac_address_test") {
  main_source =
      "//src/connectivity/wlan/tests/wlancfg/SuggestApMacAddressTest.py"
  libraries = [
    "//src/testing/end_to_end/mobly_base_tests:fuchsia_wlan_base_test",
    "//sdk/fidl/fuchsia.net:fuchsia.net_python",
    "//sdk/fidl/fuchsia.wlan.policy:fuchsia.wlan.policy_python",
    "//sdk/fidl/fuchsia.wlan.product.deprecatedconfiguration:fuchsia.wlan.product.deprecatedconfiguration_python",
  ]
}

group("tests_in_fyi") {
  testonly = true
  public_deps = [ ":start_stop_client_connections_test" ]
}

group("tests_for_general_cq_shielded_dut_only") {
  testonly = true
  public_deps = wlancfg_tests_for_general_cq_shielded_dut_only
}
