# This is a helper group so developers can easily add all tests to their build. It is not run by
# infra. You should not directly add tests here, but rather to one of the other groups below so it
# runs in infra.
group("tests_host") {
  testonly = true
  public_deps = [
    ":tests_for_fyi",
    ":tests_for_general_cq",
    ":tests_for_general_cq_no_shield_box",
    ":tests_for_wlan_cq",
  ]
}

# These tests run as a blocking tryjob against every single CL anywhere
# in the tree. Therefore, we need to be extremely conservative with
# the tests we choose to run here, ensuring they give us sufficient
# signal for the amount of testbed load they'll require.
# Consider instead putting your test in `tests_for_wlan_cq`
group("tests_for_general_cq") {
  testonly = true
  public_deps = [ ":connect_to_ap_test" ]
}

# Only tests which do not interact with a AP or SoftAP can be run
# without a shield box. These tests can run against any DUT in
# the infra pool of devices, which are much less capacity-limited
# than the WLAN-specific shielded testbeds.
group("tests_for_general_cq_no_shield_box") {
  testonly = true
  public_deps = [
    ":iface_correctness_and_consistency_test",
    ":iface_lifecycle_test",
    ":wifi_chip_correctness_and_consistency_test",
    ":wifi_chip_existence_test",
    ":wlan_canary_test",
    ":wlan_driver_restart_test",
  ]
}

# These tests run in blocking CI (~once per hour) as well as a blocking
# tryjob on any CL with "wlan" in a file path. We should strive for a
# representative sample of tests here for all our functionality, but
# we should optimize for maximum bang for our buck (e.g. add a
# reboot test here, but only for wpa2, not for every single security type).
group("tests_for_wlan_cq") {
  testonly = true
  public_deps = [ ":apf_test" ]
}

# If you're writing a new test, add it to FYI first until it has a sufficient
# number of passing runs (either here in FYI or via `fx test-remote`). Tests in
# FYI don't cause any alerting if they break, so having the test here doesn't
# provide much of a safety net. Consider moving it to one of the CQ groups above.
group("tests_for_fyi") {
  testonly = true
  public_deps = []
}

# These tests don't cause alerting if they break, and are configured to
# upload performance data to fuchsiaperf via Catapult.
group("tests_for_fyi_performance") {
  testonly = true
  public_deps = [ ":create_client_iface_benchmark_test" ]
}
