{
    actions: [
        {
            type: "expect_pass",
            matchers: [
                "*",
            ],
        },
        {
            type: "expect_failure_with_err_logs",
            matchers: [
                "tcp::tcp_bind_with_zone_connect_unzoned_ns2",
                "tcp::tcp_socket_shutdown_listener_v4_ns2",
                "tcp::tcp_socket_shutdown_listener_v6_ns2",
                "udp::udp_recv_msg_postflight_fidl_ns3*",
                "udp::udp_send_msg_preflight*ns3*",
            ],
        },
        {
            type: "skip",
            matchers: [
                // TODO(https://fxbug.dev/319298842): Fails by timing out.
                // Reenable once Netstack2 uses the bound device when
                // connecting.
                "tcp::tcp_connect_bound_to_device_ns2",

                // Netstack2 does not propagate a number of ICMP error variants to TCP sockets.
                "tcp::tcp_*_icmp_error_ns2::phantomdata_ipv[46]_icmpv[46]parameterproblem_*",
                "tcp::tcp_*_icmp_error_ns2::phantomdata_ipv[46]_icmptimeexceeded_*",
                "tcp::tcp_*_icmp_error_ns2::phantomdata_ipv6_icmpdestunreachable_default_icmpv6destunreachablecode_addrunreachable_expects_libc_ehostunreach",
                "tcp::tcp_*_icmp_error_ns2::phantomdata_ipv6_icmpdestunreachable_default_icmpv6destunreachablecode_beyondscope_expects_libc_ehostunreach",
                "tcp::tcp_*_icmp_error_ns2::phantomdata_ipv6_icmpdestunreachable_default_icmpv6destunreachablecode_commadministrativelyprohibited_expects_libc_eacces",
                "tcp::tcp_*_icmp_error_ns2::phantomdata_ipv6_icmpdestunreachable_default_icmpv6destunreachablecode_rejectroute_expects_libc_eacces",
                "tcp::tcp_*_icmp_error_ns2::phantomdata_ipv6_icmpdestunreachable_default_icmpv6destunreachablecode_srcaddrfailedpolicy_expects_libc_eacces",
            ],
        },
    ],
}
