import("//build/rust/rustc_test.gni")

rustc_test("sockets") {
  edition = "2024"
  output_name = "netstack_sockets_fidl_test"
  deps = [
    "//sdk/fidl/fuchsia.net:fuchsia.net_rust",
    "//sdk/fidl/fuchsia.net.matchers:fuchsia.net.matchers_rust",
    "//sdk/fidl/fuchsia.net.sockets:fuchsia.net.sockets_rust",
    "//src/connectivity/network/testing/netemul/rust:lib",
    "//src/connectivity/network/tests/integration/common:netstack_testing_common",
    "//src/connectivity/network/tests/integration/macros:netstack_testing_macros",
    "//src/lib/fidl/rust/fidl",
    "//src/lib/fuchsia",
    "//third_party/rust_crates:assert_matches",
  ]
  sources = [ "src/lib.rs" ]
  configs -= [ "//build/config/rust/lints:allow_unused_results" ]
}
