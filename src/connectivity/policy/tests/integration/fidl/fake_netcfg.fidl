library fuchsia.net.policy.testing;

using fuchsia.net.policy.properties;

@discoverable
closed protocol FakeNetcfg {
    strict UpdateProperties(struct {
        network_id uint64;
        is_default bool;
        updates vector<fuchsia.net.policy.properties.PropertyUpdate>:MAX;
    }) -> ();
};
