{
    include: [
        "//src/sys/test_runners/rust/default.shard.cml",
        "inspect/offer.shard.cml",
        "sys/component/realm_builder.shard.cml",
        "syslog/client.shard.cml",
    ],
    program: {
        binary: "bin/http_client_integration_test",
    },
    children: [
        {
            name: "netstack-debug",
            url: "#meta/netstack-debug.cm",
        },
        {
            name: "http-client-config-never-idle",
            url: "#meta/http-client-config-never-idle.cm",
        },
        {
            name: "http-client-config-idle-1ms",
            url: "#meta/http-client-config-idle-1ms.cm",
        },
    ],

    // We'll instantiate `http-client.cm` in one of these collections, which also
    // configures whether and how it should stop when there are momentarily no requests.
    collections: [
        {
            name: "never_idle",
            durability: "transient",
        },
        {
            name: "idle_1ms",
            durability: "transient",
        },
    ],
    use: [
        {
            protocol: "fuchsia.posix.socket.Provider",
            from: "#netstack-debug",
        },
        {
            event_stream: [
                "started",
                "stopped",
            ],
            from: "parent",
        },
    ],
    offer: [
        {
            config: "fuchsia.http-client.StopOnIdleTimeoutMillis",
            from: "#http-client-config-never-idle",
            to: "#never_idle",
        },
        {
            config: "fuchsia.http-client.StopOnIdleTimeoutMillis",
            from: "#http-client-config-idle-1ms",
            to: "#idle_1ms",
        },
        {
            protocol: "fuchsia.posix.socket.Provider",
            from: "#netstack-debug",
            to: [
                "#idle_1ms",
                "#never_idle",
            ],
        },

        // fuchsia_hyper::new_https_client fails if there isn't a file at /config/ssl/cert.pem, but
        // the unit tests don't actually make https connections and so don't need any certs, so we
        // can just give them an empty file instead of making them a system test and giving them the
        // system certs.
        {
            directory: "pkg",
            from: "framework",
            as: "root-ssl-certificates",
            to: [
                "#idle_1ms",
                "#never_idle",
            ],
            rights: [ "r*" ],
            subdir: "fake-ssl-certs",
        },
    ],
}
