group("testing") {
  testonly = true
  deps = [
    ":tests",
    "fuzzing",
    "loadbench",
  ]
}

group("tests") {
  testonly = true

  deps = [
    "catapult_converter:tests",
    "end_to_end/libs/tests:tests($host_toolchain)",
    "fuzzing:tests",
    "host-target-testing:tests",
    "loadbench:tests",
    "perfcompare:tests($host_toolchain)",
    "realm_client:tests",
    "sl4f:tests",
  ]
}

group("e2e_tests") {
  testonly = true

  deps = []

  if (!is_asan) {
    # Do not run host-driven tests on Fuchsia's `asan` build variant.
    deps += [ "end_to_end/mobly_driver/tests/functional_tests:tests" ]
  }
}
