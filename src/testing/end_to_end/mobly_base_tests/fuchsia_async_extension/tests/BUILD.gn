import("//build/python/python_host_test.gni")

assert(is_host,
       "fuchsia_async_extension_test only supported on a host toolchain")

python_host_test("fuchsia_async_extension_test") {
  main_source = "fuchsia_async_extension_test.py"
  libraries = [
    "//src/testing/end_to_end/mobly_base_tests/fuchsia_async_extension",
    "//third_party/mobly",
  ]
}

group("tests") {
  testonly = true
  public_deps = [ ":fuchsia_async_extension_test" ]
}
