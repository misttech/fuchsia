import("//build/python/python_mobly_test.gni")

assert(is_host, "smoke_test only supported in host toolchains")

python_mobly_test("smoke_test") {
  main_source = "mobly_driver_smoke_test.py"

  libraries = [ "//src/testing/end_to_end/mobly_driver/tests/functional_tests/smoke_test/trivial_controller" ]

  params_source = "params.yaml"

  # Used for infra Swarming bot allocation.
  environments = [
    {
      dimensions = {
        device_type = "AEMU"
      }
    },
  ]
}
