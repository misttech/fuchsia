import("//build/testing/environments.gni")

astro_ap_env = {
  dimensions = {
    access_points = "1"
    device_type = "Astro"
    pool = "fuchsia.tests.connectivity"
  }
  tags = [ "antlion" ]
}

astro_ap_iperf_env = {
  dimensions = {
    access_points = "1"
    device_type = "Astro"
    iperf_servers = "1"
    pool = "fuchsia.tests.connectivity"
  }
  tags = [ "antlion" ]
}

