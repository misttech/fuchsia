assert(is_host, "antlion tests only supported for host testing")

group("e2e_tests") {
  testonly = true
  public_deps = [
    "dhcp:e2e_tests",
    "wlan:e2e_tests",
    "wlan_policy:e2e_tests",

    # As tests are migrated out of the antlion directory, add them to this
    # group to ensure they are still included in the e2e test suite for
    # release testing.
    "//src/connectivity/wlan/tests/wlancfg:connection_stress_test",
    "//src/connectivity/wlan/tests/wlancfg:hidden_networks_test",
    "//src/connectivity/wlan/tests/wlancfg:policy_scan_test",
    "//src/connectivity/wlan/tests/wlancfg:regulatory_recovery_test",
    "//src/connectivity/wlan/tests/wlancfg:saved_networks_test",
    "//src/connectivity/wlan/tests/wlancfg:start_stop_client_connections_test",
    "//src/connectivity/wlan/tests/wlancfg:wlan_misc_scenario_test",
  ]
}

group("e2e_tests_quick") {
  testonly = true
  public_deps = [
    "wlan:e2e_tests_quick",
    "wlan_policy:e2e_tests_quick",
  ]
}

# Test cases that are not run automatically in infra, they are only used for
# release testing.
group("e2e_tests_manual") {
  testonly = true
  public_deps = [
    "wlan:e2e_tests_manual",
    "//src/connectivity/wlan/tests/wlancfg:tests_for_release_testing",
  ]
}
