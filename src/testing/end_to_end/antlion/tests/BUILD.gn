assert(is_host, "antlion tests only supported for host testing")

group("e2e_tests") {
  testonly = true
  public_deps = [
    "dhcp:e2e_tests",
    "wlan:e2e_tests",
    "wlan_policy:e2e_tests",

    # As tests are migrated out of the antlion directory, add them to this
    # group to ensure they are still included in the e2e test suite for
    # release testing.
    "//src/connectivity/wlan/tests/wlancfg:regulatory_recovery_test",
    "//src/connectivity/wlan/tests/wlancfg:start_stop_client_connections_test",
  ]
}

group("e2e_tests_quick") {
  testonly = true
  public_deps = [
    "wlan:e2e_tests_quick",
    "wlan_policy:e2e_tests_quick",
  ]
}

group("e2e_tests_manual") {
  testonly = true
  public_deps = [ "wlan:e2e_tests_manual" ]
}
