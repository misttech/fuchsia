import("//build/python/python_library.gni")

group("e2e_tests_libs") {
  testonly = true

  deps = [ ":libs" ]
}

python_library("libs") {
  library_name = "libs"

  visibility = [
    ":*",
    "//src/testing/end_to_end/mobly_controller:*",
  ]

  sources = [
    "__init__.py",
    "openwrt_lib.py",
    "proc/job.py",
    "proc/runner.py",
    "ssh/connection.py",
    "ssh/formatter.py",
    "ssh/settings.py",
    "validation.py",
  ]
  source_root = "//src/testing/end_to_end/libs"
  library_deps = []
}
