import("//build/python/python_library.gni")

python_library("openwrt_access_point") {
  library_name = "openwrt_access_point"
  source_root = "."
  sources = [
    "__init__.py",
    "lib/__init__.py",
    "lib/access_point_config.py",
    "lib/access_point_config_mapper.py",
    "lib/capabilities.py",
    "lib/dhcp_config.py",
    "lib/dhcp_controller.py",
    "lib/hostapd_options.py",
    "lib/profiles/actiontec.py",
    "lib/profiles/asus.py",
    "lib/profiles/belkin.py",
    "lib/profiles/linksys.py",
    "lib/profiles/netgear.py",
    "lib/profiles/securifi.py",
    "lib/profiles/tplink.py",
    "lib/uci_bss_options.py",
    "lib/uci_options.py",
    "lib/uci_radio_options.py",
  ]

  library_deps = [ "//src/testing/end_to_end/libs" ]
}
