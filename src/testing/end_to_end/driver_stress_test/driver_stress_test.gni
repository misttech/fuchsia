import("//build/python/python_mobly_test.gni")

# Defines a declarative host-side driver start/stop stress test target.
#
# Parameters:
#   driver_url (required): Absolute component URL of the driver under test.
#   iterations (optional): Number of start/stop loop iterations. Default is 100.
#   mechanism (optional): Start/stop implementation mechanism. Options:
#     "host_restart" -> Executes process teardown via ffx driver restart.
#     "disable_enable" -> Dynamic unbinding without process destruction.
#     "both" (default) -> Executes both host_restart and disable_enable iterations.
#   devfs_paths (optional): List of relative string paths under /dev/ to track.
#   environments (optional): Hardware/emulator targeting block. Default is emu_env.
template("driver_restart_stress_test") {
  _dummy_invoker = {
    forward_variables_from(invoker, "*")
  }
  not_needed([ "_dummy_invoker" ])

  assert(defined(invoker.driver_url), "driver_url is required")
  assert(is_host,
         "driver_restart_stress_test is intended for host toolchain use only")

  python_mobly_test(target_name) {
    main_source = "//src/testing/end_to_end/driver_stress_test/test_runners/test_driver_restart_stress.py"
    libraries = [
      "//src/testing/end_to_end/driver_stress_test/driver_stress_lib",
      "//src/testing/end_to_end/mobly_base_tests/fuchsia_base_test",
    ]
    test_data_deps =
        [ "//src/developer/ffx/tools/driver:ffx_driver_tool_test_data" ]

    params = {
      driver_url = invoker.driver_url

      if (defined(invoker.iterations)) {
        iterations = invoker.iterations
      } else {
        iterations = 100
      }

      if (defined(invoker.mechanism)) {
        mechanism = invoker.mechanism
      } else {
        mechanism = "both"
      }

      if (defined(invoker.devfs_paths)) {
        devfs_paths = invoker.devfs_paths
      } else {
        devfs_paths = []
      }
    }

    if (defined(invoker.environments)) {
      environments = invoker.environments
    }
  }
}

