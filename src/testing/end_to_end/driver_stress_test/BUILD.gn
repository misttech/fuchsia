import("//src/testing/end_to_end/driver_stress_test/driver_stress_test.gni")

assert(is_host, "driver stress test targets only supported in host toolchain")

driver_restart_stress_test("example_driver_restart_stress_test") {
  # Note: This is an example placeholder driver URL.
  driver_url = "fuchsia-boot:///dummy#meta/dummy.cm"
  iterations = 1
}

driver_suspend_stress_test("example_driver_suspend_stress_test") {
  # Note: This is an example placeholder driver URL.
  driver_url = "fuchsia-boot:///dummy#meta/dummy.cm"
  iterations = 1
}

group("tests") {
  testonly = true
  deps = [
    ":example_driver_restart_stress_test",
    ":example_driver_suspend_stress_test",
  ]
}
