import("//build/python/python_host_test.gni")
import("//build/python/python_library.gni")
import("//build/testing/host_test_data.gni")

if (is_host) {
  python_host_test("control_flows_test") {
    main_source = "control_flows_test.py"
    libraries = [
      "//third_party/mobly",
      "//src/testing/end_to_end/honeydew",
      "//third_party/parameterized",
    ]
  }
}

# Group containing all of the functional test cases for "utils" and their dependencies.
group("tests") {
  testonly = true
  public_deps = [ ":control_flows_test($host_toolchain)" ]
}
