import("//build/python/python_host_test.gni")

assert(is_host)

python_host_test("inspect_test") {
  main_source = "inspect_test.py"
  libraries = [ "//src/testing/end_to_end/honeydew" ]
  main_callable = "unittest.main"
  extra_args = [ "-v" ]
}

python_host_test("screenshot_test") {
  main_source = "screenshot_test.py"
  libraries = [
    "//third_party/mobly",
    "//src/testing/end_to_end/honeydew",
    "//third_party/parameterized",
  ]
}

python_host_test("control_flows_test") {
  main_source = "control_flows_test.py"
  libraries = [
    "//third_party/mobly",
    "//src/testing/end_to_end/honeydew",
    "//third_party/parameterized",
  ]
}

group("tests") {
  testonly = true
  public_deps = [
    ":control_flows_test",
    ":inspect_test",
    ":screenshot_test",
  ]
}
