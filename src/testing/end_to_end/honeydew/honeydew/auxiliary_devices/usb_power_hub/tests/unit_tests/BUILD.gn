import("//build/python/python_host_test.gni")

if (is_host) {
  python_host_test("usb_power_hub_using_dmc_test") {
    main_source = "usb_power_hub_using_dmc_test.py"
    libraries = [
      "//src/testing/end_to_end/honeydew",
      "//third_party/parameterized",
    ]
    main_callable = "unittest.main"
    extra_args = [ "-v" ]
  }
  python_host_test("linux_virtual_usb_hub_test") {
    main_source = "linux_virtual_usb_hub_test.py"
    libraries = [ "//src/testing/end_to_end/honeydew" ]
    main_callable = "unittest.main"
    extra_args = [ "-v" ]
  }
}

group("tests") {
  testonly = true
  public_deps = [
    ":linux_virtual_usb_hub_test($host_toolchain)",
    ":usb_power_hub_using_dmc_test($host_toolchain)",
  ]
}
