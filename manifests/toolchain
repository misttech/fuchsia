             version="git_revision:4e4dd43dc83e6aab6fedc61bdb4a9f6a8508640d"
             platforms="linux-amd64,linux-arm64"
             path="prebuilt/third_party/go/{{.OS}}-{{.Arch}}"/>

    <!-- LLDB
         TODO(mcgrathr): repo/bot link about provenance
    -->
