             platforms="linux-amd64,linux-arm64"
             path="prebuilt/third_party/gn/{{.OS}}-{{.Arch}}"/>

    <!-- Ninja from https://ninja-build.org/ -->
    <!-- TODO(phosek): link to bot/recipe/autoroller(?) -->
