             version="version:2@3.11.3.chromium.29"
             platforms="linux-amd64,linux-arm64"
             path="prebuilt/third_party/python3/{{.OS}}-{{.Arch}}"/>

    <!-- Black - Python formatter for formatting Python code.
    -->
