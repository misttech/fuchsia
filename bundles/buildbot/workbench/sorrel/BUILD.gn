import("//build/assembly/product_bundle_test_group.gni")
import("//build/testing/environments.gni")

product_bundle_test_group("stable") {
  product_bundle_name = "workbench_eng.sorrel"
  environments = [ sorrel_env ]
  target_tests = [ "//src/sys/component_manager:hermetic_tests" ]
}

product_bundle_test_group("staging") {
  product_bundle_name = "workbench_eng.sorrel"
  environments = [ sorrel_env ]
  host_tests = [ "//src/tests/end_to_end/power/suspend_resume:suspend_resume_test($host_toolchain)" ]
  tests = []
}

product_bundle_test_group("stable_bluetooth") {
  product_bundle_name = "workbench_eng.sorrel"
  environments = [ bt_lacewing_sorrel_env ]
  tests = []
}

product_bundle_test_group("staging_bluetooth") {
  product_bundle_name = "workbench_eng.sorrel"
  environments = [ bt_lacewing_sorrel_env ]
  target_tests =
      [ "//src/tests/end_to_end/connectivity/bluetooth:e2e_tests_smoke" ]
}

product_bundle_test_group("stable_wlan") {
  product_bundle_name = "workbench_eng.sorrel"
  environments = [ wlan_sorrel_ap_env ]
  tests = []
}

product_bundle_test_group("staging_wlan") {
  product_bundle_name = "workbench_eng.sorrel"
  environments = [ wlan_sorrel_ap_env ]
  host_tests = [
    "//src/testing/end_to_end/antlion/tests/wlan/compliance:vape_interop_test",
    "//src/testing/end_to_end/antlion/tests/wlan/compliance:wlan_phy_compliance_abg_test",
    "//src/testing/end_to_end/antlion/tests/wlan/compliance:wlan_security_compliance_11a_test",
    "//src/testing/end_to_end/antlion/tests/wlan/compliance:wlan_security_compliance_11bg_test",
    "//src/testing/end_to_end/antlion/tests/wlan/functional:beacon_loss_test",
    "//src/testing/end_to_end/antlion/tests/wlan_policy:hidden_networks_test",
    "//src/testing/end_to_end/antlion/tests/wlan_policy:policy_scan_test",
    "//src/testing/end_to_end/antlion/tests/wlan_policy:saved_networks_test",
    "//src/testing/end_to_end/honeydew/honeydew/affordances/connectivity/wlan/wlan_policy/tests/functional_tests",
  ]
}
