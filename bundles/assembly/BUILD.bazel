#
# The /core realm AIBs
#
# These are the Assembly Input Bundles that are included by all assembled
# systems that include the `/core` realm.
# core_realm
#
# This AIB adds the `/core` realm itself, and it's mandatory children.  The
# other AIBs in this group add shards and optional children of `/core`.
#
# This is "less than minimal".  "utility" systems include this to get a `/core`
# realm, but do not include the `common_standard` AIB as that brings in too much
# functionality for these specialized systems.
#
# All children in `/core` receive InspectSink and LogSink.
#
# buildifier: leave-alone
assembly_input_bundle(
    name = "core_realm",
    auto_include_in = [
        "standard",
        "utility",
    ],
    bootfs_packages = [
        "//bundles/assembly/bazel_inputs/src/sys/pkg/bin/pkg-cache",
    ],
    base_packages = [
        # This is a required dependency of pkg-cache
        "//bundles/assembly/bazel_inputs/src/sys/pkg/bin/system-update-committer",
        # Build-Information
        "//bundles/assembly/bazel_inputs/src/developer/build_info:build-info-service",
        # Developer.
        "//bundles/assembly/bazel_inputs/src/developer/forensics:pkg",
    ],
    drivers = [
        {
            "set": "base",
            # Fallback driver for uart nodes.
            "package_target": "//bundles/assembly/bazel_inputs/src/devices/serial/drivers/serial:package",
            "driver_components": ["meta/serial.cm"],
        },
    ],
    root_shards = [
        "//src/sys/core:meta/core.root_shard.cml",
    ],
    bootstrap_shards = [
        "//src/devices/bin/driver_framework:meta/base_drivers.bootstrap_shard.cml",
        "//src/sys/pkg/bin/pkg-cache:meta/pkg-cache.bootstrap_shard.cml",
    ],
    core_shards = [
        "//src/sys/core:meta/core.cml",

        # TODO:  These shards should be folded into the above
        # `core.cml` file itself as they are never omitted from it.
        # TODO:  These shards should be folded into the above
        # `core.cml` file itself as they are never omitted from it.
        "//src/developer/build_info:meta/build_info.core_shard.cml",
        "//src/developer/forensics:forensics.core_shard.cml",
        "//sdk/lib/inspect:offer.shard.cml",
    ],
    compiled_packages = [
        {
            # These are not included into the core.cml directly, but may be included
            # via other shards.
            "component_includes": [
                {
                    "source": "//sdk/lib/inspect:offer.shard.cml",
                    "destination": "inspect/offer.shard.cml",
                },
                {
                    "source": "//sdk/lib/syslog:offer.shard.cml",
                    "destination": "syslog/offer.shard.cml",
                },
                {
                    "source": "//src/connectivity/bluetooth/profiles/bt-a2dp:meta/bt-a2dp-common.core_shard.cml",
                    "destination": "src/connectivity/bluetooth/profiles/bt-a2dp/meta/bt-a2dp-common.core_shard.cml",
                },
                {
                    "source": "//src/intl/intl_services:meta/intl.core_shard.base.cml",
                    "destination": "src/intl/intl_services/meta/intl.core_shard.base.cml",
                },
                {
                    "source": "//src/recovery/system/meta/core_shards:base.shard.cml",
                    "destination": "src/recovery/system/meta/core_shards/base.shard.cml",
                },
                {
                    "source": "//src/recovery/system/meta/core_shards:ui.shard.cml",
                    "destination": "src/recovery/system/meta/core_shards/ui.shard.cml",
                },
                {
                    "source": "//src/session/bin/session_manager:meta/session_manager.core_shard.cml",
                    "destination": "src/session/bin/session_manager/meta/session_manager.core_shard.cml",
                },
                {
                    "source": "//src/settings/service:meta/setui_service_base.core_shard.cml",
