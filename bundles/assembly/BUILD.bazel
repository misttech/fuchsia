# buildifier: leave-alone
assembly_input_bundle(
    name = "bootstrap",
    auto_include_in = [
        "bootstrap",
        "utility",
        "standard",
    ],
    bootfs_packages = select({
        "//conditions:default": _BOOTSTRAP_AIB_BOOTSTRAP_PKGS,
        # Enabling profiling fundamentally changes how the platform is
        # compiled and requires the addition of instrumentation_data_processor
        # package in bootfs packages to collect and process profiles.
        "//build/bazel/config/select/is_profile:true": _BOOTSTRAP_AIB_BOOTSTRAP_PKGS + [
            "//bundles/assembly/bazel_inputs/src/sys/instrumentation_data_processor:instrumentation_data_processor_pkg",
        ],
    }),
    bootstrap_shards = select({
        "//conditions:default": _BOOTSTRAP_AIB_BOOTSTRAP_SHARDS,
        # Enabling profiling fundamentally changes how the platform is
        # compiled and requires the addition of instrumentation_data_processor
        # shard to the bootstrap shard list.
        "//build/bazel/config/select/is_profile:true": _BOOTSTRAP_AIB_BOOTSTRAP_SHARDS + [
            "//src/sys/instrumentation_data_processor:meta/instrumentation_data_processor.bootstrap_shard.cml",
