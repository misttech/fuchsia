import("//build/bazel/export_fuchsia_package_to_bazel.gni")
import("//third_party/sbase/binaries.gni")

foreach(bin, sbase_binaries) {
  export_fuchsia_package_to_bazel("${bin}_pkg") {
    package = "//third_party/sbase:${bin}_pkg"
  }
}
