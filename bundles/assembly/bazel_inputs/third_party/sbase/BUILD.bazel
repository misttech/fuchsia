load("//build/bazel/rules/packages:prebuilt_package.bzl", "prebuilt_package")
load(
    "//third_party/sbase:binaries.bzl",
    "sbase_binaries",
)

package(
    default_applicable_licenses = ["//:license"],
    default_visibility = ["//bundles/assembly:__subpackages__"],
)

[
    prebuilt_package(
        name = "%s_pkg" % bin,
        archive = "@gn_targets//bundles/assembly/bazel_inputs/third_party/sbase:%s_pkg" % bin,
    )
    for bin in sbase_binaries
]
